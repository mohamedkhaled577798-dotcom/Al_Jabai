@using PropertyManagement.Application.Constants
@model PropertyManagement.Application.DTOs.Templates.ContractTemplateDto
@{
    ViewData["Title"] = "تفاصيل القالب";
    var allVariables = ViewBag.VariableCatalog as List<TemplateVariableInfo> ?? new List<TemplateVariableInfo>();
    var foundVars = allVariables.Where(v => Model.ExtractedVariables.Contains(v.Key)).ToList();
    var missingVars = allVariables.Where(v => Model.MissingVariables.Contains(v.Key)).ToList();
}

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
            <div>
                <h3 class="mb-2">@Model.Name</h3>
                <div class="d-flex flex-wrap gap-2">
                    <span class="badge bg-primary">@Model.ContractTypeName</span>
                    <span class="badge @(Model.IsActive ? "bg-success" : "bg-secondary")">@(Model.IsActive ? "نشط" : "غير نشط")</span>
                    <span class="badge bg-dark">الإصدار @Model.Version</span>
                </div>
                <div class="text-muted small mt-2">آخر تحليل: @(Model.LastParsedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</div>
            </div>
            <div class="d-flex flex-wrap gap-2">
                <a class="btn btn-outline-primary" asp-action="Download" asp-route-id="@Model.Id">تحميل الملف (.docx)</a>
                @Html.AntiForgeryToken()
                <button type="button" class="btn btn-outline-warning" id="reparseTemplateBtn" data-template-id="@Model.Id">إعادة التحليل</button>
                <a class="btn btn-outline-secondary" asp-action="Edit" asp-route-id="@Model.Id">تعديل</a>
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('هل أنت متأكد من حذف القالب؟');">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-danger">حذف</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-3 col-6">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="h3 text-success mb-0">@Model.ExtractedVariables.Count</div>
            <small class="text-muted">المتغيرات المستخدمة</small>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <a href="#missingVars" class="text-decoration-none">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="h3 text-warning mb-0">@Model.MissingVariables.Count</div>
                <small class="text-muted">المتغيرات المفقودة</small>
            </div>
        </a>
    </div>
    <div class="col-md-3 col-6">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="h3 text-info mb-0">@Model.CustomVariables.Count</div>
            <small class="text-muted">المتغيرات المخصصة</small>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="h5 mb-0">@Model.FileSizeDisplay</div>
            <small class="text-muted">حجم الملف</small>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <h5 class="mb-3">تحليل المتغيرات</h5>
        <div class="accordion" id="detailsParseAccordion">
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button bg-success-subtle" type="button" data-bs-toggle="collapse" data-bs-target="#detailsFound">
                        المتغيرات الموجودة في الملف
                    </button>
                </h2>
                <div id="detailsFound" class="accordion-collapse collapse show" data-bs-parent="#detailsParseAccordion">
                    <div class="accordion-body p-0">
                        <div class="table-responsive">
                            <table class="table table-sm mb-0">
                                <thead class="table-light"><tr><th>المتغير</th><th>الاسم</th><th>التصنيف</th><th>قيمة تجريبية</th></tr></thead>
                                <tbody>
                                @if (!foundVars.Any())
                                {
                                    <tr><td colspan="4" class="text-center text-muted">لا يوجد</td></tr>
                                }
                                else
                                {
                                    @foreach (var variable in foundVars)
                                    {
                                        <tr>
                                            <td><code class="var-chip">@variable.Placeholder</code></td>
                                            <td>@variable.Label</td>
                                            <td><span class="badge bg-secondary">@variable.Group</span></td>
                                            <td class="text-muted fst-italic">@variable.SampleValue</td>
                                        </tr>
                                    }
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="accordion-item" id="missingVars">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed bg-warning-subtle" type="button" data-bs-toggle="collapse" data-bs-target="#detailsMissing">
                        المتغيرات المفقودة
                    </button>
                </h2>
                <div id="detailsMissing" class="accordion-collapse collapse" data-bs-parent="#detailsParseAccordion">
                    <div class="accordion-body p-0">
                        <div class="table-responsive">
                            <table class="table table-sm mb-0">
                                <thead class="table-light"><tr><th>المتغير</th><th>الاسم</th><th>التصنيف</th><th>قيمة تجريبية</th></tr></thead>
                                <tbody>
                                @if (!missingVars.Any())
                                {
                                    <tr><td colspan="4" class="text-center text-muted">لا يوجد</td></tr>
                                }
                                else
                                {
                                    @foreach (var variable in missingVars)
                                    {
                                        <tr>
                                            <td><code class="var-chip">@variable.Placeholder</code></td>
                                            <td>@variable.Label</td>
                                            <td><span class="badge bg-secondary">@variable.Group</span></td>
                                            <td class="text-muted fst-italic">@variable.SampleValue</td>
                                        </tr>
                                    }
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed bg-info-subtle" type="button" data-bs-toggle="collapse" data-bs-target="#detailsCustom">
                        متغيرات مخصصة
                    </button>
                </h2>
                <div id="detailsCustom" class="accordion-collapse collapse" data-bs-parent="#detailsParseAccordion">
                    <div class="accordion-body p-0">
                        <div class="table-responsive">
                            <table class="table table-sm mb-0">
                                <thead class="table-light"><tr><th>المتغير</th><th>ملاحظة</th></tr></thead>
                                <tbody>
                                @if (!Model.CustomVariables.Any())
                                {
                                    <tr><td colspan="2" class="text-center text-muted">لا يوجد</td></tr>
                                }
                                else
                                {
                                    @foreach (var custom in Model.CustomVariables)
                                    {
                                        <tr>
                                            <td><code class="var-chip">@($"{{{{{custom}}}}}")</code></td>
                                            <td class="text-muted">ستُترك كما هي إذا لم يتم تعريفها</td>
                                        </tr>
                                    }
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-3">
            <a class="btn btn-primary" asp-controller="Contracts" asp-action="Create" asp-route-templateId="@Model.Id">إنشاء عقد بهذا القالب</a>
        </div>
    </div>
</div>
