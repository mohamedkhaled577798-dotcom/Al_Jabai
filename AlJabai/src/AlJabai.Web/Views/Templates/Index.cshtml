@model IEnumerable<PropertyManagement.Domain.Entities.ContractTemplate>
@{ ViewData["Title"] = "قوالب العقود"; }
<div class="d-flex justify-content-between align-items-center mb-3"><h3>قوالب العقود</h3><a class="btn btn-primary" asp-action="Create">إضافة قالب</a></div>
<table class="table table-striped"><thead><tr><th>الاسم</th><th>النوع</th><th>الإصدار</th><th>الحالة</th><th>آخر تحليل</th><th>إجراءات</th></tr></thead><tbody>@foreach(var t in Model){<tr><td>@t.Name</td><td>@t.ContractType</td><td>@t.Version</td><td>@(t.IsActive?"نشط":"غير نشط")</td><td>@(t.LastParsedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td><td class="d-flex gap-1"><a class="btn btn-sm btn-outline-info" asp-action="Details" asp-route-id="@t.Id">تفاصيل</a><a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@t.Id">تعديل</a><a class="btn btn-sm btn-outline-secondary" asp-action="Download" asp-route-id="@t.Id">تحميل</a></td></tr>}</tbody></table>