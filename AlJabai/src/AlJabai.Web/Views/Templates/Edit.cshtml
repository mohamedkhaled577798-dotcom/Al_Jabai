@model PropertyManagement.Application.DTOs.Templates.UpdateTemplateDto
@{
    ViewData["Title"] = "تعديل قالب";
}

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <h4 class="mb-3">تعديل القالب</h4>
        <form method="post" enctype="multipart/form-data" class="row g-3">
            @Html.AntiForgeryToken()
            <div class="col-md-6">
                <label asp-for="Name" class="form-label">الاسم</label>
                <input asp-for="Name" class="form-control" />
            </div>
            <div class="col-md-6">
                <label asp-for="ContractType" class="form-label">النوع</label>
                <select asp-for="ContractType" class="form-select">
                    <option value="1">شهري</option>
                    <option value="2">سنوي</option>
                    <option value="3">متعدد السنوات</option>
                    <option value="4">تجاري</option>
                    <option value="5">BOT</option>
                    <option value="6">انتفاع</option>
                </select>
            </div>
            <div class="col-md-12">
                <label asp-for="DocxFile" class="form-label">رفع ملف Word جديد (اختياري)</label>
                <input asp-for="DocxFile" type="file" class="form-control" accept=".docx" />
            </div>
            <div class="col-md-6">
                <label asp-for="RequiredFieldsJson" class="form-label">الحقول المطلوبة JSON</label>
                <textarea asp-for="RequiredFieldsJson" class="form-control" rows="3"></textarea>
            </div>
            <div class="col-md-6">
                <label asp-for="DefaultClausesJson" class="form-label">بنود افتراضية JSON</label>
                <textarea asp-for="DefaultClausesJson" class="form-control" rows="3"></textarea>
            </div>
            <div class="col-12 form-check">
                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                <label asp-for="IsActive" class="form-check-label">القالب نشط</label>
            </div>
            <div class="col-12 d-flex gap-2">
                <button class="btn btn-primary">تحديث</button>
                <a class="btn btn-outline-secondary" asp-action="Index">إلغاء</a>
            </div>
        </form>
    </div>
</div>
