@model WaqfSystem.Application.DTOs.Document.PropertyDocumentSummaryDto

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">ملخص الوثائق</h5>
            <div class="d-flex gap-2">
                <a class="btn btn-sm btn-success" href="@Url.Action("Upload", "Documents", new { propertyId = Model.PropertyId })">رفع وثيقة</a>
                <a class="btn btn-sm btn-outline-primary" href="@Url.Action("ForProperty", "Documents", new { propertyId = Model.PropertyId })">عرض كل الوثائق</a>
            </div>
        </div>

        <div class="row g-2 mb-3">
            <div class="col-md-2"><div class="p-2 border rounded text-center"><div class="small text-muted">الإجمالي</div><div class="h5">@Model.TotalDocuments</div></div></div>
            <div class="col-md-2"><div class="p-2 border rounded text-center"><div class="small text-muted">معتمدة</div><div class="h5 text-success">@Model.VerifiedCount</div></div></div>
            <div class="col-md-2"><div class="p-2 border rounded text-center"><div class="small text-muted">معلقة</div><div class="h5 text-primary">@Model.PendingCount</div></div></div>
            <div class="col-md-2"><div class="p-2 border rounded text-center"><div class="small text-muted">منتهية</div><div class="h5 text-danger">@Model.ExpiredCount</div></div></div>
            <div class="col-md-4"><div class="p-2 border rounded text-center"><div class="small text-muted">الامتثال</div><div class="h5">@Model.CompliancePercent.ToString("0")%</div><div class="progress"><div class="progress-bar bg-success" style="width:@Model.CompliancePercent%"></div></div></div></div>
        </div>

        @if (Model.MissingRequiredTypes.Any())
        {
            <div class="alert alert-warning mb-0">
                <div class="fw-bold mb-1">أنواع إلزامية مفقودة</div>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var miss in Model.MissingRequiredTypes)
                    {
                        <span class="badge text-bg-warning">@miss</span>
                    }
                </div>
            </div>
        }
    </div>
</div>
