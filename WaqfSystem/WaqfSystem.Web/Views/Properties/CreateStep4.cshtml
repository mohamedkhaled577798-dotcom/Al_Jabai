@model WaqfSystem.Web.ViewModels.Properties.PropertyCreateViewModel
@{
    ViewData["Title"] = "إضافة بناية — الخطوة 4: تفاصيل البناية";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
<style>
    .facility-check {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }
    .facility-check label {
        display: flex;
        align-items: center;
        gap: 6px;
        border: 1px solid #dee2e6;
        border-radius: 8px;
        padding: 6px 12px;
        cursor: pointer;
        font-size: 13px;
        font-weight: 500;
        transition: all 0.2s ease;
        user-select: none;
        background: #fff;
    }
    .facility-check label:hover {
        border-color: #0D5C3A;
        background: #f0fdf4;
    }
    .facility-check label:has(input:checked) {
        border-color: #0D5C3A;
        background: #dcfce7;
        color: #0D5C3A;
    }
    .facility-check input[type=checkbox] {
        display: none;
    }
    .floor-accordion .accordion-button:not(.collapsed) {
        background: #f0fdf4;
        color: #0D5C3A;
        box-shadow: none;
    }
    .floor-badge {
        font-size: 11px;
        background: #dcfce7;
        color: #0D5C3A;
        padding: 2px 8px;
        border-radius: 10px;
        font-weight: 700;
    }
    .unit-row {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr 100px auto;
        gap: 8px;
        align-items: center;
        margin-bottom: 8px;
        padding: 8px;
        background: #fafafa;
        border-radius: 8px;
        border: 1px solid #f0f0f0;
    }
    @@media (max-width: 768px) {
        .unit-row {
            grid-template-columns: 1fr 1fr;
        }
    }
    .btn-add-unit {
        border: 1.5px dashed #0D5C3A;
        color: #0D5C3A;
        background: transparent;
        font-size: 12px;
        padding: 5px 14px;
        border-radius: 8px;
        transition: all 0.2s;
    }
    .btn-add-unit:hover {
        background: #dcfce7;
        border-style: solid;
    }
    .form-section {
        background: #fff;
        border-radius: 10px;
        padding: 20px;
        margin-bottom: 16px;
        border: 1px solid #f0f0f0;
    }
    .section-heading {
        font-size: 15px;
        font-weight: 700;
        color: #0D5C3A;
        border-bottom: 2px solid #dcfce7;
        padding-bottom: 6px;
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .unit-label {
        font-size: 11px;
        color: #6c757d;
        font-weight: 600;
        margin-bottom: 2px;
    }
    .required-star { color: #dc3545; }
</style>
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Property" asp-action="Index">الأملاك</a></li>
        <li class="breadcrumb-item"><a asp-controller="Properties" asp-action="Create">إضافة بناية</a></li>
        <li class="breadcrumb-item active">تفاصيل البناية</li>
    </ol>
</nav>

<div class="d-flex align-items-center mb-3">
    <h5 class="mb-0 fw-bold">
        <i class="bi bi-layers-fill text-success me-2"></i>
        تفاصيل البناية والطوابق والوحدات
    </h5>
</div>

@await Html.PartialAsync("_WizardPartials", Model)

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <strong>يوجد أخطاء:</strong>
        <div asp-validation-summary="All" class="mt-1 mb-0" style="font-size:13px"></div>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form asp-controller="Properties" asp-action="CreateStep4" method="post" id="step4Form">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="DraftKey" />
    <input type="hidden" asp-for="CurrentStep" value="4" />

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">

            @* SECTION: خصائص البناية العامة *@
            <div class="form-section">
                <div class="section-heading">
                    <i class="bi bi-building-fill"></i> الخصائص العامة للبناية
                </div>
                <div class="row g-3">
                    <div class="col-md-2">
                        <label asp-for="BuildingDetails.FloorCount" class="form-label fw-semibold">
                            عدد الطوابق <span class="required-star">*</span>
                        </label>
                        <input asp-for="BuildingDetails.FloorCount"
                               type="number" min="1" max="100"
                               class="form-control form-control-sm"
                               id="floorCountInput"
                               onchange="rebuildFloors()" />
                        <span asp-validation-for="BuildingDetails.FloorCount" class="text-danger" style="font-size:12px"></span>
                    </div>
                    <div class="col-md-2">
                        <label asp-for="BuildingDetails.BasementCount" class="form-label fw-semibold">عدد البدرومات</label>
                        <input asp-for="BuildingDetails.BasementCount"
                               type="number" min="0" max="10"
                               class="form-control form-control-sm"
                               id="basementCountInput"
                               onchange="rebuildFloors()" />
                        <span asp-validation-for="BuildingDetails.BasementCount" class="text-danger" style="font-size:12px"></span>
                    </div>
                    <div class="col-md-2">
                        <label asp-for="BuildingDetails.ConstructionYear" class="form-label fw-semibold">سنة البناء</label>
                        <input asp-for="BuildingDetails.ConstructionYear"
                               type="number" min="1800" max="2025"
                               class="form-control form-control-sm" placeholder="مثال: 1990" />
                        <span asp-validation-for="BuildingDetails.ConstructionYear" class="text-danger" style="font-size:12px"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="BuildingDetails.FloorAreaSqm" class="form-label fw-semibold">مساحة الطابق (م²)</label>
                        <input asp-for="BuildingDetails.FloorAreaSqm"
                               type="number" step="0.01"
                               class="form-control form-control-sm" placeholder="مثال: 250" />
                        <span asp-validation-for="BuildingDetails.FloorAreaSqm" class="text-danger" style="font-size:12px"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="BuildingDetails.PrimaryUsage" class="form-label fw-semibold">الاستخدام الرئيسي</label>
                        <select asp-for="BuildingDetails.PrimaryUsage"
                                asp-items="Model.BuildingDetails.UsageOptions"
                                class="form-select form-select-sm"></select>
                        <span asp-validation-for="BuildingDetails.PrimaryUsage" class="text-danger" style="font-size:12px"></span>
                    </div>
                </div>
            </div>

            @* SECTION: المرافق المشتركة *@
            <div class="form-section">
                <div class="section-heading">
                    <i class="bi bi-stars"></i> المرافق المشتركة
                </div>
                <div class="facility-check">
                    <label>
                        <input asp-for="BuildingDetails.HasElevator" type="checkbox" />
                        🛗 مصعد
                    </label>
                    <label>
                        <input asp-for="BuildingDetails.HasParking" type="checkbox" />
                        🅿️ مواقف سيارات
                    </label>
                    <label>
                        <input asp-for="BuildingDetails.HasGenerator" type="checkbox" />
                        ⚡ مولد كهربائي
                    </label>
                    <label>
                        <input asp-for="BuildingDetails.HasCentralAC" type="checkbox" />
                        ❄️ تكييف مركزي
                    </label>
                    <label>
                        <input asp-for="BuildingDetails.HasRooftop" type="checkbox" />
                        🏠 سطح / روف
                    </label>
                    <label>
                        <input asp-for="BuildingDetails.HasWaterTank" type="checkbox" />
                        💧 خزان مياه
                    </label>
                    <label>
                        <input asp-for="BuildingDetails.HasSecurityCameras" type="checkbox" />
                        📷 كاميرات أمن
                    </label>
                    <label>
                        <input asp-for="BuildingDetails.HasPrayerRoom" type="checkbox" />
                        🕌 مصلى
                    </label>
                </div>
            </div>

            @* SECTION: تفاصيل الطوابق والوحدات *@
            <div class="form-section">
                <div class="section-heading">
                    <i class="bi bi-layout-split"></i> تفاصيل الطوابق والوحدات
                </div>

                <div class="accordion floor-accordion" id="floorsAccordion">
                    @for (int fi = 0; fi < Model.BuildingDetails.Floors.Count; fi++)
                    {
                        var floor = Model.BuildingDetails.Floors[fi];
                        bool isFirst = fi == 0;
                        <div class="accordion-item mb-2 border rounded" id="floorItem_@fi">
                            <h2 class="accordion-header">
                                <button class="accordion-button @(isFirst ? "" : "collapsed")"
                                        type="button"
                                        data-bs-toggle="collapse"
                                        data-bs-target="#floorBody_@fi"
                                        aria-expanded="@(isFirst ? "true" : "false")">
                                    <span class="floor-badge me-2">@floor.FloorDisplayName</span>
                                    <span class="text-muted ms-2" id="floorUnitCount_@fi"
                                          style="font-size:12px; font-weight:500">
                                        @floor.Units.Count وحدة
                                    </span>
                                </button>
                            </h2>
                            <div id="floorBody_@fi"
                                 class="accordion-collapse collapse @(isFirst ? "show" : "")">
                                <div class="accordion-body">

                                    @* Hidden indexed inputs *@
                                    <input type="hidden" name="BuildingDetails.Floors[@fi].FloorNumber"
                                           value="@floor.FloorNumber" />
                                    <input type="hidden" name="BuildingDetails.Floors[@fi].FloorLabel"
                                           value="@floor.FloorLabel" />

                                    <div class="row g-2 mb-3">
                                        <div class="col-md-3">
                                            <label class="form-label fw-semibold" style="font-size:12px">الاستخدام</label>
                                            <select name="BuildingDetails.Floors[@fi].FloorUsage"
                                                    class="form-select form-select-sm">
                                                @foreach (var opt in Model.BuildingDetails.FloorUsageOptions)
                                                {
                                                    <option value="@opt.Value"
                                                            selected="@(opt.Value == floor.FloorUsage ? "selected" : null)">
                                                        @opt.Text
                                                    </option>
                                                }
                                            </select>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label fw-semibold" style="font-size:12px">المساحة (م²)</label>
                                            <input type="number" step="0.01"
                                                   name="BuildingDetails.Floors[@fi].AreaSqm"
                                                   value="@floor.AreaSqm"
                                                   class="form-control form-control-sm"
                                                   placeholder="م²" />
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label fw-semibold" style="font-size:12px">الحالة الإنشائية</label>
                                            <select name="BuildingDetails.Floors[@fi].StructuralCondition"
                                                    class="form-select form-select-sm">
                                                @foreach (var opt in Model.BuildingDetails.StructuralConditionOptions)
                                                {
                                                    <option value="@opt.Value"
                                                            selected="@(opt.Value == floor.StructuralCondition ? "selected" : null)">
                                                        @opt.Text
                                                    </option>
                                                }
                                            </select>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label fw-semibold" style="font-size:12px">ارتفاع السقف (سم)</label>
                                            <input type="number"
                                                   name="BuildingDetails.Floors[@fi].CeilingHeightCm"
                                                   value="@floor.CeilingHeightCm"
                                                   class="form-control form-control-sm"
                                                   placeholder="مثال: 300" />
                                        </div>
                                        <div class="col-12">
                                            <div class="form-check">
                                                <input type="checkbox"
                                                       name="BuildingDetails.Floors[@fi].HasBalcony"
                                                       class="form-check-input"
                                                       id="hasBalcony_@fi"
                                                       value="true"
                                                       @(floor.HasBalcony ? "checked" : "") />
                                                <label class="form-check-label" for="hasBalcony_@fi"
                                                       style="font-size:13px">يحوي شرفة / بلكون</label>
                                            </div>
                                        </div>
                                    </div>

                                    @* Units *@
                                    <div class="d-flex align-items-center justify-content-between mb-2">
                                        <span class="fw-semibold" style="font-size:13px; color:#495057">
                                            <i class="bi bi-door-open me-1"></i> الوحدات
                                        </span>
                                        <button type="button"
                                                class="btn-add-unit btn"
                                                onclick="addUnit(@fi)">
                                            <i class="bi bi-plus-circle me-1"></i> إضافة وحدة
                                        </button>
                                    </div>

                                    @* Units header *@
                                    <div class="unit-row" style="background:#f5f5f5; font-size:10px; font-weight:700; color:#6c757d; padding:4px 8px;">
                                        <span>نوع الوحدة</span>
                                        <span>المساحة (م²)</span>
                                        <span>حالة الإشغال</span>
                                        <span>الإيجار الشهري</span>
                                        <span></span>
                                    </div>

                                    <div id="unitsContainer_@fi">
                                        @for (int ui = 0; ui < floor.Units.Count; ui++)
                                        {
                                            var unit = floor.Units[ui];
                                            <div class="unit-row" id="unit_@(fi)_@ui">
                                                <div>
                                                    <select name="BuildingDetails.Floors[@fi].Units[@ui].UnitType"
                                                            class="form-select form-select-sm">
                                                        @foreach (var opt in Model.BuildingDetails.UnitTypeOptions)
                                                        {
                                                            <option value="@opt.Value"
                                                                    selected="@(opt.Value == unit.UnitType ? "selected" : null)">
                                                                @opt.Text
                                                            </option>
                                                        }
                                                    </select>
                                                </div>
                                                <div>
                                                    <input type="number" step="0.01"
                                                           name="BuildingDetails.Floors[@fi].Units[@ui].AreaSqm"
                                                           value="@unit.AreaSqm"
                                                           class="form-control form-control-sm"
                                                           placeholder="م²" />
                                                </div>
                                                <div>
                                                    <select name="BuildingDetails.Floors[@fi].Units[@ui].OccupancyStatus"
                                                            class="form-select form-select-sm">
                                                        @foreach (var opt in Model.BuildingDetails.OccupancyOptions)
                                                        {
                                                            <option value="@opt.Value"
                                                                    selected="@(opt.Value == unit.OccupancyStatus ? "selected" : null)">
                                                                @opt.Text
                                                            </option>
                                                        }
                                                    </select>
                                                </div>
                                                <div>
                                                    <input type="number" step="1000"
                                                           name="BuildingDetails.Floors[@fi].Units[@ui].MarketRentMonthly"
                                                           value="@unit.MarketRentMonthly"
                                                           class="form-control form-control-sm"
                                                           placeholder="د.ع" />
                                                </div>
                                                <div>
                                                    <button type="button"
                                                            class="btn btn-sm btn-outline-danger py-0 px-2"
                                                            onclick="removeUnit(this)"
                                                            title="حذف الوحدة">
                                                        <i class="bi bi-trash3"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        }
                                    </div>

                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="text-center mt-3">
                    <button type="button" class="btn btn-outline-success btn-sm px-4 rounded-pill shadow-sm" onclick="addFloor()">
                        <i class="bi bi-plus-circle-fill me-1"></i> إضافة طابق جديد
                    </button>
                </div>
            </div>

        </div>
        <div class="card-footer bg-white d-flex justify-content-between align-items-center py-3">
            <a asp-controller="Properties" asp-action="CreateStep3"
               asp-route-draftKey="@Model.DraftKey"
               class="btn btn-outline-secondary">
                <i class="bi bi-arrow-right me-1"></i> السابق
            </a>
            <button type="submit" class="btn btn-success px-4">
                التالي: المستندات
                <i class="bi bi-arrow-left ms-1"></i>
            </button>
        </div>
    </div>
</form>

@section Scripts {
<script>
    // ── Options arrays serialized from server ─────────────────────────────────
    const unitTypeOptions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model.BuildingDetails.UnitTypeOptions.Select(o => new { value = o.Value, text = o.Text })
    ));
    const occupancyOptions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model.BuildingDetails.OccupancyOptions.Select(o => new { value = o.Value, text = o.Text })
    ));
    const usageOptions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model.BuildingDetails.FloorUsageOptions.Select(o => new { value = o.Value, text = o.Text })
    ));
    const conditionOptions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model.BuildingDetails.StructuralConditionOptions.Select(o => new { value = o.Value, text = o.Text })
    ));

    function buildSelectOptions(options, selectedValue) {
        return options.map(o =>
            `<option value="${o.value}"${o.value === selectedValue ? ' selected' : ''}>${o.text}</option>`
        ).join('');
    }

    // ── addUnit ───────────────────────────────────────────────────────────────
    function addUnit(floorIdx) {
        const container = document.getElementById(`unitsContainer_${floorIdx}`);
        const existingUnits = container.querySelectorAll('.unit-row');
        const ui = existingUnits.length;

        const row = document.createElement('div');
        row.className = 'unit-row';
        row.id = `unit_${floorIdx}_${ui}`;
        row.innerHTML = `
            <div>
                <select name="BuildingDetails.Floors[${floorIdx}].Units[${ui}].UnitType"
                        class="form-select form-select-sm">
                    ${buildSelectOptions(unitTypeOptions, '')}
                </select>
            </div>
            <div>
                <input type="number" step="0.01"
                       name="BuildingDetails.Floors[${floorIdx}].Units[${ui}].AreaSqm"
                       class="form-control form-control-sm" placeholder="م²" />
            </div>
            <div>
                <select name="BuildingDetails.Floors[${floorIdx}].Units[${ui}].OccupancyStatus"
                        class="form-select form-select-sm">
                    ${buildSelectOptions(occupancyOptions, 'Vacant')}
                </select>
            </div>
            <div>
                <input type="number" step="1000"
                       name="BuildingDetails.Floors[${floorIdx}].Units[${ui}].MarketRentMonthly"
                       class="form-control form-control-sm" placeholder="د.ع" />
            </div>
            <div>
                <button type="button" class="btn btn-sm btn-outline-danger py-0 px-2"
                        onclick="removeUnit(this)" title="حذف الوحدة">
                    <i class="bi bi-trash3"></i>
                </button>
            </div>
        `;
        container.appendChild(row);
        updateUnitCount(floorIdx);
    }

    // ── removeUnit ────────────────────────────────────────────────────────────
    function removeUnit(btn) {
        const row = btn.closest('.unit-row');
        const rowId = row.id; // unit_{fi}_{ui}
        const parts = rowId.split('_');
        const floorIdx = parseInt(parts[1]);
        const container = document.getElementById(`unitsContainer_${floorIdx}`);

        const units = container.querySelectorAll('.unit-row');
        if (units.length <= 1) {
            alert('يجب أن يكون هناك وحدة واحدة على الأقل في كل طابق');
            return;
        }

        row.remove();

        // Re-index remaining rows
        const remaining = container.querySelectorAll('.unit-row');
        remaining.forEach((r, newUi) => {
            r.id = `unit_${floorIdx}_${newUi}`;
            r.querySelectorAll('input, select').forEach(el => {
                if (el.name) {
                    el.name = el.name.replace(
                        /BuildingDetails\.Floors\[\d+\]\.Units\[\d+\]/,
                        `BuildingDetails.Floors[${floorIdx}].Units[${newUi}]`
                    );
                }
            });
        });

        updateUnitCount(floorIdx);
    }

    // ── updateUnitCount ───────────────────────────────────────────────────────
    function updateUnitCount(fi) {
        const container = document.getElementById(`unitsContainer_${fi}`);
        if (!container) return;
        const count = container.querySelectorAll('.unit-row').length;
        const label = document.getElementById(`floorUnitCount_${fi}`);
        if (label) label.textContent = `${count} وحدة`;
    }

    // ── rebuildFloors (updates counts hint) ──────────────────────────────────
    function rebuildFloors() {
        const count = parseInt(document.getElementById('floorCountInput').value ?? 1);
        const basements = parseInt(document.getElementById('basementCountInput').value ?? 0);
        // This hint could be used to tell user to save/reload to auto-generate if they want, 
        // but since we added "Add Floor", it's less critical.
    }

    // ── addFloor ─────────────────────────────────────────────────────────────
    function addFloor() {
        const accordion = document.getElementById('floorsAccordion');
        const fi = accordion.querySelectorAll('.accordion-item').length;

        // Determine next floor number
        let maxFloor = -1;
        document.querySelectorAll('input[name$=".FloorNumber"]').forEach(input => {
            const val = parseInt(input.value);
            if (!isNaN(val) && val > maxFloor) maxFloor = val;
        });
        const newFloorNum = maxFloor + 1;
        const newFloorName = newFloorNum === 0 ? "الطابق الأرضي" : `الطابق ${newFloorNum}`;

        const item = document.createElement('div');
        item.className = 'accordion-item mb-2 border rounded';
        item.id = `floorItem_${fi}`;
        item.innerHTML = `
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" 
                        data-bs-target="#floorBody_${fi}" aria-expanded="false">
                    <span class="floor-badge me-2">${newFloorName}</span>
                    <span class="text-muted ms-2" id="floorUnitCount_${fi}" style="font-size:12px; font-weight:500">
                        1 وحدة
                    </span>
                </button>
            </h2>
            <div id="floorBody_${fi}" class="accordion-collapse collapse">
                <div class="accordion-body">
                    <input type="hidden" name="BuildingDetails.Floors[${fi}].FloorNumber" value="${newFloorNum}" />
                    <input type="hidden" name="BuildingDetails.Floors[${fi}].FloorLabel" value="${newFloorName}" />

                    <div class="row g-2 mb-3">
                        <div class="col-md-3">
                            <label class="form-label fw-semibold" style="font-size:12px">الاستخدام</label>
                            <select name="BuildingDetails.Floors[${fi}].FloorUsage" class="form-select form-select-sm">
                                ${buildSelectOptions(usageOptions, 'Residential')}
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-semibold" style="font-size:12px">المساحة (م²)</label>
                            <input type="number" step="0.01" name="BuildingDetails.Floors[${fi}].AreaSqm" class="form-control form-control-sm" placeholder="م²" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-semibold" style="font-size:12px">الحالة الإنشائية</label>
                            <select name="BuildingDetails.Floors[${fi}].StructuralCondition" class="form-select form-select-sm">
                                ${buildSelectOptions(conditionOptions, 'Excellent')}
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-semibold" style="font-size:12px">ارتفاع السقف (سم)</label>
                            <input type="number" name="BuildingDetails.Floors[${fi}].CeilingHeightCm" class="form-control form-control-sm" placeholder="مثال: 300" />
                        </div>
                        <div class="col-12">
                            <div class="form-check">
                                <input type="checkbox" name="BuildingDetails.Floors[${fi}].HasBalcony" class="form-check-input" id="hasBalcony_${fi}" value="true" />
                                <label class="form-check-label" for="hasBalcony_${fi}" style="font-size:13px">يحوي شرفة / بلكون</label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <span class="fw-semibold" style="font-size:13px; color:#495057">
                            <i class="bi bi-door-open me-1"></i> الوحدات
                        </span>
                        <button type="button" class="btn-add-unit btn" onclick="addUnit(${fi})">
                            <i class="bi bi-plus-circle me-1"></i> إضافة وحدة
                        </button>
                    </div>

                    <div class="unit-row" style="background:#f5f5f5; font-size:10px; font-weight:700; color:#6c757d; padding:4px 8px;">
                        <span>نوع الوحدة</span>
                        <span>المساحة (م²)</span>
                        <span>حالة الإشغال</span>
                        <span>الإيجار الشهري</span>
                        <span></span>
                    </div>

                    <div id="unitsContainer_${fi}">
                        <div class="unit-row" id="unit_${fi}_0">
                            <div>
                                <select name="BuildingDetails.Floors[${fi}].Units[0].UnitType" class="form-select form-select-sm">
                                    ${buildSelectOptions(unitTypeOptions, 'Apartment')}
                                </select>
                            </div>
                            <div>
                                <input type="number" step="0.01" name="BuildingDetails.Floors[${fi}].Units[0].AreaSqm" class="form-control form-control-sm" placeholder="م²" />
                            </div>
                            <div>
                                <select name="BuildingDetails.Floors[${fi}].Units[0].OccupancyStatus" class="form-select form-select-sm">
                                    ${buildSelectOptions(occupancyOptions, 'Vacant')}
                                </select>
                            </div>
                            <div>
                                <input type="number" step="1000" name="BuildingDetails.Floors[${fi}].Units[0].MarketRentMonthly" class="form-control form-control-sm" placeholder="د.ع" />
                            </div>
                            <div>
                                <button type="button" class="btn btn-sm btn-outline-danger py-0 px-2" onclick="removeUnit(this)" title="حذف الوحدة">
                                    <i class="bi bi-trash3"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        `;
        accordion.appendChild(item);

        // Update Floor Count Input
        const floorCountInput = document.getElementById('floorCountInput');
        if (floorCountInput && newFloorNum >= 0) {
            const currentTotal = accordion.querySelectorAll('.accordion-item').length;
            const basements = parseInt(document.getElementById('basementCountInput').value || 0);
            floorCountInput.value = currentTotal - basements;
        }

        // Collapse others and show new one
        bootstrap.Collapse.getOrCreateInstance(item.querySelector('.accordion-collapse')).show();
    }
</script>
@{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
