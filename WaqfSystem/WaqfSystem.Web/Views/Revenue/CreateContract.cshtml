@model WaqfSystem.Application.DTOs.Revenue.CreateContractDto
@{
    ViewData["Title"] = "إنشاء عقد";
}
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white"><h5 class="mb-0">إنشاء عقد إيجار</h5></div>
    <div class="card-body">
        <form method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-4"><label class="form-label">رقم العقار</label><input class="form-control" asp-for="PropertyId" /></div>
                <div class="col-md-4"><label class="form-label">رقم الطابق</label><input class="form-control" asp-for="FloorId" /></div>
                <div class="col-md-4"><label class="form-label">رقم الوحدة</label><input class="form-control" asp-for="UnitId" /></div>
                <div class="col-md-6"><label class="form-label">اسم المستأجر</label><input class="form-control" asp-for="TenantNameAr" /></div>
                <div class="col-md-6"><label class="form-label">الهاتف</label><input class="form-control" asp-for="TenantPhone" /></div>
                <div class="col-md-4"><label class="form-label">الإيجار</label><input class="form-control" asp-for="RentAmount" /></div>
                <div class="col-md-4"><label class="form-label">تاريخ البدء</label><input class="form-control" asp-for="StartDate" type="date" id="startDate" /></div>
                <div class="col-md-4"><label class="form-label">تاريخ الانتهاء</label><input class="form-control" asp-for="EndDate" type="date" id="endDate" /></div>
                <div class="col-md-4"><label class="form-label">فترة السماح بالأيام</label><input class="form-control" asp-for="GracePeriodDays" /></div>
                <div class="col-md-4"><label class="form-label">غرامة يومية</label><input class="form-control" asp-for="PenaltyPerDay" /></div>
                <div class="col-md-4 d-flex align-items-end"><div class="form-check"><input class="form-check-input" asp-for="AllowsPartialPayments" /><label class="form-check-label" asp-for="AllowsPartialPayments">السماح بالدفع الجزئي</label></div></div>
                <div class="col-12"><label class="form-label">ملاحظات</label><textarea class="form-control" asp-for="Notes"></textarea></div>
            </div>
            <div class="mt-3 d-flex gap-2">
                <button class="btn btn-success" type="submit">حفظ العقد</button>
                <a class="btn btn-outline-secondary" href="@Url.Action("Contracts", "Revenue")">رجوع</a>
            </div>
        </form>
        <div class="mt-3 border rounded p-3 bg-light">
            <div class="fw-semibold mb-2">معاينة جدول الدفعات</div>
            <div id="schedulePreview" class="small text-secondary">حدّد التاريخ والمبلغ لإظهار المعاينة</div>
        </div>
    </div>
</div>
@section Scripts {
<script>
function buildSchedulePreview() {
    const start = new Date(document.getElementById('startDate').value);
    const end = new Date(document.getElementById('endDate').value);
    const rent = Number(document.getElementById('RentAmount').value || 0);
    if (isNaN(start) || isNaN(end) || !rent || start > end) {
        document.getElementById('schedulePreview').textContent = 'حدّد التاريخ والمبلغ لإظهار المعاينة';
        return;
    }

    const rows = [];
    const cursor = new Date(start.getFullYear(), start.getMonth(), 1);
    const limit = new Date(end.getFullYear(), end.getMonth(), 1);
    while (cursor <= limit) {
        rows.push(`<div>${cursor.toLocaleDateString('ar-IQ', { year: 'numeric', month: 'long' })}: ${rent.toLocaleString('ar-IQ')} د.ع</div>`);
        cursor.setMonth(cursor.getMonth() + 1);
    }
    document.getElementById('schedulePreview').innerHTML = rows.join('');
}
['startDate', 'endDate', 'RentAmount'].forEach(id => document.getElementById(id)?.addEventListener('input', buildSchedulePreview));
buildSchedulePreview();
</script>
}
