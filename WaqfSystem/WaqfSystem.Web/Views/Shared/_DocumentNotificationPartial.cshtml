@using System.Security.Claims
@using WaqfSystem.Application.DTOs.Document
@inject WaqfSystem.Application.Services.IDocumentAlertService DocAlertService
@{
    var userId = int.TryParse(User.FindFirstValue(ClaimTypes.NameIdentifier), out var uid) ? uid : 0;
    var today = DateTime.UtcNow.Date;
    var items = userId > 0
        ? await DocAlertService.GetUnreadAlertsForUserAsync(userId)
        : new List<DocumentAlertDto>();
    var count = items.Count;
}

<div class="dropdown me-3">
    <a class="nav-link position-relative" href="#" id="docNotifDropdown" data-bs-toggle="dropdown" aria-expanded="false" title="تنبيهات الوثائق">
        <i class="bi bi-file-earmark-text fs-5"></i>
        @if (count > 0)
        {
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-warning text-dark">@count</span>
        }
    </a>
    <div class="dropdown-menu dropdown-menu-end shadow p-0" style="width:360px;">
        <div class="p-3 border-bottom">
            <div class="fw-bold">تنبيهات الوثائق</div>
            <div class="small text-muted">وثائق منتهية أو تنتهي خلال 30 يوما</div>
        </div>
        <div style="max-height:320px; overflow:auto;">
            @if (!items.Any())
            {
                <div class="p-3 text-muted text-center">لا توجد تنبيهات وثائق حالياً</div>
            }
            else
            {
                foreach (var item in items)
                {
                    var expiry = item.ExpiryDate?.Date;
                    var isExpired = expiry.HasValue && expiry.Value < today;
                    var days = expiry.HasValue ? (expiry.Value - today).Days : (int?)null;
                    <a class="dropdown-item border-bottom py-2" asp-controller="Documents" asp-action="Detail" asp-route-id="@item.DocumentId">
                        <div class="fw-semibold">@item.DocumentTypeNameAr - @item.PropertyWqfNumber</div>
                        <div class="small text-muted">
                            @item.DocumentTitle
                            @if (days.HasValue)
                            {
                                <text> | </text>
                                if (isExpired)
                                {
                                    <span class="text-danger">منتهية منذ @Math.Abs(days.Value) يوم</span>
                                }
                                else
                                {
                                    <span class="text-warning">متبقي @days يوم</span>
                                }
                            }
                        </div>
                    </a>
                }
            }
        </div>
        <div class="p-2 text-center">
            <a class="btn btn-sm btn-outline-primary" asp-controller="Documents" asp-action="Index">إدارة الوثائق</a>
        </div>
    </div>
</div>
