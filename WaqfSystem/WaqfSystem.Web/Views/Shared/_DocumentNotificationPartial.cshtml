@using Microsoft.EntityFrameworkCore
@using WaqfSystem.Infrastructure.Data
@inject WaqfDbContext DbContext
@{
    var today = DateTime.UtcNow.Date;
    var count = 0;
    var items = new List<(int PropertyId, string? DocumentType, string? DocumentNumber, DateTime? ExpiryDate, string? WaqfNumber)>();

    try
    {
        var alertWindowEnd = today.AddDays(30);

        var expiringQuery = DbContext.PropertyDocuments
            .AsNoTracking()
            .Where(d => !d.IsDeleted && d.ExpiryDate.HasValue && d.ExpiryDate.Value.Date <= alertWindowEnd);

        count = await expiringQuery.CountAsync();
        var dataList = await expiringQuery
            .OrderBy(d => d.ExpiryDate)
            .Take(5)
            .Select(d => new
            {
                d.PropertyId,
                d.DocumentType,
                d.DocumentNumber,
                d.ExpiryDate,
                WaqfNumber = d.Property.WqfNumber
            })
            .ToListAsync();

        items = dataList.Select(x => (x.PropertyId, x.DocumentType, x.DocumentNumber, x.ExpiryDate, x.WaqfNumber)).ToList();
    }
    catch
    {
        // Keep layout rendering even if document schema is not fully migrated.
    }
}

<div class="dropdown me-3">
    <a class="nav-link position-relative" href="#" id="docNotifDropdown" data-bs-toggle="dropdown" aria-expanded="false" title="تنبيهات الوثائق">
        <i class="bi bi-file-earmark-text fs-5"></i>
        @if (count > 0)
        {
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-warning text-dark">@count</span>
        }
    </a>
    <div class="dropdown-menu dropdown-menu-end shadow p-0" style="width:360px;">
        <div class="p-3 border-bottom">
            <div class="fw-bold">تنبيهات الوثائق</div>
            <div class="small text-muted">وثائق منتهية أو تنتهي خلال 30 يوما</div>
        </div>
        <div style="max-height:320px; overflow:auto;">
            @if (!items.Any())
            {
                <div class="p-3 text-muted text-center">لا توجد تنبيهات وثائق حالياً</div>
            }
            else
            {
                foreach (var item in items)
                {
                    var isExpired = item.ExpiryDate!.Value.Date < today;
                    var days = (item.ExpiryDate!.Value.Date - today).Days;
                    <a class="dropdown-item border-bottom py-2" asp-controller="Property" asp-action="Details" asp-route-id="@item.PropertyId">
                        <div class="fw-semibold">@(item.DocumentType ?? "مستند") - @item.WaqfNumber</div>
                        <div class="small text-muted">
                            @(string.IsNullOrWhiteSpace(item.DocumentNumber) ? "بدون رقم" : item.DocumentNumber)
                            |
                            @if (isExpired)
                            {
                                <span class="text-danger">منتهية منذ @Math.Abs(days) يوم</span>
                            }
                            else
                            {
                                <span class="text-warning">متبقي @days يوم</span>
                            }
                        </div>
                    </a>
                }
            }
        </div>
        <div class="p-2 text-center">
            <a class="btn btn-sm btn-outline-primary" asp-controller="Property" asp-action="Index">إدارة الوثائق</a>
        </div>
    </div>
</div>
