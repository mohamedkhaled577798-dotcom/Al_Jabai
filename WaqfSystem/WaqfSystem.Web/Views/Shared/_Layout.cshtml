<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - نظام حصر الأملاك | الوقف السني</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Outfit:wght@400;600;700&display=swap" rel="stylesheet">
    
    <!-- Bootstrap RTL -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <!-- Custom Styles -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div id="wrapper">
        <!-- Sidebar -->
        <nav id="sidebar">
            <div class="sidebar-header">
                <h4 class="mb-0">نظام حصر الأملاك</h4>
                <small class="text-muted">هيئة إدارة واستثمار أموال الوقف</small>
            </div>

            <ul class="list-unstyled components">
                <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                    <a asp-controller="Dashboard" asp-action="Index">
                        <i class="fas fa-chart-line me-2"></i> لوحة التحكم
                    </a>
                </li>
                <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Property" && string.IsNullOrEmpty(ViewContext.HttpContext.Request.Query["ownershipType"]) && string.IsNullOrEmpty(ViewContext.HttpContext.Request.Query["propertyType"]) ? "active" : "")">
                    <a asp-controller="Property" asp-action="Index">
                        <i class="fas fa-building me-2"></i> كافة العقارات
                    </a>
                </li>
                
                <li class="@(ViewContext.HttpContext.Request.Query["ownershipType"] == "FullWaqf" ? "active" : "")">
                    <a asp-controller="Property" asp-action="Index" asp-route-ownershipType="FullWaqf">
                        <i class="fas fa-shield-halved me-2"></i> الأملاك المظبوطة
                    </a>
                </li>

                <li class="@(ViewContext.HttpContext.Request.Query["ownershipType"] == "Partnership" ? "active" : "")">
                    <a asp-controller="Property" asp-action="Index" asp-route-ownershipType="Partnership">
                        <i class="fas fa-handshake me-2"></i> الأملاك الملحقة
                    </a>
                </li>

                <li class="@(ViewContext.HttpContext.Request.Query["propertyType"] == "Agricultural" ? "active" : "")">
                    <a asp-controller="Property" asp-action="Index" asp-route-propertyType="Agricultural">
                        <i class="fas fa-seedling me-2"></i> الأملاك الزراعية
                    </a>
                </li>

                <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Property" && ViewContext.HttpContext.Request.Query["view"] == "documents" ? "active" : "")">
                    <a asp-controller="Property" asp-action="Index" asp-route-view="documents">
                        <i class="fas fa-folder-open me-2"></i> إدارة الوثائق
                    </a>
                </li>

                <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Partnership" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                    <a asp-controller="Partnership" asp-action="Index">
                        <i class="fas fa-handshake me-2"></i> عقود الشراكة
                    </a>
                </li>

                <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Partnership" && ViewContext.RouteData.Values["action"]?.ToString() == "Partners" ? "active" : "")">
                    <a asp-controller="Partnership" asp-action="Partners">
                        <i class="fas fa-user-tie me-2"></i> دليل الشركاء والمستثمرين
                    </a>
                </li>

                <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Gis" ? "active" : "")">
                    <a asp-controller="Gis" asp-action="Explorer">
                        <i class="fas fa-map-marked-alt me-2"></i> مستكشف الخرائط
                    </a>
                </li>

                @{
                    var isMissionRoute = ViewContext.RouteData.Values["controller"]?.ToString() == "Missions";
                }
                <li class="@(isMissionRoute && ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")">
                    <a asp-controller="Missions" asp-action="Dashboard">
                        <i class="fas fa-gauge me-2"></i> لوحة المهام
                    </a>
                </li>
                <li class="@(isMissionRoute && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                    <a asp-controller="Missions" asp-action="Index">
                        <i class="fas fa-tasks me-2"></i> كل المهام
                    </a>
                </li>
                @if (User.IsInRole("FIELD_INSPECTOR"))
                {
                    <li class="@(isMissionRoute && ViewContext.RouteData.Values["action"]?.ToString() == "MyMissions" ? "active" : "")">
                        <a asp-controller="Missions" asp-action="MyMissions">
                            <i class="fas fa-user-check me-2"></i> مهامي
                        </a>
                    </li>
                }
                <li class="@(isMissionRoute && ViewContext.RouteData.Values["action"]?.ToString() == "Calendar" ? "active" : "")">
                    <a asp-controller="Missions" asp-action="Calendar">
                        <i class="fas fa-calendar-alt me-2"></i> الجدول
                    </a>
                </li>
                @if (User.IsInRole("SYS_ADMIN") || User.IsInRole("AUTH_DIRECTOR") || User.IsInRole("REGIONAL_MGR"))
                {
                    <li class="@(isMissionRoute && ViewContext.RouteData.Values["action"]?.ToString() == "Teams" ? "active" : "")">
                        <a asp-controller="Missions" asp-action="Teams">
                            <i class="fas fa-users me-2"></i> الفرق
                        </a>
                    </li>
                }
                @if (User.IsInRole("SYS_ADMIN") || User.IsInRole("AUTH_DIRECTOR") || User.IsInRole("REGIONAL_MGR") || User.IsInRole("FIELD_SUPERVISOR"))
                {
                    <li class="@(isMissionRoute && ViewContext.RouteData.Values["action"]?.ToString() == "PerformanceReport" ? "active" : "")">
                        <a asp-controller="Missions" asp-action="PerformanceReport">
                            <i class="fas fa-chart-column me-2"></i> الأداء
                        </a>
                    </li>
                }

                <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Report" ? "active" : "")">
                    <a asp-controller="Report" asp-action="Index">
                        <i class="fas fa-file-export me-2"></i> التقارير
                    </a>
                </li>

                <li class="nav-divider mt-3 mb-2 bg-secondary opacity-25" style="height:1px; list-style:none;"></li>

                <li>
                    <a href="/swagger" target="_blank">
                        <i class="fas fa-code me-2 text-info"></i> بوابة المطورين (API)
                    </a>
                </li>
                
                <li>
                    <a href="http://localhost:5000" target="_blank">
                        <i class="fas fa-globe-asia me-2"></i> نظام GIS المتقدم
                    </a>
                </li>
                <li>
                    <a href="http://localhost:5268" target="_blank">
                        <i class="fas fa-file-invoice-dollar me-2"></i> نظام الممتلكات (الجباية)
                    </a>
                </li>
                @if (User.IsInRole("SYS_ADMIN"))
                {
                    <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "User" ? "active" : "")">
                        <a asp-controller="User" asp-action="Index">
                            <i class="fas fa-user-shield me-2"></i> إدارة المستخدمين
                        </a>
                    </li>
                }
            </ul>
        </nav>

        <!-- Main Content -->
        <div id="content">
            <nav class="navbar navbar-expand-lg navbar-light glass mb-4 rounded-4 shadow-sm">
                <div class="container-fluid">
                    <button type="button" id="sidebarCollapse" class="btn btn-primary d-md-none">
                        <i class="fas fa-align-right"></i>
                    </button>
                    
                    <div class="ms-auto d-flex align-items-center">
                        @await Html.PartialAsync("_DocumentNotificationPartial")
                        @await Html.PartialAsync("_MissionNotificationPartial")
                        <div class="dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                <span class="me-2 d-none d-lg-inline text-gray-600 small">@User.Identity?.Name</span>
                                <div class="rounded-circle bg-light d-flex align-items-center justify-content-center" style="width:32px; height:32px">
                                    <i class="fas fa-user text-secondary"></i>
                                </div>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow">
                                <li><a class="dropdown-item" href="#"><i class="fas fa-id-card me-2"></i> الملف الشخصي</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        <button type="submit" class="dropdown-item text-danger border-0 bg-transparent w-100 text-start">
                                            <i class="fas fa-sign-out-alt me-2"></i> تسجيل الخروج
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </nav>

            <main role="main">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="fas fa-exclamation-triangle me-2"></i> @TempData["ErrorMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/signalr/dist/browser/signalr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
