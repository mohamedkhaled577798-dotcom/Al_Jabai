@model WaqfSystem.Application.DTOs.Document.UploadNewVersionDto
@{
    ViewData["Title"] = "رفع نسخة جديدة";
}

<h3 class="mb-3">رفع نسخة جديدة</h3>
<form asp-action="UploadVersion" asp-controller="Documents" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <input asp-for="DocumentId" type="hidden" />
    <div class="mb-3">
        <label class="form-label">الملف</label>
        <input asp-for="File" class="form-control" type="file" required />
    </div>
    <div class="mb-3">
        <label class="form-label">تحديث تاريخ الانتهاء (اختياري)</label>
        <input asp-for="UpdateExpiryDate" class="form-control" type="date" />
    </div>
    <div class="mb-3">
        <label class="form-label">ملاحظات</label>
        <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary" href="@Url.Action("Detail", "Documents", new { id = Model.DocumentId })">إلغاء</a>
        <button class="btn btn-success" type="submit">رفع النسخة</button>
    </div>
</form>
