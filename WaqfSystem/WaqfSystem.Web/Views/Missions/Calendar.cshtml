@using System.Text.Json
@model WaqfSystem.Web.ViewModels.Mission.MissionCalendarViewModel
@{
    ViewData["Title"] = "الجدول";
}

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <h2 class="fw-bold mb-0">جدول المهام الميدانية — @Model.MonthNameAr @Model.Year</h2>
        <div class="d-flex gap-2">
            <a asp-action="Calendar" asp-route-year="@Model.PrevYear" asp-route-month="@Model.PrevMonth" class="btn btn-outline-secondary">الشهر السابق</a>
            <a asp-action="Calendar" asp-route-year="@Model.NextYear" asp-route-month="@Model.NextMonth" class="btn btn-outline-secondary">الشهر التالي</a>
        </div>
    </div>

    <form method="get" class="row g-2 mb-3">
        <input type="hidden" name="year" value="@Model.Year" />
        <input type="hidden" name="month" value="@Model.Month" />
        <div class="col-md-4"><select class="form-select" name="governorateId"><option value="">كل المحافظات</option>@foreach(var g in Model.Governorates){<option value="@g.Value" selected="@(Model.FilterGovernorateId?.ToString()==g.Value)">@g.Text</option>}</select></div>
        <div class="col-md-2 d-grid"><button class="btn btn-primary">تطبيق</button></div>
    </form>

    <div class="d-flex gap-3 flex-wrap mb-3">
        <span><i class="bi bi-circle-fill text-primary"></i> مُكلَّفة</span>
        <span><i class="bi bi-circle-fill text-success"></i> مكتملة</span>
        <span><i class="bi bi-circle-fill text-warning"></i> قيد المراجعة</span>
        <span><i class="bi bi-circle-fill text-danger"></i> تصحيح</span>
    </div>

    <div class="mb-3">
        <button class="btn btn-sm btn-outline-primary" id="gridToggle">عرض الشبكة</button>
        <button class="btn btn-sm btn-outline-secondary" id="listToggle">عرض القائمة</button>
    </div>

    <div id="calendarGrid" class="border rounded-3 overflow-hidden"></div>
    <div id="calendarList" class="d-none"></div>
</div>

@section Scripts {
<script>
    const events = @Html.Raw(JsonSerializer.Serialize(Model.Events));
    const year = @Model.Year;
    const month = @Model.Month;

    const dayNames = ['الأحد','الاثنين','الثلاثاء','الأربعاء','الخميس','الجمعة','السبت'];
    function buildGrid() {
        const root = document.getElementById('calendarGrid');
        root.innerHTML = '';
        const header = document.createElement('div');
        header.className = 'd-grid';
        header.style.gridTemplateColumns = 'repeat(7,1fr)';
        dayNames.forEach(d=>{ const c=document.createElement('div'); c.className='p-2 bg-light border text-center fw-bold'; c.textContent=d; header.appendChild(c); });
        root.appendChild(header);

        const grid = document.createElement('div');
        grid.className = 'd-grid';
        grid.style.gridTemplateColumns = 'repeat(7,1fr)';

        const first = new Date(year, month - 1, 1);
        const startDay = first.getDay();
        const daysInMonth = new Date(year, month, 0).getDate();

        for(let i=0;i<startDay;i++){
            const empty=document.createElement('div');
            empty.className='border p-2';
            empty.style.minHeight='120px';
            grid.appendChild(empty);
        }

        for(let day=1; day<=daysInMonth; day++){
            const cell = document.createElement('div');
            cell.className = 'border p-2';
            cell.style.minHeight = '120px';
            const title = document.createElement('div');
            title.className = 'fw-bold mb-1';
            title.textContent = day;
            cell.appendChild(title);
            const daily = events.filter(e => new Date(e.start).getDate() === day);
            daily.forEach(e => {
                const card = document.createElement('a');
                card.href = '/Missions/Detail/' + e.id;
                card.className = 'd-block text-decoration-none text-dark rounded p-1 mb-1 small';
                card.style.borderRight = '4px solid ' + e.color;
                card.title = e.title + ' - ' + e.assignedToName;
                card.innerHTML = '<div>'+e.id+'</div><div>'+e.assignedToName+'</div>';
                cell.appendChild(card);
            });
            grid.appendChild(cell);
        }

        root.appendChild(grid);
    }

    function buildList() {
        const root = document.getElementById('calendarList');
        root.innerHTML = '';
        const grouped = {};
        events.forEach(e => {
            const d = new Date(e.start).toISOString().substring(0,10);
            grouped[d] = grouped[d] || [];
            grouped[d].push(e);
        });

        Object.keys(grouped).sort().forEach(date => {
            const box = document.createElement('div');
            box.className = 'card border-0 shadow-sm mb-2';
            box.innerHTML = '<div class="card-header bg-white fw-bold">'+date+'</div>';
            const body = document.createElement('div');
            body.className = 'card-body';
            grouped[date].forEach(e => {
                const row = document.createElement('a');
                row.href = '/Missions/Detail/' + e.id;
                row.className = 'd-flex justify-content-between align-items-center text-decoration-none text-dark border rounded-3 p-2 mb-2';
                row.innerHTML = '<div>'+e.title+'</div><span class="badge" style="background:'+e.color+'">'+e.stage+'</span>';
                body.appendChild(row);
            });
            box.appendChild(body);
            root.appendChild(box);
        });
    }

    document.getElementById('gridToggle').addEventListener('click', function(){ document.getElementById('calendarGrid').classList.remove('d-none'); document.getElementById('calendarList').classList.add('d-none'); });
    document.getElementById('listToggle').addEventListener('click', function(){ document.getElementById('calendarGrid').classList.add('d-none'); document.getElementById('calendarList').classList.remove('d-none'); });

    buildGrid();
    buildList();
</script>
}
