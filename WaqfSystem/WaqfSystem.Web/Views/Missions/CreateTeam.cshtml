@model WaqfSystem.Application.DTOs.Mission.TeamCreateDto
@{
    ViewData["Title"] = "إنشاء فريق";
    var governorates = ViewBag.Governorates as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? new();
}

<div class="container py-4">
    <h3 class="fw-bold mb-3">إنشاء فريق جديد</h3>
    <form method="post" class="card border-0 shadow-sm">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6"><label class="form-label">اسم الفريق</label><input asp-for="TeamName" class="form-control" required /></div>
                <div class="col-md-6"><label class="form-label">رمز الفريق</label><input asp-for="TeamCode" class="form-control" required /></div>
                <div class="col-md-6"><label class="form-label">المحافظة</label><select asp-for="GovernorateId" asp-items="governorates" class="form-select"></select></div>
                <div class="col-md-6"><label class="form-label">معرف القائد (اختياري)</label><input asp-for="LeaderId" type="number" class="form-control" /></div>
                <div class="col-12"><label class="form-label">الوصف</label><textarea asp-for="Description" class="form-control" rows="3"></textarea></div>
            </div>
            <div class="mt-3 d-flex justify-content-end gap-2"><a asp-action="Teams" class="btn btn-light">إلغاء</a><button class="btn btn-primary">حفظ الفريق</button></div>
        </div>
    </form>
</div>
