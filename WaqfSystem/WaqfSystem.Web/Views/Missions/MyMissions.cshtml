@using WaqfSystem.Core.Enums
@model WaqfSystem.Web.ViewModels.Mission.MissionIndexViewModel
@{
    ViewData["Title"] = "مهامي";
}

<div class="container-fluid py-3">
    <h2 class="fw-bold mb-3">مهامي الميدانية</h2>

    <ul class="nav nav-pills mb-3">
        <li class="nav-item"><button class="nav-link active" data-bs-toggle="pill" data-bs-target="#tabAssigned">المعلقة</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="pill" data-bs-target="#tabActive">جارية</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="pill" data-bs-target="#tabCompleted">مكتملة</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="pill" data-bs-target="#tabAll">الكل</button></li>
    </ul>

    <div class="tab-content">
        <div class="tab-pane fade show active" id="tabAssigned">@RenderCards(Model.Missions.Items.Where(x=>x.Stage==MissionStage.Assigned).ToList())</div>
        <div class="tab-pane fade" id="tabActive">@RenderCards(Model.Missions.Items.Where(x=>x.Stage==MissionStage.InProgress || x.Stage==MissionStage.DataEntry || x.Stage==MissionStage.Accepted).ToList())</div>
        <div class="tab-pane fade" id="tabCompleted">@RenderCards(Model.Missions.Items.Where(x=>x.Stage==MissionStage.Completed).ToList())</div>
        <div class="tab-pane fade" id="tabAll">@RenderCards(Model.Missions.Items)</div>
    </div>
</div>

@functions{
    private Microsoft.AspNetCore.Html.IHtmlContent RenderCards(List<WaqfSystem.Application.DTOs.Mission.MissionListItemDto> items)
    {
        var sb = new System.Text.StringBuilder();
        if (!items.Any())
        {
            sb.Append("<div class='alert alert-light'>لا توجد مهام</div>");
            return new Microsoft.AspNetCore.Html.HtmlString(sb.ToString());
        }
        sb.Append("<div class='row g-3'>");
        foreach (var m in items)
        {
            var action = m.Stage == MissionStage.Assigned ? "قبول" : m.Stage == MissionStage.Accepted ? "تسجيل وصول" : m.Stage == MissionStage.DataEntry ? "متابعة" : "عرض";
            sb.Append($"<div class='col-md-6 col-lg-4'><div class='card border-0 shadow-sm h-100'><div class='card-body'><div class='small text-muted'>{m.MissionCode}</div><h6 class='fw-bold'>{m.Title}</h6><div class='small mb-1'>{m.DistrictNameAr}</div><div class='small text-muted mb-2'>{m.MissionDate:yyyy/MM/dd}</div><div class='progress mb-2' style='height:8px;'><div class='progress-bar' style='width:{m.ProgressPercent}%'></div></div><a href='/Missions/Detail/{m.Id}' class='btn btn-sm btn-primary'>{action}</a></div></div></div>");
        }
        sb.Append("</div>");
        return new Microsoft.AspNetCore.Html.HtmlString(sb.ToString());
    }
}
