@model WaqfSystem.Web.ViewModels.Mission.TeamsViewModel
@{
    ViewData["Title"] = "إدارة الفرق";
}

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold mb-0">إدارة الفرق الميدانية</h2>
        <a asp-action="CreateTeam" class="btn btn-primary">إنشاء فريق جديد</a>
    </div>

    <form method="get" class="row g-2 mb-3">
        <div class="col-md-4"><select class="form-select" name="governorateId"><option value="">كل المحافظات</option>@foreach(var g in Model.Governorates){<option value="@g.Value" selected="@(Model.FilterGovernorateId?.ToString()==g.Value)">@g.Text</option>}</select></div>
        <div class="col-md-2 d-grid"><button class="btn btn-outline-primary">تطبيق</button></div>
    </form>

    <div class="row g-3">
        @foreach (var team in Model.Teams)
        {
            <div class="col-lg-4 col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-2"><h5 class="fw-bold mb-0">@team.TeamName</h5><span class="badge bg-dark">@team.TeamCode</span></div>
                        <div class="text-muted mb-1">@team.GovernorateNameAr</div>
                        <div class="mb-1">القائد: @(team.LeaderName ?? "غير محدد")</div>
                        <div class="mb-2">الأعضاء: @team.Members.Count | المهام النشطة: @team.ActiveMissionCount</div>
                        <div class="d-flex gap-2">
                            <a asp-action="TeamDetail" asp-route-id="@team.Id" class="btn btn-sm btn-outline-primary">عرض الفريق</a>
                            <a asp-action="TeamDetail" asp-route-id="@team.Id" class="btn btn-sm btn-outline-secondary">إدارة الأعضاء</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
