@model WaqfSystem.Web.ViewModels.Properties.PartnershipEditViewModel
@{
    ViewData["Title"] = "تعديل الشراكة";
}
<div class="container" dir="rtl">
    <h3 class="mb-3">تعديل الشراكة</h3>
    <form asp-action="Edit" method="post" enctype="multipart/form-data" class="card card-body">
        @Html.AntiForgeryToken()
        <input asp-for="Form.Id" type="hidden" />
        <div class="row g-3">
            <div class="col-md-4"><label class="form-label">نوع الشراكة</label><select asp-for="Form.PartnershipType" class="form-select" asp-items="Html.GetEnumSelectList<WaqfSystem.Core.Enums.PartnershipType>()"></select></div>
            <div class="col-md-4"><label class="form-label">نسبة الوقف</label><input asp-for="Form.WaqfSharePercent" class="form-control" /></div>
            <div class="col-md-4"><label class="form-label">نوع التوزيع</label><select asp-for="Form.RevenueDistribMethod" class="form-select" asp-items="Html.GetEnumSelectList<WaqfSystem.Core.Enums.RevenueDistribMethod>()"></select></div>
            <div class="col-md-6"><label class="form-label">اسم الشريك</label><input asp-for="Form.PartnerName" class="form-control" /></div>
            <div class="col-md-6"><label class="form-label">الهاتف</label><input asp-for="Form.PartnerPhone" class="form-control" /></div>
            <div class="col-md-6"><label class="form-label">البريد</label><input asp-for="Form.PartnerEmail" class="form-control" /></div>
            <div class="col-md-6"><label class="form-label">مرفق اتفاقية جديد</label><input asp-for="Form.AgreementFile" type="file" class="form-control" /></div>
            <div class="col-12"><label class="form-label">ملاحظات</label><textarea asp-for="Form.Notes" class="form-control"></textarea></div>
        </div>
        <div class="mt-3 d-flex justify-content-between">
            <a class="btn btn-outline-secondary" href="@Url.Action("Detail", new { id = Model.Form.Id })">إلغاء</a>
            <button class="btn btn-success" type="submit">حفظ التعديلات</button>
        </div>
    </form>
</div>
