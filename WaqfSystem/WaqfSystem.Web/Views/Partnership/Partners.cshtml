@using WaqfSystem.Core.Enums
@model WaqfSystem.Web.ViewModels.Properties.PartnerListViewModel
@{
    ViewData["Title"] = "دليل الشركاء والمستثمرين";
}

<div class="container-fluid" dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 mb-0 text-gray-800"><i class="fas fa-user-tie me-2 text-primary"></i> دليل الشركاء والمستثمرين</h2>
            <p class="text-muted small mb-0">عرض وإدارة كافة الأشخاص والشركات المتعاقدة مع الوقف</p>
        </div>
        <div class="d-flex gap-2">
            <a href="@Url.Action("CreatePartner")" class="btn btn-primary rounded-pill px-4 shadow-sm">
                <i class="fas fa-plus-circle me-1"></i> إضافة شريك / شركة جديد
            </a>
        </div>
    </div>

    <!-- Stats Summary -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 bg-white p-3">
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-primary-subtle p-3 me-3">
                        <i class="fas fa-users text-primary fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small fw-bold">إجمالي الشركاء</div>
                        <div class="h4 mb-0 fw-bold">@Model.Partners.Count</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 bg-white p-3">
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-success-subtle p-3 me-3">
                        <i class="fas fa-building text-success fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small fw-bold">شركات ومؤسسات</div>
                        <div class="h4 mb-0 fw-bold">@Model.Partners.Count(x => x.Type == PartnerType.Company)</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 bg-white p-3">
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-info-subtle p-3 me-3">
                        <i class="fas fa-user text-info fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small fw-bold">أفراد ومستثمرون</div>
                        <div class="h4 mb-0 fw-bold">@Model.Partners.Count(x => x.Type == PartnerType.Individual)</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 bg-white p-3">
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-warning-subtle p-3 me-3">
                        <i class="fas fa-handshake text-warning fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small fw-bold">إجمالي العقود</div>
                        <div class="h4 mb-0 fw-bold">@Model.Partners.Sum(x => x.PartnershipCount)</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-3">
            <form method="get" class="row g-2">
                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 rounded-start-pill"><i class="fas fa-search text-muted"></i></span>
                        <input type="text" name="searchTerm" value="@Model.SearchTerm" class="form-control border-start-0 rounded-end-pill" placeholder="ابحث بالاسم، رقم الهاتف...">
                    </div>
                </div>
                <div class="col-md-3">
                    <select name="partnerType" class="form-select rounded-pill" onchange="this.form.submit()">
                        <option value="">كافة أنواع الشركاء</option>
                        @foreach (var type in Enum.GetValues<PartnerType>())
                        {
                            <option value="@type" selected="@(Model.PartnerType == type)">@type</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100 rounded-pill">تطبيق</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Partners Grid -->
    <div class="row g-4">
        @foreach (var partner in Model.Partners)
        {
            <div class="col-xl-4 col-md-6">
                <div class="card border-0 shadow-sm rounded-4 h-100 partner-card transition-all">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div class="d-flex align-items-center">
                                <div class="avatar-circle me-3 @(partner.Type == PartnerType.Company ? "bg-success-subtle text-success" : "bg-primary-subtle text-primary")">
                                    <i class="fas @(partner.Type == PartnerType.Company ? "fa-building" : "fa-user") fs-5"></i>
                                </div>
                                <div>
                                    <h5 class="mb-1 fw-bold">@partner.Name</h5>
                                    <span class="badge @(partner.Type == PartnerType.Company ? "bg-success-subtle text-success" : "bg-primary-subtle text-primary") rounded-pill x-small">
                                        @(partner.Type == PartnerType.Company ? "شركة / مؤسسة" : "فرد / مستثمر")
                                    </span>
                                </div>
                            </div>
                            <div class="dropdown">
                                <button class="btn btn-link text-muted p-0" data-bs-toggle="dropdown">
                                    <i class="fas fa-ellipsis-v"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3">
                                    <li><a class="dropdown-item" href="@Url.Action("Index", new { SearchTerm = partner.Name })"><i class="fas fa-file-contract me-2"></i> عرض العقود</a></li>
                                    <li><a class="dropdown-item" href="tel:@partner.Phone"><i class="fas fa-phone me-2"></i> اتصال</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item text-primary" href="@Url.Action("Create", new { partnerName = partner.Name })"><i class="fas fa-plus me-2"></i> عقد جديد</a></li>
                                </ul>
                            </div>
                        </div>

                        <div class="contact-info bg-light bg-opacity-50 rounded-4 p-3 mb-3">
                            <div class="d-flex align-items-center mb-2">
                                <i class="fas fa-phone-alt text-muted me-2 small" style="width: 20px;"></i>
                                <span class="small font-monospace">@partner.Phone</span>
                            </div>
                            @if (!string.IsNullOrEmpty(partner.Email))
                            {
                                <div class="d-flex align-items-center mb-2">
                                    <i class="fas fa-envelope text-muted me-2 small" style="width: 20px;"></i>
                                    <span class="small">@partner.Email</span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(partner.Address))
                            {
                                <div class="d-flex align-items-center">
                                    <i class="fas fa-map-marker-alt text-muted me-2 small" style="width: 20px;"></i>
                                    <span class="small text-truncate">@partner.Address</span>
                                </div>
                            }
                        </div>

                        <div class="row g-2">
                            <div class="col-6">
                                <div class="p-2 border rounded-3 text-center">
                                    <div class="text-muted x-small">عدد العقارات</div>
                                    <div class="fw-bold text-primary">@partner.PartnershipCount</div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="p-2 border rounded-3 text-center">
                                    <div class="text-muted x-small">إجمالي الحصص</div>
                                    <div class="fw-bold text-success">@partner.TotalWaqfRevenue.ToString("N0") <small class="x-small">د.ع</small></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-white border-0 p-3 pt-0">
                        <a href="@Url.Action("Index", new { SearchTerm = partner.Name })" class="btn btn-outline-primary btn-sm w-100 rounded-pill">
                            <i class="fas fa-external-link-alt me-1"></i> تفاصيل الشراكات
                        </a>
                    </div>
                </div>
            </div>
        }

        @if (!Model.Partners.Any())
        {
            <div class="col-12 text-center py-5">
                <div class="opacity-25 mb-3">
                    <i class="fas fa-users-slash fa-5x"></i>
                </div>
                <h4 class="text-muted">لا يوجد شركاء مطابقين للبحث</h4>
                <a href="@Url.Action("Partners")" class="btn btn-link">إعادة ضبط الفلتر</a>
            </div>
        }
    </div>
</div>

<style>
    .avatar-circle {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .partner-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 1rem 3rem rgba(0,0,0,.1) !important;
    }
    .x-small {
        font-size: 0.75rem;
    }
    .transition-all {
        transition: all 0.3s ease;
    }
</style>
