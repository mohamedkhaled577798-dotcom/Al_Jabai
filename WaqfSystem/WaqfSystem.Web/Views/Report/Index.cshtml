@{
    ViewData["Title"] = "التقارير والإحصائيات";
}

<div class="mb-4">
    <h2 class="h3 mb-0 text-gray-800"><i class="fas fa-file-chart-line me-2"></i> مركز التقارير والإحصائيات</h2>
    <p class="text-muted small">قم بتوليد وتحميل التقارير التفصيلية عن الأملاك والمهمات الميدانية.</p>
</div>

<div class="row g-4">
    <!-- Reports Cards -->
    <div class="col-md-4">
        <div class="card h-100 shadow-sm border-0 transition-hover" style="cursor: pointer;">
            <div class="card-body text-center p-4">
                <div class="rounded-circle bg-soft-primary p-3 mx-auto mb-3 d-flex align-items-center justify-content-center" style="width: 70px; height: 70px; background-color: rgba(13, 110, 253, 0.1);">
                    <i class="fas fa-building fa-2x text-primary"></i>
                </div>
                <h5>تقرير الأملاك الكلي</h5>
                <p class="small text-muted">ملخص شامل لجميع العقارات المسجلة حسب المحافظة والحالة.</p>
                <form asp-action="PropertyExport" method="post">
                    <button type="submit" class="btn btn-outline-primary w-100 rounded-pill mt-2">
                        <i class="fas fa-download me-1"></i> تحميل PDF
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card h-100 shadow-sm border-0 transition-hover" style="cursor: pointer;">
            <div class="card-body text-center p-4">
                <div class="rounded-circle bg-soft-success p-3 mx-auto mb-3 d-flex align-items-center justify-content-center" style="width: 70px; height: 70px; background-color: rgba(25, 135, 84, 0.1);">
                    <i class="fas fa-tasks fa-2x text-success"></i>
                </div>
                <h5>تقرير المهمات الميدانية</h5>
                <p class="small text-muted">إحصائيات إنجاز الفرق الميدانية ونسب التغطية الجغرافية.</p>
                <button class="btn btn-outline-success w-100 rounded-pill mt-2">
                    <i class="fas fa-file-excel me-1"></i> تحميل Excel
                </button>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card h-100 shadow-sm border-0 transition-hover" style="cursor: pointer;">
            <div class="card-body text-center p-4">
                <div class="rounded-circle bg-soft-warning p-3 mx-auto mb-3 d-flex align-items-center justify-content-center" style="width: 70px; height: 70px; background-color: rgba(255, 193, 7, 0.1);">
                    <i class="fas fa-database fa-2x text-warning"></i>
                </div>
                <h5>تقرير جودة البيانات</h5>
                <p class="small text-muted">رصد الفجوات في البيانات والخصائص الناقصة للعقارات (DQS).</p>
                <button class="btn btn-outline-warning w-100 rounded-pill mt-2">
                    <i class="fas fa-eye me-1"></i> عرض التفاصيل
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .transition-hover {
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }
    .transition-hover:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1.5rem rgba(0,0,0,.1)!important;
    }
</style>
