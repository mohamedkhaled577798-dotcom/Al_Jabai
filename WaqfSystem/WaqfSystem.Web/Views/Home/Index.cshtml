@using WaqfSystem.Core.Enums
@{
    ViewData["Title"] = "الرئيسية";
}

<div class="container py-5">
    <div class="row align-items-center mb-5">
        <div class="col-lg-7">
            <h1 class="display-4 fw-bold mb-3">نظام حصر وإدارة <span class="text-primary">الأملاك الوقفية</span></h1>
            <p class="lead text-muted mb-4">المنظومة المتكاملة للتحول الرقمي في إدارة واستثمار عقارات ديوان الوقف السني، مع دعم كامل للبيانات الجغرافية والمسوحات الميدانية.</p>
            <div class="hstack gap-3">
                <a asp-controller="Property" asp-action="Index" class="btn btn-primary btn-lg px-4 shadow">
                    <i class="fas fa-building me-2"></i> استعراض الأملاك
                </a>
                <a asp-controller="Gis" asp-action="Explorer" class="btn btn-outline-secondary btn-lg px-4">
                    <i class="fas fa-map-marked-alt me-2"></i> الخارطة التفاعلية
                </a>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="glass p-4 rounded-5 shadow-lg position-relative mt-5 mt-lg-0">
                <div class="rounded-4 overflow-hidden shadow">
                    <img src="https://images.unsplash.com/photo-1577017040065-619eeedfe76c?auto=format&fit=crop&q=80&w=800" class="img-fluid" alt="Architecture">
                </div>
                <div class="position-absolute bottom-0 start-0 m-4 bg-white p-3 rounded-4 shadow-sm hstack gap-3 border border-light">
                    <div class="bg-primary bg-opacity-10 p-2 rounded-3">
                        <i class="fas fa-shield-alt text-primary"></i>
                    </div>
                    <div>
                        <div class="small fw-bold">نظام آمن</div>
                        <div class="text-muted" style="font-size: 0.7rem;">حماية كاملة للبيانات</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-5">
        <div class="col-md-4">
            <div class="card h-100 p-4 border-0 shadow-sm border-bottom border-3 border-primary">
                <div class="mb-3 text-primary"><i class="fas fa-database fa-2x"></i></div>
                <h4>قاعدة بيانات مركزية</h4>
                <p class="text-muted">أرشفة رقمية شاملة لجميع السجلات والمستندات القانونية والمخططات الهندسية.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 p-4 border-0 shadow-sm border-bottom border-3 border-success">
                <div class="mb-3 text-success"><i class="fas fa-mobile-alt fa-2x"></i></div>
                <h4>تطبيقات ميدانية</h4>
                <p class="text-muted">مزامنة فورية مع الفرق الجوالة لرفع الصور والإحداثيات والملاحظات مباشرة للديوان.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 p-4 border-0 shadow-sm border-bottom border-3 border-info">
                <div class="mb-3 text-info"><i class="fas fa-chart-line fa-2x"></i></div>
                <h4>ذكاء الأعمال وتوقع الاستثمار</h4>
                <p class="text-muted">تحليلات متقدمة لتوزيع الأصول وتقييم فرص الاستثمار المتاحة في المدن العراقية.</p>
            </div>
        </div>
    </div>
</div>
