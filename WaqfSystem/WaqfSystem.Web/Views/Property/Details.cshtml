<div class="d-flex justify-content-between align-items-end mb-4">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-2">
                <li class="breadcrumb-item small"><a asp-action="Index">إدارة العقارات</a></li>
                <li class="breadcrumb-item active small" aria-current="page">تفاصيل العقار</li>
            </ol>
        </nav>
        <h2 class="h3 mb-1 fw-bold">@Model.PropertyName</h2>
        <div class="hstack gap-2 mt-2">
            <span class="badge bg-white text-dark shadow-sm border px-3 py-2 rounded-pill font-monospace">@Model.WqfNumber</span>
            <span class="badge @(Model.ApprovalStage == WaqfSystem.Core.Enums.ApprovalStage.Approved ? "bg-success" : "bg-warning text-dark") shadow-sm px-3 py-2 rounded-pill">
                <i class="fas @(Model.ApprovalStage == WaqfSystem.Core.Enums.ApprovalStage.Approved ? "fa-check-circle" : "fa-clock") me-1"></i>
                @Model.ApprovalStage.ToString()
            </span>
        </div>
    </div>
    <div class="hstack gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary shadow-sm"><i class="fas fa-edit me-1"></i> تعديل</a>
        <div class="dropdown">
            <button class="btn btn-outline-secondary dropdown-toggle shadow-sm" type="button" data-bs-toggle="dropdown">
                إجراءات إضافية
            </button>
            <ul class="dropdown-menu dropdown-menu-end shadow">
                <li><a class="dropdown-item" href="#"><i class="fas fa-print me-2 text-muted"></i> طباعة الوثيقة</a></li>
                <li><a class="dropdown-item" href="#"><i class="fas fa-history me-2 text-muted"></i> السجل التاريخي</a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item text-danger" href="#"><i class="fas fa-trash me-2"></i> حذف</a></li>
            </ul>
        </div>
    </div>
</div>

<div class="row">
    <!-- Quick Info Column -->
    <div class="col-xl-4 col-lg-5">
        <div class="card shadow-sm border-0 mb-4 overflow-hidden rounded-4">
            <div class="position-relative">
                <img src="/api/photo/main/@Model.Id" class="card-img-top" style="height: 250px; object-fit: cover;" onerror="this.src='https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&q=80&w=600'">
                <div class="position-absolute top-0 end-0 m-3 hstack gap-2">
                    <button class="btn btn-sm glass rounded-circle p-2 text-white shadow"><i class="fas fa-camera"></i></button>
                </div>
            </div>
            <div class="card-body p-4">
                <div class="mb-4">
                    <div class="hstack justify-content-between mb-2">
                        <label class="text-secondary small fw-bold">دقة وتكامل البيانات (DQS)</label>
                        <span class="fw-bold @(Model.DqsScore >= 70 ? "text-success" : "text-warning")">@Model.DqsScore%</span>
                    </div>
                    <div class="progress rounded-pill" style="height: 10px;">
                        <div class="progress-bar @(Model.DqsScore >= 70 ? "bg-success" : "bg-warning") progress-bar-striped progress-bar-animated" role="progressbar" style="width: @(Model.DqsScore)%"></div>
                    </div>
                </div>

                <div class="row g-0 mb-3 pb-3 border-bottom">
                    <div class="col-6 text-muted small">نوع العقار</div>
                    <div class="col-6 text-end fw-bold">@Model.PropertyType.ToString()</div>
                </div>
                <div class="row g-0 mb-3 pb-3 border-bottom">
                    <div class="col-6 text-muted small">المحافظة</div>
                    <div class="col-6 text-end fw-bold">@Model.GovernorateName</div>
                </div>
                <div class="row g-0">
                    <div class="col-6 text-muted small">تاريخ الإضافة</div>
                    <div class="col-6 text-end fw-bold">@Model.CreatedAt.ToString("yyyy/MM/dd")</div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0 mb-4 rounded-4" style="background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);">
            <div class="card-body p-4 text-white">
                <h6 class="card-title fw-bold mb-3 hstack gap-2">
                    <i class="fas fa-map-marked-alt text-primary"></i> الموقع الجغرافي
                </h6>
                <div id="miniMap" class="rounded-3 bg-dark bg-opacity-25" style="height: 200px; border: 1px solid rgba(255,255,255,0.1);">
                    <!-- Map Placeholder with better UI -->
                    <div class="d-flex align-items-center justify-content-center h-100 flex-column opacity-50">
                        <i class="fas fa-satellite fa-2x mb-2"></i>
                        <span class="small">الخارطة الجغرافية</span>
                    </div>
                </div>
                <div class="mt-3 text-center">
                    <code class="text-primary bg-primary bg-opacity-10 px-3 py-2 rounded-pill small">
                        @Model.Latitude, @Model.Longitude
                    </code>
                </div>
            </div>
        </div>
    </div>

    <!-- Details Tabbed Container -->
    <div class="col-xl-8 col-lg-7">
        <div class="card shadow-sm border-0 mb-4 rounded-4">
            <div class="card-header border-0 bg-transparent p-0 px-4 pt-3">
                <ul class="nav nav-pills gap-2 mb-0" id="propertyTabs" role="tablist">
                    <li class="nav-item">
                        <button class="nav-link active rounded-pill px-4" id="general-tab" data-bs-toggle="tab" data-bs-target="#general" type="button">العامة</button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link rounded-pill px-4" id="structure-tab" data-bs-toggle="tab" data-bs-target="#structure" type="button">الهيكل</button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link rounded-pill px-4" id="docs-tab" data-bs-toggle="tab" data-bs-target="#docs" type="button">الوثائق</button>
                    </li>
                </ul>
            </div>
            <div class="card-body p-4 pt-5">
                <div class="tab-content" id="propertyTabsContent">
                    <!-- General Tab -->
                    <div class="tab-pane fade show active" id="general" role="tabpanel">
                        <div class="row g-4">
                            <div class="col-md-6">
                                <label class="text-secondary small d-block mb-1">الاسم الرسمي في السجلات</label>
                                <p class="h6 fw-bold">@Model.PropertyName</p>
                            </div>
                            <div class="col-md-6">
                                <label class="text-secondary small d-block mb-1">فئة العقار</label>
                                <p class="h6 fw-bold">@Model.PropertyCategory.ToString()</p>
                            </div>
                            <div class="col-md-4">
                                <label class="text-secondary small d-block mb-1">المساحة الكلية (م2)</label>
                                <p class="h6 fw-bold">@Model.TotalAreaSqm?.ToString("N0") م2</p>
                            </div>
                            <div class="col-md-4">
                                <label class="text-secondary small d-block mb-1">نوع البناء</label>
                                <p class="h6 fw-bold">@Model.ConstructionType?.ToString()</p>
                            </div>
                            <div class="col-md-4">
                                <label class="text-secondary small d-block mb-1">الحالة الإنشائية</label>
                                <p class="h6 fw-bold">@Model.StructuralCondition?.ToString()</p>
                            </div>
                            <div class="col-12 mt-4 pt-4 border-top">
                                <label class="text-secondary small d-block mb-1">الملاحظات والوصف التفصيلي</label>
                                <p class="lh-lg">@(string.IsNullOrEmpty(Model.Notes) ? "لا توجد ملاحظات مسجلة." : Model.Notes)</p>
                            </div>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="structure" role="tabpanel">
                        <div class="text-center py-5">
                            <div class="bg-light p-4 rounded-circle d-inline-block mb-3">
                                <i class="fas fa-layer-group fa-2x text-primary opacity-50"></i>
                            </div>
                            <p class="text-muted">جاري تحميل بيانات الطوابق والوحدات من الخادم...</p>
                        </div>
                    </div>
                    
                    <div class="tab-pane fade" id="docs" role="tabpanel">
                        <div class="text-center py-5">
                            <i class="fas fa-file-contract fa-2x text-muted mb-3"></i>
                            <p class="text-muted">لا توجد مستندات مرفقة حالياً.</p>
                            <button class="btn btn-sm btn-outline-primary rounded-pill"><i class="fas fa-plus me-1"></i> رفع مستند</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Workflow Action Bar -->
        <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
            <div class="card-body p-4 d-flex justify-content-between align-items-center" style="background: rgba(245, 158, 11, 0.05);">
                <div>
                    <h6 class="fw-bold text-dark mb-1 hstack gap-2">
                        <span class="p-2 bg-warning bg-opacity-10 rounded-3"><i class="fas fa-flag-checkered text-warning"></i></span>
                        إجراءات سير العمل
                    </h6>
                    <p class="mb-0 small text-secondary ms-5">المرحلة الحالية: <strong>@Model.ApprovalStage.ToString()</strong></p>
                </div>
                <div class="hstack gap-2">
                    <button class="btn btn-white btn-sm border shadow-sm px-3" onclick="showCorrectionModal()">طلب تصحيح</button>
                    <button class="btn btn-success btn-sm shadow-sm px-4 @(Model.DqsScore < 70 ? "disabled" : "")">تأكيد وموافقة</button>
                </div>
            </div>
        </div>
    </div>
</div>
