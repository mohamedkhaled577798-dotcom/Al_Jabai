@model List<WaqfSystem.Application.DTOs.Document.DocumentTypeDto>
@{
    ViewData["Title"] = "أنواع الوثائق";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">إدارة أنواع الوثائق</h3>
    <a class="btn btn-success" href="@Url.Action("CreateDocumentType", "Admin")">إضافة نوع جديد</a>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form method="post" asp-action="CreateDocumentType" class="row g-2">
            @Html.AntiForgeryToken()
            <div class="col-md-2"><input class="form-control" name="Code" placeholder="الكود" required /></div>
            <div class="col-md-2"><input class="form-control" name="NameAr" placeholder="الاسم عربي" required /></div>
            <div class="col-md-2"><input class="form-control" name="NameEn" placeholder="الاسم إنجليزي" required /></div>
            <div class="col-md-2"><input class="form-control" name="Category" placeholder="التصنيف" required /></div>
            <div class="col-md-1 form-check d-flex align-items-center"><input class="form-check-input" type="checkbox" name="IsRequired" id="isReq" /><label class="form-check-label me-1" for="isReq">إلزامي</label></div>
            <div class="col-md-1 form-check d-flex align-items-center"><input class="form-check-input" type="checkbox" name="HasExpiry" id="hasExp" /><label class="form-check-label me-1" for="hasExp">ينتهي</label></div>
            <div class="col-md-1"><input class="form-control" type="number" name="AlertDays1" placeholder="تنبيه 1" /></div>
            <div class="col-md-1"><input class="form-control" type="number" name="AlertDays2" placeholder="تنبيه 2" /></div>
            <div class="col-md-3"><input class="form-control" name="AllowedExtensions" value="pdf,jpg,jpeg,png,tiff" placeholder="الامتدادات" /></div>
            <div class="col-md-2"><input class="form-control" type="number" name="MaxFileSizeMB" value="10" placeholder="MB" /></div>
            <div class="col-md-4"><input class="form-control" name="VerifierRoles" placeholder="LEGAL_REVIEWER,ENGINEER" /></div>
            <div class="col-md-3"><button class="btn btn-primary w-100">إضافة النوع</button></div>
        </form>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>الاسم</th>
                <th>الكود</th>
                <th>إلزامي</th>
                <th>ينتهي</th>
                <th>أيام التنبيه</th>
                <th>الامتدادات</th>
                <th>الأدوار</th>
                <th>العدد</th>
                <th>الحالة</th>
                <th>إجراءات</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var t in Model)
            {
                <tr>
                    <td>@t.NameAr</td>
                    <td>@t.Code</td>
                    <td>@(t.IsRequired ? "نعم" : "لا")</td>
                    <td>@(t.HasExpiry ? "نعم" : "لا")</td>
                    <td>@(t.AlertDays1?.ToString() ?? "-") / @(t.AlertDays2?.ToString() ?? "-")</td>
                    <td>@t.AllowedExtensions</td>
                    <td>@string.Join(", ", t.VerifierRoles)</td>
                    <td>@t.DocumentCount</td>
                    <td><span class="badge @(t.IsActive ? "bg-success" : "bg-secondary")">@(t.IsActive ? "نشط" : "غير نشط")</span></td>
                    <td class="d-flex gap-2">
                        <a class="btn btn-sm btn-outline-primary" href="@Url.Action("EditDocumentType", "Admin", new { id = t.Id })">تعديل</a>
                        <button type="button" class="btn btn-sm btn-outline-warning js-toggle" data-id="@t.Id">تفعيل/إيقاف</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
<script>
(function(){
    document.querySelectorAll('.js-toggle').forEach(btn => {
        btn.addEventListener('click', async function(){
            const form = new URLSearchParams({ id: this.dataset.id });
            const res = await fetch('@Url.Action("ToggleDocumentType", "Admin")', { method:'POST', headers:{'Content-Type':'application/x-www-form-urlencoded'}, body: form.toString() }).then(r=>r.json());
            if(res.success){ location.reload(); }
        });
    });
})();
</script>
}
