@{
    ViewData["Title"] = "منع الوصول";
    var permission = ViewBag.Permission as string ?? "غير محدد";
}

<div class="container py-5">
    <div class="card shadow-sm border-0 mx-auto" style="max-width:720px;">
        <div class="card-body text-center p-5">
            <div class="display-1 text-danger mb-3"><i class="bi bi-lock-fill"></i></div>
            <h2 class="mb-3">ليس لديك صلاحية للوصول</h2>
            <p class="text-muted mb-2">الصلاحية المطلوبة: <strong>@permission</strong></p>
            <p class="text-muted mb-4">تواصل مع المدير لمنح الصلاحية</p>
            <a href="javascript:history.back()" class="btn btn-primary">رجوع</a>
        </div>
    </div>
</div>
