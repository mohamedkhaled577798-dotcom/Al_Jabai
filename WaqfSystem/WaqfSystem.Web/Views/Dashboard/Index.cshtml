@model WaqfSystem.Web.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "لوحة التحكم";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="h3 mb-0 text-gray-800">نظرة عامة على النظام</h2>
        <div class="d-none d-sm-inline-block">
            <a href="#" class="btn btn-sm btn-primary shadow-sm"><i class="fas fa-download fa-sm text-white-50 me-1"></i> تحميل التقرير</a>
        </div>
    </div>

    <div class="row">
        <!-- Totals -->
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-0 h-100 py-2 shadow-sm" style="background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col me-2">
                            <div class="text-xs font-weight-bold text-white text-uppercase mb-1 opacity-75">إجمالي العقارات</div>
                            <div class="h4 mb-0 font-weight-bold text-white">@Model.TotalProperties.ToString("N0")</div>
                        </div>
                        <div class="col-auto">
                            <div class="rounded-circle bg-white bg-opacity-25 p-3">
                                <i class="fas fa-building fa-lg text-white"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-0 h-100 py-2 shadow-sm" style="background: linear-gradient(135deg, #10b981 0%, #059669 100%);">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col me-2">
                            <div class="text-xs font-weight-bold text-white text-uppercase mb-1 opacity-75">بانتظار الموافقة</div>
                            <div class="h4 mb-0 font-weight-bold text-white">@Model.PendingApproval</div>
                        </div>
                        <div class="col-auto">
                            <div class="rounded-circle bg-white bg-opacity-25 p-3">
                                <i class="fas fa-clock fa-lg text-white"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-0 h-100 py-2 shadow-sm" style="background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col me-2">
                            <div class="text-xs font-weight-bold text-white text-uppercase mb-1 opacity-75">دقة البيانات (DQS)</div>
                            <div class="h4 mb-0 font-weight-bold text-white">@Model.AverageDqsScore%</div>
                        </div>
                        <div class="col-auto">
                            <div class="rounded-circle bg-white bg-opacity-25 p-3">
                                <i class="fas fa-chart-pie fa-lg text-white"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-0 h-100 py-2 shadow-sm" style="background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col me-2">
                            <div class="text-xs font-weight-bold text-white text-uppercase mb-1 opacity-75">مهام ميدانية نشطة</div>
                            <div class="h4 mb-0 font-weight-bold text-white">@Model.ActiveMissions</div>
                        </div>
                        <div class="col-auto">
                            <div class="rounded-circle bg-white bg-opacity-25 p-3">
                                <i class="fas fa-walking fa-lg text-white"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Distribution Chart (Placeholder) -->
        <div class="col-lg-8">
            <div class="card shadow mb-4">
                <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                    <h6 class="m-0 font-weight-bold text-primary">توزيع العقارات حسب المحافظات</h6>
                </div>
                <div class="card-body">
                    <div class="chart-area" style="height: 300px; background: #f8f9fc; border-radius: 10px; display: flex; align-items: flex-end; justify-content: space-around; padding: 20px;">
                        @foreach (var gov in Model.GovernorateStats)
                        {
                            <div class="text-center" style="width: 60px;">
                                <div class="bg-primary" style="height: @(gov.Percentage * 3)px; width: 40px; margin: 0 auto; border-radius: 5px 5px 0 0;"></div>
                                <small class="d-block mt-2">@gov.Name</small>
                                <span class="badge bg-light text-dark">@gov.Count</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Actions -->
        <div class="col-lg-4">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">آخر التحديثات</h6>
                </div>
                <div class="card-body">
                    <div class="timeline" style="border-right: 2px solid #e3e6f0; padding-right: 20px;">
                        <!-- Static dummy activities -->
                        <div class="activity-item mb-3 position-relative">
                            <i class="fas fa-circle text-primary position-absolute" style="right: -27px; top: 5px; font-size: 12px; background: white;"></i>
                            <div class="small text-muted">منذ ساعتين</div>
                            <strong>أحمد علي</strong> قام بتحديث عقار <a href="#">WQF-01-2024-X12</a>
                        </div>
                        <div class="activity-item mb-3 position-relative">
                            <i class="fas fa-circle text-success position-absolute" style="right: -27px; top: 5px; font-size: 12px; background: white;"></i>
                            <div class="small text-muted">منذ 5 ساعات</div>
                            <strong>سارة محمد</strong> رفعت مستندات لعقار <a href="#">WQF-01-2024-Y45</a>
                        </div>
                        <div class="activity-item position-relative">
                            <i class="fas fa-circle text-warning position-absolute" style="right: -27px; top: 5px; font-size: 12px; background: white;"></i>
                            <div class="small text-muted">يوم أمس</div>
                            <strong>منظومة GIS</strong> قامت بمزامنة 12 موقعاً جديداً
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
