@model IEnumerable<WaqfSystem.Core.Entities.User>
@{
    ViewData["Title"] = "إدارة المستخدمين";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h3 mb-0 text-gray-800"><i class="fas fa-users-cog me-2"></i> إدارة مستخدمي النظام</h2>
    <a href="#" class="btn btn-primary shadow-sm">
        <i class="fas fa-user-plus fa-sm me-1"></i> إضافة مستخدم جديد
    </a>
</div>

<div class="card shadow border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-secondary small text-uppercase">
                    <tr>
                        <th class="ps-4">المستخدم</th>
                        <th>الدور الوظيفي</th>
                        <th>النطاق الجغرافي</th>
                        <th>الحالة</th>
                        <th>آخر دخول</th>
                        <th class="text-center pe-4">الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <div class="rounded-circle bg-soft-primary p-2 me-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; background-color: rgba(13, 110, 253, 0.1);">
                                        <i class="fas fa-user text-primary"></i>
                                    </div>
                                    <div>
                                        <div class="fw-bold">@user.FullNameAr</div>
                                        <div class="small text-muted">@user.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-info-subtle text-info rounded-pill px-3">
                                    @(user.Role?.NameAr ?? user.Role?.Code ?? "غير محدد")
                                </span>
                            </td>
                            <td>
                                @(user.Governorate?.NameAr ?? "كل العراق")
                            </td>
                            <td>
                                @if (user.IsActive)
                                {
                                    <span class="badge bg-success-subtle text-success rounded-pill px-3">
                                        <i class="fas fa-check-circle me-1"></i> نشط
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger-subtle text-danger rounded-pill px-3">
                                        <i class="fas fa-times-circle me-1"></i> غير نشط
                                    </span>
                                }
                            </td>
                            <td class="small text-muted">
                                @(user.LastLoginAt?.ToString("yyyy/MM/dd HH:mm") ?? "لم يدخل بعد")
                            </td>
                            <td class="text-center pe-4">
                                <div class="btn-group">
                                    <button class="btn btn-sm btn-light text-primary" title="تعديل"><i class="fas fa-edit"></i></button>
                                    <button class="btn btn-sm btn-light text-danger" title="تعطيل"><i class="fas fa-user-slash"></i></button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
