        <p class="mb-2"><strong>المحيط:</strong> ${p.perimeterMeters ? p.perimeterMeters.toFixed(2) + ' م' : '-'}</p>
        <a href="${url}${p.entityId}" class="btn btn-sm btn-warning"><i class="fas fa-edit me-1"></i>تعديل الحدود</a>
    </div>`;
}

// Layer Toggle
function toggleLayer(layerName) {
    var checkbox = document.getElementById('layer' + layerName.charAt(0).toUpperCase() + layerName.slice(1));
    if (checkbox && checkbox.checked) map.addLayer(layers[layerName]);
    else if (checkbox) map.removeLayer(layers[layerName]);
}

// Base Map
function setBaseMap(type, btn) {
    map.removeLayer(osmLayer); map.removeLayer(satelliteLayer);
    map.removeLayer(terrainLayer); map.removeLayer(hybridLabels);
    document.querySelectorAll('#baseMapBtns .btn').forEach(b => b.classList.remove('active'));
    if (btn) btn.classList.add('active');
    switch(type) {
        case 'osm': map.addLayer(osmLayer); break;
        case 'satellite': map.addLayer(satelliteLayer); break;
        case 'terrain': map.addLayer(terrainLayer); break;
        case 'hybrid': map.addLayer(satelliteLayer); map.addLayer(hybridLabels); break;
    }
}

// Drawing Functions
function startDrawPolygon() { new L.Draw.Polygon(map, drawControl.options.draw.polygon).enable(); }
function startDrawLine() { new L.Draw.Polyline(map, drawControl.options.draw.polyline).enable(); }
function startDrawMarker() { new L.Draw.Marker(map, drawControl.options.draw.marker).enable(); }
function enableEdit() { drawnItems.eachLayer(l => l.editing?.enable()); }
function deleteSelected() { drawnItems.clearLayers(); document.getElementById('drawingInfo').style.display = 'none'; }
function clearDrawings() { drawnItems.clearLayers(); currentDrawnLayer = null; document.getElementById('drawingInfo').style.display = 'none'; }

function updateDrawingInfo(layer) {
    document.getElementById('drawingInfo').style.display = 'block';
    if (layer.getLatLngs) {
        var latlngs = layer.getLatLngs()[0] || layer.getLatLngs();
        if (Array.isArray(latlngs[0])) latlngs = latlngs[0];
        var area = L.GeometryUtil.geodesicArea(latlngs);
        var perimeter = 0;
        for (var i = 0; i < latlngs.length - 1; i++) perimeter += latlngs[i].distanceTo(latlngs[i + 1]);
        if (layer instanceof L.Polygon) perimeter += latlngs[latlngs.length - 1].distanceTo(latlngs[0]);
        document.getElementById('drawArea').textContent = area.toFixed(2) + ' م²';
        document.getElementById('drawPerimeter').textContent = perimeter.toFixed(2) + ' م';
    }
}

// Save Functions
async function loadEntitiesForSave() {
    var type = document.getElementById('saveEntityType').value;
    var entityDiv = document.getElementById('entitySelectDiv');
    var newFieldsDiv = document.getElementById('newEntityFields');
    var select = document.getElementById('saveEntityId');
    if (type === 'mosque' || type === 'property') {
        entityDiv.style.display = 'block';
        newFieldsDiv.style.display = 'none';
        select.innerHTML = '<option value="">جاري التحميل...</option>';
        try {
            var url = type === 'mosque' ? '/api/GisApi/layers/mosques/geojson' : '/api/GisApi/layers/properties/geojson';
            var response = await fetch(url);
            var data = await response.json();
            select.innerHTML = '<option value="">-- اختر --</option>';
            data.features.forEach(f => {
                select.innerHTML += `<option value="${f.properties.id}">${f.properties.name} (${f.properties.code})</option>`;
            });
        } catch (e) { console.error(e); }
    } else if (type === 'land' || type === 'road') {
        entityDiv.style.display = 'none';
        newFieldsDiv.style.display = 'block';
    } else {
        entityDiv.style.display = 'none';
        newFieldsDiv.style.display = 'none';
    }
}

async function saveGeometry() {
    if (!currentDrawnLayer) { alert('لا يوجد شكل للحفظ'); return; }
    var type = document.getElementById('saveEntityType').value;
    var geoJson = currentDrawnLayer.toGeoJSON();
    try {
        var url, body;
        if (type === 'mosque') {
            var mosqueId = document.getElementById('saveEntityId').value;
            if (!mosqueId) { alert('اختر المسجد'); return; }
            url = `/api/GisApi/mosques/${mosqueId}/boundary`;
            body = { geoJson: JSON.stringify(geoJson.geometry), boundaryType: 'Building' };
        } else if (type === 'property') {
            var propertyId = document.getElementById('saveEntityId').value;
            if (!propertyId) { alert('اختر العقار'); return; }
            url = `/api/GisApi/properties/${propertyId}/boundary`;
            body = { geoJson: JSON.stringify(geoJson.geometry), boundaryType: 'Building' };
        } else if (type === 'land') {
            url = '/api/GisApi/lands';
            body = { nameAr: document.getElementById('newEntityName').value, provinceId: parseInt(document.getElementById('newEntityProvince').value), boundaryGeoJson: JSON.stringify(geoJson.geometry), landType: 'Waqf', landUse: 'Vacant' };
        } else if (type === 'road') {
            url = '/api/GisApi/roads';
            body = { nameAr: document.getElementById('newEntityName').value, provinceId: parseInt(document.getElementById('newEntityProvince').value), geometryGeoJson: JSON.stringify(geoJson.geometry), roadType: 'Local' };
        }
        var response = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
        if (response.ok) {
            alert('تم الحفظ بنجاح');
            bootstrap.Modal.getInstance(document.getElementById('saveModal')).hide();
            drawnItems.clearLayers();
            loadAllData();
        } else {
            alert('خطأ: ' + await response.text());
        }
    } catch (e) { console.error(e); alert('حدث خطأ أثناء الحفظ'); }
}

// Search - بحث ذكي يعمل على الفهرس المركزي
function searchFeatures() {
    var term = document.getElementById('searchInput').value.trim().toLowerCase();
    if (!term) return;

    // تجنب التكرار: مسجد يظهر كـ point وكـ boundary - نأخذ الـ point فقط
    var seen = new Set();
    var results = [];

    allFeaturesIndex.forEach(function(item) {
        var p = item.feature.properties;
        // تجاهل الـ boundaries في البحث (نكتفي بالـ points)
        if (item.entityType === 'mosqueBoundary' || item.entityType === 'propertyBoundary') return;

        var id = (p.id || '') + '_' + item.entityType;
        if (seen.has(id)) return;
        seen.add(id);

        var name = (p.name || p.entityName || '').toLowerCase();
        var code = (p.code || p.entityCode || '').toLowerCase();
        var address = (p.address || '').toLowerCase();
        var neighborhood = (p.neighborhood || '').toLowerCase();

        if (name.includes(term) || code.includes(term) || address.includes(term) || neighborhood.includes(term)) {
            var typeLabel = item.entityType === 'mosque' ? '🕌' : item.entityType === 'property' ? '🏢' : item.entityType === 'land' ? '🗺️' : '🛣️';
            results.push({ layer: item.layer, name: typeLabel + ' ' + (p.name || p.entityName || p.code || '') });
        }
    });

    // إزالة نتائج البحث السابقة
    var existingPanel = document.getElementById('searchResultsPanel');
    if (existingPanel) existingPanel.remove();

    if (results.length === 0) {
        showSearchNotification('لم يتم العثور على: ' + term, 'warning');
        return;
    }

    if (results.length === 1) {
        // نتيجة واحدة فقط - اذهب إليها مباشرة
        zoomToFeature(results[0].layer);
        return;
    }

    // أكثر من نتيجة - عرض قائمة
    var panel = document.createElement('div');
    panel.id = 'searchResultsPanel';
    panel.style.cssText = 'position:absolute;top:80px;right:330px;z-index:2000;background:white;border-radius:8px;box-shadow:0 4px 15px rgba(0,0,0,0.2);max-width:300px;max-height:400px;overflow-y:auto;direction:rtl;';
    panel.innerHTML = `
        <div style="padding:10px 15px;background:#1e88e5;color:white;border-radius:8px 8px 0 0;display:flex;justify-content:space-between;align-items:center;">
            <strong><i class="fas fa-search me-2"></i>نتائج البحث (${results.length})</strong>
            <button onclick="document.getElementById('searchResultsPanel').remove()" style="background:none;border:none;color:white;cursor:pointer;"><i class="fas fa-times"></i></button>
        </div>
        <div id="searchResultsList">${results.map((r,i) => `
            <div style="padding:8px 12px;border-bottom:1px solid #eee;cursor:pointer;" onclick="zoomToFeatureByIndex(${i})" onmouseover="this.style.background='#f0f7ff'" onmouseout="this.style.background='white'">
                <i class="fas fa-map-marker-alt text-primary me-2"></i>${r.name}
            </div>`).join('')}
        </div>`;
    document.querySelector('.col-lg-9').appendChild(panel);

    // تخزين النتائج للوصول إليها
    window._searchResults = results;
    showSearchNotification(`وجد ${results.length} نتيجة`, 'success');
}

function zoomToFeature(layer) {
    if (layer.getBounds) map.fitBounds(layer.getBounds(), { maxZoom: 18, padding: [50, 50] });
    else if (layer.getLatLng) map.setView(layer.getLatLng(), 18);
    layer.openPopup();
}

function zoomToFeatureByIndex(index) {
    if (window._searchResults && window._searchResults[index]) {
        zoomToFeature(window._searchResults[index].layer);
    }
}

function showSearchNotification(msg, type) {
    var colors = { success: '#28a745', warning: '#ffc107', danger: '#dc3545' };
    var n = document.createElement('div');
    n.style.cssText = `position:absolute;bottom:30px;right:50%;transform:translateX(50%);z-index:3000;background:${colors[type]||'#333'};color:white;padding:10px 20px;border-radius:20px;font-weight:bold;box-shadow:0 3px 10px rgba(0,0,0,0.3);`;
    n.textContent = msg;
    document.body.appendChild(n);
    setTimeout(() => n.remove(), 3000);
}

document.getElementById('searchInput').addEventListener('keypress', function(e) {
    if (e.key === 'Enter') searchFeatures();
});

function filterByProvince() { loadAllData(); }

// Initialize
loadIraqBoundary();
loadAllData();
</script>
