@{
    ViewData["Title"] = "الخريطة التفاعلية المتكاملة";
    Layout = "_Layout";
}

<style>
    #mainMap { height: calc(100vh - 120px); min-height: 600px; }
    .layer-item { padding: 8px 12px; border-bottom: 1px solid #eee; cursor: pointer; }
    .layer-item:hover { background: #f8f9fa; }
    .layer-color { width: 16px; height: 16px; border-radius: 3px; display: inline-block; margin-left: 8px; }
    .sidebar-panel { max-height: calc(100vh - 180px); overflow-y: auto; }
    .feature-popup { min-width: 250px; }
    .feature-popup h6 { border-bottom: 2px solid #007bff; padding-bottom: 5px; }
    .stat-card { text-align: center; padding: 10px; background: #f8f9fa; border-radius: 5px; }
    .drawing-tools .btn { margin: 2px; }
</style>

<div class="row g-0">
    <!-- Sidebar -->
    <div class="col-lg-3 bg-white shadow-sm" style="z-index:1000;">
        <div class="p-3 bg-primary text-white">
            <h5 class="mb-0"><i class="fas fa-map-marked-alt me-2"></i>الخريطة التفاعلية</h5>
        </div>
        
        <!-- Search -->
        <div class="p-3 border-bottom">
            <div class="input-group">
                <input type="text" id="searchInput" class="form-control" placeholder="بحث بالاسم أو الكود...">
                <button class="btn btn-outline-primary" onclick="searchFeatures()"><i class="fas fa-search"></i></button>
            </div>
        </div>

        <!-- Quick Stats -->
        <div class="p-3 border-bottom">
            <div class="row g-2 text-center">
                <div class="col-4">
                    <div class="stat-card">
                        <i class="fas fa-mosque text-primary"></i>
                        <h6 class="mb-0" id="statMosques">0</h6>
                        <small>مسجد</small>
                    </div>
                </div>
                <div class="col-4">
                    <div class="stat-card">
                        <i class="fas fa-building text-success"></i>
                        <h6 class="mb-0" id="statProperties">0</h6>
                        <small>عقار</small>
                    </div>
                </div>
                <div class="col-4">
                    <div class="stat-card">
                        <i class="fas fa-map text-warning"></i>
                        <h6 class="mb-0" id="statLands">0</h6>
                        <small>أرض</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Layers Panel -->
        <div class="p-3 border-bottom">
            <h6 class="mb-2"><i class="fas fa-layer-group me-2"></i>الطبقات</h6>
            <div class="sidebar-panel" style="max-height:220px;">
                <div class="layer-item">
                    <input type="checkbox" id="layerIraqBoundary" checked onchange="toggleLayer('iraqBoundary')">
                    <span class="layer-color" style="background:#c62828;border:2px solid #c62828;"></span>
                    <label for="layerIraqBoundary">🇮🇶 حدود العراق</label>
                </div>
                <div class="layer-item">
                    <input type="checkbox" id="layerMosques" checked onchange="toggleLayer('mosques')">
                    <span class="layer-color" style="background:#1e88e5;"></span>
                    <label for="layerMosques">المساجد (نقاط)</label>
                </div>
                <div class="layer-item">
                    <input type="checkbox" id="layerMosqueBoundaries" checked onchange="toggleLayer('mosqueBoundaries')">
                    <span class="layer-color" style="background:#1565c0;"></span>
                    <label for="layerMosqueBoundaries">حدود المساجد</label>
                </div>
                <div class="layer-item">
                    <input type="checkbox" id="layerProperties" checked onchange="toggleLayer('properties')">
                    <span class="layer-color" style="background:#43a047;"></span>
                    <label for="layerProperties">العقارات (نقاط)</label>
                </div>
                <div class="layer-item">
                    <input type="checkbox" id="layerPropertyBoundaries" onchange="toggleLayer('propertyBoundaries')">
                    <span class="layer-color" style="background:#2e7d32;"></span>
                    <label for="layerPropertyBoundaries">حدود العقارات</label>
                </div>
                <div class="layer-item">
                    <input type="checkbox" id="layerLands" onchange="toggleLayer('lands')">
                    <span class="layer-color" style="background:#ff9800;"></span>
                    <label for="layerLands">أراضي الوقف</label>
                </div>
                <div class="layer-item">
                    <input type="checkbox" id="layerRoads" onchange="toggleLayer('roads')">
                    <span class="layer-color" style="background:#795548;"></span>
                    <label for="layerRoads">الطرق</label>
                </div>
            </div>
        </div>

        <!-- Drawing Tools -->
        <div class="p-3 border-bottom">
            <h6 class="mb-2"><i class="fas fa-pencil-alt me-2"></i>أدوات الرسم</h6>
            <div class="drawing-tools">
                <button class="btn btn-sm btn-outline-primary" onclick="startDrawPolygon()" title="رسم مضلع"><i class="fas fa-draw-polygon"></i></button>
                <button class="btn btn-sm btn-outline-info" onclick="startDrawLine()" title="رسم خط"><i class="fas fa-route"></i></button>
                <button class="btn btn-sm btn-outline-success" onclick="startDrawMarker()" title="إضافة نقطة"><i class="fas fa-map-marker-alt"></i></button>
                <button class="btn btn-sm btn-outline-warning" onclick="enableEdit()" title="تعديل"><i class="fas fa-edit"></i></button>
                <button class="btn btn-sm btn-outline-danger" onclick="deleteSelected()" title="حذف"><i class="fas fa-trash"></i></button>
                <button class="btn btn-sm btn-secondary" onclick="clearDrawings()" title="مسح الكل"><i class="fas fa-eraser"></i></button>
            </div>
            <div id="drawingInfo" class="mt-2 p-2 bg-light rounded small" style="display:none;">
                <div class="row">
                    <div class="col-6"><strong>المساحة:</strong> <span id="drawArea">--</span></div>
                    <div class="col-6"><strong>المحيط:</strong> <span id="drawPerimeter">--</span></div>
                </div>
            </div>
        </div>

        <!-- Base Maps -->
        <div class="p-3 border-bottom">
            <h6 class="mb-2"><i class="fas fa-globe me-2"></i>الخريطة الأساسية</h6>
            <div class="btn-group btn-group-sm w-100" id="baseMapBtns">
                <button class="btn btn-outline-secondary active" onclick="setBaseMap('osm',this)">عادية</button>
                <button class="btn btn-outline-secondary" onclick="setBaseMap('satellite',this)">فضائية</button>
                <button class="btn btn-outline-secondary" onclick="setBaseMap('hybrid',this)">هجين</button>
                <button class="btn btn-outline-secondary" onclick="setBaseMap('terrain',this)">تضاريس</button>
            </div>
        </div>

        <!-- Province Filter -->
        <div class="p-3">
            <h6 class="mb-2"><i class="fas fa-filter me-2"></i>تصفية بالمحافظة</h6>
            <select id="provinceFilter" class="form-select form-select-sm" onchange="filterByProvince()">
                <option value="">جميع المحافظات</option>
                @foreach (var province in ViewBag.Provinces as IEnumerable<WaqfGIS.Core.Entities.Province> ?? new List<WaqfGIS.Core.Entities.Province>())
                {
                    <option value="@province.Id">@province.NameAr</option>
                }
            </select>
            <button class="btn btn-sm btn-outline-danger mt-2 w-100" onclick="zoomToIraq()">
                <i class="fas fa-compress-arrows-alt me-1"></i>التركيز على العراق
            </button>
        </div>
    </div>

    <!-- Map Area -->
    <div class="col-lg-9">
        <div id="mainMap"></div>
    </div>
</div>

<!-- Save Modal -->
<div class="modal fade" id="saveModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="fas fa-save me-2"></i>حفظ الحدود</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">نوع الكيان</label>
                    <select id="saveEntityType" class="form-select" onchange="loadEntitiesForSave()">
                        <option value="">-- اختر --</option>
                        <option value="mosque">حدود مسجد</option>
                        <option value="property">حدود عقار</option>
                        <option value="land">أرض وقف جديدة</option>
                        <option value="road">طريق جديد</option>
                    </select>
                </div>
                <div id="entitySelectDiv" class="mb-3" style="display:none;">
                    <label class="form-label">اختر الكيان</label>
                    <select id="saveEntityId" class="form-select"></select>
                </div>
                <div id="newEntityFields" style="display:none;">
                    <div class="mb-3">
                        <label class="form-label">الاسم</label>
                        <input type="text" id="newEntityName" class="form-control">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">المحافظة</label>
                        <select id="newEntityProvince" class="form-select">
                            @foreach (var province in ViewBag.Provinces as IEnumerable<WaqfGIS.Core.Entities.Province> ?? new List<WaqfGIS.Core.Entities.Province>())
                            {
                                <option value="@province.Id">@province.NameAr</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="alert alert-info">
                    <strong>المساحة:</strong> <span id="modalArea">--</span> م²
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                <button type="button" class="btn btn-primary" onclick="saveGeometry()">
                    <i class="fas fa-save me-1"></i>حفظ
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet.draw/1.0.4/leaflet.draw.css" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet.draw/1.0.4/leaflet.draw.js"></script>

<script>
// Base Maps
var osmLayer = L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '© OpenStreetMap' });
var satelliteLayer = L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', { attribution: '© Esri' });
var terrainLayer = L.tileLayer('https://{s}.tile.opentopomap.org/{z}/{x}/{y}.png', { attribution: '© OpenTopoMap' });
var hybridLabels = L.tileLayer('https://{s}.basemaps.cartocdn.com/light_only_labels/{z}/{x}/{y}{r}.png');

// Initialize Map centered on Iraq
var map = L.map('mainMap', { layers: [osmLayer] }).setView([33.3, 44.4], 6);

// Layer Groups
var layers = {
    iraqBoundary: L.layerGroup().addTo(map),
    mosques: L.layerGroup().addTo(map),
    mosqueBoundaries: L.layerGroup().addTo(map),
    properties: L.layerGroup().addTo(map),
    propertyBoundaries: L.layerGroup(),
    lands: L.layerGroup(),
    roads: L.layerGroup()
};

var drawnItems = new L.FeatureGroup().addTo(map);
var currentDrawnLayer = null;

// ===== Iraq Boundary =====
// حدود العراق الجغرافية الحقيقية (مبسطة)
var iraqCoords = [
    [37.0, 30.0],[38.0, 29.5],[39.2, 29.1],[40.0, 29.0],[41.2, 29.5],
    [42.0, 30.0],[43.5, 29.7],[44.7, 29.2],[46.3, 29.1],[47.4, 30.0],
    [47.9, 30.0],[48.0, 30.4],[48.6, 30.4],[48.9, 30.9],[47.7, 31.0],
    [47.4, 31.2],[47.8, 32.0],[48.3, 31.7],[48.9, 30.9],[47.4, 32.4],
    [46.5, 34.0],[45.4, 34.0],[45.6, 35.1],[44.8, 37.1],[44.2, 38.0],
    [43.9, 37.3],[42.8, 37.4],[42.3, 37.2],[41.2, 37.1],[40.7, 37.1],
    [39.5, 37.1],[38.8, 36.8],[38.6, 34.0],[37.0, 33.4],[37.0, 30.0]
];

function loadIraqBoundary() {
    layers.iraqBoundary.clearLayers();
    
    // الطبقة الخارجية للتمييز (ظل خارجي)
    var iraqOuterGlow = L.polygon(iraqCoords, {
        color: '#c62828',
        weight: 6,
        opacity: 0.25,
        fill: false
    }).addTo(layers.iraqBoundary);
    
    // الحدود الرئيسية
    var iraqPolygon = L.polygon(iraqCoords, {
        color: '#c62828',
        weight: 3,
        opacity: 1.0,
        dashArray: '8, 5',
        fillColor: '#fff9c4',
        fillOpacity: 0.07,
        interactive: false
    }).addTo(layers.iraqBoundary);
    
    // علامة اسم الدولة في وسط العراق
    var countryLabel = L.marker([33.3, 43.7], {
        icon: L.divIcon({
            className: '',
            html: '<div style="font-size:15px;font-weight:bold;color:#b71c1c;text-shadow:0 0 4px white,0 0 4px white,0 0 4px white;pointer-events:none;white-space:nowrap;">🇮🇶 جمهورية العراق</div>',
            iconSize: [200, 30],
            iconAnchor: [100, 15]
        }),
        interactive: false,
        zIndexOffset: -1000
    }).addTo(layers.iraqBoundary);
    
    iraqPolygon.bindTooltip('جمهورية العراق', {
        permanent: false,
        direction: 'center',
        className: 'fw-bold text-danger'
    });
}

function zoomToIraq() {
    map.flyToBounds(L.latLngBounds(iraqCoords), { padding: [30, 30], duration: 1.5 });
}

// Draw Control
var drawControl = new L.Control.Draw({
    position: 'topright',
    draw: {
        polygon: { allowIntersection: false, shapeOptions: { color: '#ff5722', fillOpacity: 0.3 } },
        polyline: { shapeOptions: { color: '#795548', weight: 4 } },
        circle: false, circlemarker: false, rectangle: false,
        marker: { icon: L.icon({ iconUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.7.1/images/marker-icon.png', iconSize: [25, 41], iconAnchor: [12, 41] }) }
    },
    edit: { featureGroup: drawnItems }
});
map.addControl(drawControl);

// Draw Events
map.on(L.Draw.Event.CREATED, function(e) {
    currentDrawnLayer = e.layer;
    drawnItems.addLayer(e.layer);
    updateDrawingInfo(e.layer);
    if (e.layerType === 'polygon' || e.layerType === 'polyline') {
        new bootstrap.Modal(document.getElementById('saveModal')).show();
        document.getElementById('modalArea').textContent = document.getElementById('drawArea').textContent;
    }
});

map.on(L.Draw.Event.EDITED, function(e) {
    e.layers.eachLayer(function(layer) { updateDrawingInfo(layer); });
});

// Load All Data
async function loadAllData() {
    await Promise.all([
        loadMosques(), loadMosqueBoundaries(),
        loadProperties(), loadPropertyBoundaries(),
        loadLands(), loadRoads()
    ]);
}

async function loadMosques() {
    try {
        var response = await fetch('/api/GisApi/layers/mosques/geojson');
        var data = await response.json();
        layers.mosques.clearLayers();
        L.geoJSON(data, {
            pointToLayer: function(feature, latlng) {
                return L.circleMarker(latlng, { radius: 8, fillColor: '#1e88e5', color: '#1565c0', fillOpacity: 0.8, weight: 2 });
            },
            onEachFeature: function(feature, layer) { layer.bindPopup(createMosquePopup(feature.properties)); }
        }).addTo(layers.mosques);
        document.getElementById('statMosques').textContent = data.features?.length || 0;
    } catch (e) { console.error('Error loading mosques:', e); }
}

async function loadMosqueBoundaries() {
    try {
        var response = await fetch('/api/GisApi/layers/mosqueboundaries/geojson');
        var data = await response.json();
        layers.mosqueBoundaries.clearLayers();
        L.geoJSON(data, {
            style: { color: '#1565c0', fillColor: '#1e88e5', fillOpacity: 0.3, weight: 2 },
            onEachFeature: function(feature, layer) { layer.bindPopup(createBoundaryPopup(feature.properties, 'mosque')); }
        }).addTo(layers.mosqueBoundaries);
    } catch (e) { console.error('Error loading mosque boundaries:', e); }
}

async function loadProperties() {
    try {
        var response = await fetch('/api/GisApi/layers/properties/geojson');
        var data = await response.json();
        layers.properties.clearLayers();
        L.geoJSON(data, {
            pointToLayer: function(feature, latlng) {
                return L.circleMarker(latlng, { radius: 7, fillColor: '#43a047', color: '#2e7d32', fillOpacity: 0.8, weight: 2 });
            },
            onEachFeature: function(feature, layer) { layer.bindPopup(createPropertyPopup(feature.properties)); }
        }).addTo(layers.properties);
        document.getElementById('statProperties').textContent = data.features?.length || 0;
    } catch (e) { console.error('Error loading properties:', e); }
}

async function loadPropertyBoundaries() {
    try {
        var response = await fetch('/api/GisApi/layers/propertyboundaries/geojson');
        var data = await response.json();
        layers.propertyBoundaries.clearLayers();
        L.geoJSON(data, {
            style: { color: '#2e7d32', fillColor: '#43a047', fillOpacity: 0.3, weight: 2 },
            onEachFeature: function(feature, layer) { layer.bindPopup(createBoundaryPopup(feature.properties, 'property')); }
        }).addTo(layers.propertyBoundaries);
    } catch (e) { console.error('Error loading property boundaries:', e); }
}

async function loadLands() {
    try {
        var response = await fetch('/api/GisApi/layers/waqflands/geojson');
        var data = await response.json();
        layers.lands.clearLayers();
        L.geoJSON(data, {
            style: function(feature) {
                var color = feature.properties.landType === 'Waqf' ? '#ff9800' :
                           feature.properties.landType === 'Leased' ? '#2196f3' : '#9e9e9e';
                return { color: color, fillColor: color, fillOpacity: 0.3, weight: 2 };
            },
            onEachFeature: function(feature, layer) { layer.bindPopup(createLandPopup(feature.properties)); }
        }).addTo(layers.lands);
        document.getElementById('statLands').textContent = data.features?.length || 0;
    } catch (e) { console.error('Error loading lands:', e); }
}

async function loadRoads() {
    try {
        var response = await fetch('/api/GisApi/layers/roads/geojson');
        var data = await response.json();
        layers.roads.clearLayers();
        L.geoJSON(data, {
            style: function(feature) {
                var width = feature.properties.roadType === 'Highway' ? 5 : feature.properties.roadType === 'Main' ? 4 : 3;
                return { color: '#795548', weight: width };
            },
            onEachFeature: function(feature, layer) { layer.bindPopup(createRoadPopup(feature.properties)); }
        }).addTo(layers.roads);
    } catch (e) { console.error('Error loading roads:', e); }
}

// Popup Creators
function createMosquePopup(p) {
    return `<div class="feature-popup">
        <h6><i class="fas fa-mosque text-primary me-2"></i>${p.name}</h6>
        <p class="mb-1"><strong>الكود:</strong> ${p.code || '-'}</p>
        <p class="mb-1"><strong>النوع:</strong> ${p.type || '-'}</p>
        <p class="mb-1"><strong>الحالة:</strong> <span class="badge" style="background:${p.statusColor || '#6c757d'}">${p.status || '-'}</span></p>
        <p class="mb-2"><strong>المساحة:</strong> ${p.areaSqm ? p.areaSqm.toFixed(0) + ' م²' : '-'}</p>
        <div class="btn-group btn-group-sm">
            <a href="/Mosques/Details/${p.id}" class="btn btn-primary"><i class="fas fa-eye"></i></a>
            <a href="/Mosques/Edit/${p.id}" class="btn btn-warning"><i class="fas fa-edit"></i></a>
        </div>
    </div>`;
}

function createPropertyPopup(p) {
    return `<div class="feature-popup">
        <h6><i class="fas fa-building text-success me-2"></i>${p.name}</h6>
        <p class="mb-1"><strong>الكود:</strong> ${p.code || '-'}</p>
        <p class="mb-1"><strong>النوع:</strong> ${p.type || '-'}</p>
        <p class="mb-2"><strong>المساحة:</strong> ${p.areaSqm ? p.areaSqm.toFixed(0) + ' م²' : '-'}</p>
        <div class="btn-group btn-group-sm">
            <a href="/Properties/Details/${p.id}" class="btn btn-success"><i class="fas fa-eye"></i></a>
            <a href="/Properties/Edit/${p.id}" class="btn btn-warning"><i class="fas fa-edit"></i></a>
        </div>
    </div>`;
}

function createLandPopup(p) {
    return `<div class="feature-popup">
        <h6><i class="fas fa-map text-warning me-2"></i>${p.name}</h6>
        <p class="mb-1"><strong>الكود:</strong> ${p.code || '-'}</p>
        <p class="mb-1"><strong>النوع:</strong> ${p.landType || '-'}</p>
        <p class="mb-1"><strong>الاستخدام:</strong> ${p.landUse || '-'}</p>
        <p class="mb-2"><strong>المساحة:</strong> ${p.calculatedAreaSqm ? p.calculatedAreaSqm.toFixed(0) + ' م²' : '-'}</p>
        <div class="btn-group btn-group-sm">
            <a href="/WaqfLands/Details/${p.id}" class="btn btn-warning"><i class="fas fa-eye"></i></a>
            <a href="/WaqfLands/Edit/${p.id}" class="btn btn-info"><i class="fas fa-edit"></i></a>
        </div>
    </div>`;
}

function createRoadPopup(p) {
    return `<div class="feature-popup">
        <h6><i class="fas fa-road text-secondary me-2"></i>${p.name}</h6>
        <p class="mb-1"><strong>النوع:</strong> ${p.roadType || '-'}</p>
        <p class="mb-1"><strong>الطول:</strong> ${p.lengthMeters ? p.lengthMeters.toFixed(0) + ' م' : '-'}</p>
        <p class="mb-1"><strong>العرض:</strong> ${p.widthMeters ? p.widthMeters + ' م' : '-'}</p>
    </div>`;
}

function createBoundaryPopup(p, type) {
    var icon = type === 'mosque' ? 'fa-mosque text-primary' : 'fa-building text-success';
    var url = type === 'mosque' ? '/Mosques/Edit/' : '/Properties/Edit/';
    return `<div class="feature-popup">
        <h6><i class="fas ${icon} me-2"></i>حدود: ${p.entityName || '-'}</h6>
        <p class="mb-1"><strong>المساحة:</strong> ${p.calculatedAreaSqm ? p.calculatedAreaSqm.toFixed(2) + ' م²' : '-'}</p>
        <p class="mb-2"><strong>المحيط:</strong> ${p.perimeterMeters ? p.perimeterMeters.toFixed(2) + ' م' : '-'}</p>
        <a href="${url}${p.entityId}" class="btn btn-sm btn-warning"><i class="fas fa-edit me-1"></i>تعديل الحدود</a>
    </div>`;
}

// Layer Toggle
function toggleLayer(layerName) {
    var checkbox = document.getElementById('layer' + layerName.charAt(0).toUpperCase() + layerName.slice(1));
    if (checkbox && checkbox.checked) map.addLayer(layers[layerName]);
    else if (checkbox) map.removeLayer(layers[layerName]);
}

// Base Map
function setBaseMap(type, btn) {
    map.removeLayer(osmLayer); map.removeLayer(satelliteLayer);
    map.removeLayer(terrainLayer); map.removeLayer(hybridLabels);
    document.querySelectorAll('#baseMapBtns .btn').forEach(b => b.classList.remove('active'));
    if (btn) btn.classList.add('active');
    switch(type) {
        case 'osm': map.addLayer(osmLayer); break;
        case 'satellite': map.addLayer(satelliteLayer); break;
        case 'terrain': map.addLayer(terrainLayer); break;
        case 'hybrid': map.addLayer(satelliteLayer); map.addLayer(hybridLabels); break;
    }
}

// Drawing Functions
function startDrawPolygon() { new L.Draw.Polygon(map, drawControl.options.draw.polygon).enable(); }
function startDrawLine() { new L.Draw.Polyline(map, drawControl.options.draw.polyline).enable(); }
function startDrawMarker() { new L.Draw.Marker(map, drawControl.options.draw.marker).enable(); }
function enableEdit() { drawnItems.eachLayer(l => l.editing?.enable()); }
function deleteSelected() { drawnItems.clearLayers(); document.getElementById('drawingInfo').style.display = 'none'; }
function clearDrawings() { drawnItems.clearLayers(); currentDrawnLayer = null; document.getElementById('drawingInfo').style.display = 'none'; }

function updateDrawingInfo(layer) {
    document.getElementById('drawingInfo').style.display = 'block';
    if (layer.getLatLngs) {
        var latlngs = layer.getLatLngs()[0] || layer.getLatLngs();
        if (Array.isArray(latlngs[0])) latlngs = latlngs[0];
        var area = L.GeometryUtil.geodesicArea(latlngs);
        var perimeter = 0;
        for (var i = 0; i < latlngs.length - 1; i++) perimeter += latlngs[i].distanceTo(latlngs[i + 1]);
        if (layer instanceof L.Polygon) perimeter += latlngs[latlngs.length - 1].distanceTo(latlngs[0]);
        document.getElementById('drawArea').textContent = area.toFixed(2) + ' م²';
        document.getElementById('drawPerimeter').textContent = perimeter.toFixed(2) + ' م';
    }
}

// Save Functions
async function loadEntitiesForSave() {
    var type = document.getElementById('saveEntityType').value;
    var entityDiv = document.getElementById('entitySelectDiv');
    var newFieldsDiv = document.getElementById('newEntityFields');
    var select = document.getElementById('saveEntityId');
    if (type === 'mosque' || type === 'property') {
        entityDiv.style.display = 'block';
        newFieldsDiv.style.display = 'none';
        select.innerHTML = '<option value="">جاري التحميل...</option>';
        try {
            var url = type === 'mosque' ? '/api/GisApi/layers/mosques/geojson' : '/api/GisApi/layers/properties/geojson';
            var response = await fetch(url);
            var data = await response.json();
            select.innerHTML = '<option value="">-- اختر --</option>';
            data.features.forEach(f => {
                select.innerHTML += `<option value="${f.properties.id}">${f.properties.name} (${f.properties.code})</option>`;
            });
        } catch (e) { console.error(e); }
    } else if (type === 'land' || type === 'road') {
        entityDiv.style.display = 'none';
        newFieldsDiv.style.display = 'block';
    } else {
        entityDiv.style.display = 'none';
        newFieldsDiv.style.display = 'none';
    }
}

async function saveGeometry() {
    if (!currentDrawnLayer) { alert('لا يوجد شكل للحفظ'); return; }
    var type = document.getElementById('saveEntityType').value;
    var geoJson = currentDrawnLayer.toGeoJSON();
    try {
        var url, body;
        if (type === 'mosque') {
            var mosqueId = document.getElementById('saveEntityId').value;
            if (!mosqueId) { alert('اختر المسجد'); return; }
            url = `/api/GisApi/mosques/${mosqueId}/boundary`;
            body = { geoJson: JSON.stringify(geoJson.geometry), boundaryType: 'Building' };
        } else if (type === 'property') {
            var propertyId = document.getElementById('saveEntityId').value;
            if (!propertyId) { alert('اختر العقار'); return; }
            url = `/api/GisApi/properties/${propertyId}/boundary`;
            body = { geoJson: JSON.stringify(geoJson.geometry), boundaryType: 'Building' };
        } else if (type === 'land') {
            url = '/api/GisApi/lands';
            body = { nameAr: document.getElementById('newEntityName').value, provinceId: parseInt(document.getElementById('newEntityProvince').value), boundaryGeoJson: JSON.stringify(geoJson.geometry), landType: 'Waqf', landUse: 'Vacant' };
        } else if (type === 'road') {
            url = '/api/GisApi/roads';
            body = { nameAr: document.getElementById('newEntityName').value, provinceId: parseInt(document.getElementById('newEntityProvince').value), geometryGeoJson: JSON.stringify(geoJson.geometry), roadType: 'Local' };
        }
        var response = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
        if (response.ok) {
            alert('تم الحفظ بنجاح');
            bootstrap.Modal.getInstance(document.getElementById('saveModal')).hide();
            drawnItems.clearLayers();
            loadAllData();
        } else {
            alert('خطأ: ' + await response.text());
        }
    } catch (e) { console.error(e); alert('حدث خطأ أثناء الحفظ'); }
}

// Search
function searchFeatures() {
    var term = document.getElementById('searchInput').value.trim();
    if (!term) { alert('أدخل كلمة البحث'); return; }
    var results = [];
    for (var layerName in layers) {
        if (layerName === 'iraqBoundary') continue;
        layers[layerName].eachLayer(function(layer) {
            if (layer.feature && layer.feature.properties) {
                var p = layer.feature.properties;
                var name = p.name || p.entityName || '';
                var code = p.code || p.entityCode || '';
                if (name.includes(term) || code.includes(term)) results.push({ layer: layer, name: name });
            }
        });
    }
    if (results.length > 0) {
        var first = results[0];
        if (first.layer.getBounds) map.fitBounds(first.layer.getBounds(), { maxZoom: 18 });
        else if (first.layer.getLatLng) map.setView(first.layer.getLatLng(), 18);
        first.layer.openPopup();
    } else { alert('لم يتم العثور على: ' + term); }
}

document.getElementById('searchInput').addEventListener('keypress', function(e) {
    if (e.key === 'Enter') searchFeatures();
});

function filterByProvince() { loadAllData(); }

// Initialize
loadIraqBoundary();
loadAllData();
</script>
}
