@model WaqfGIS.Web.Models.DisputeViewModel
@{
    ViewData["Title"] = "تعديل الدعوى القضائية";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="fas fa-edit text-warning me-2"></i>تعديل الدعوى #@Model.CaseNumber</h4>
    <div class="d-flex gap-2">
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-info"><i class="fas fa-eye me-1"></i>عرض</a>
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-right me-1"></i>رجوع</a>
    </div>
</div>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

    <!-- الكيان الوقفي المرتبط بالدعوى -->
    <div class="card mb-4" style="border:2px solid #ffc107;">
        <div class="card-header bg-warning text-dark">
            <h5 class="mb-0"><i class="fas fa-mosque me-2"></i>الكيان الوقفي المتنازع عليه</h5>
        </div>
        <div class="card-body">
            @await Html.PartialAsync("_WaqfEntitySelector", new WaqfGIS.Web.Models.WaqfEntitySelectorModel {
                UniqueId = "disputeEdit",
                EntityTypeFieldId = "EntityType",
                EntityIdFieldId   = "EntityId",
                EntityNameFieldId = "EntityName",
                CurrentEntityType = Model.EntityType,
                CurrentEntityId   = Model.EntityId,
                CurrentEntityName = Model.EntityName
            })
        </div>
    </div>

    <div class="row">
        <!-- معلومات الدعوى -->
        <div class="col-md-6">
            <div class="card mb-4">
                <div class="card-header bg-primary text-white"><h5 class="mb-0">معلومات الدعوى</h5></div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="CaseNumber" class="form-label">رقم الدعوى</label>
                        <input asp-for="CaseNumber" class="form-control" />
                        <span asp-validation-for="CaseNumber" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="CaseDate" class="form-label">تاريخ الدعوى</label>
                        <input asp-for="CaseDate" type="date" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="CourtName" class="form-label">اسم المحكمة</label>
                        <input asp-for="CourtName" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="CourtType" class="form-label">نوع المحكمة</label>
                        <select asp-for="CourtType" class="form-select">
                            <option value="">-- اختر --</option>
                            <option value="بداءة">بداءة</option>
                            <option value="استئناف">استئناف</option>
                            <option value="تمييز">تمييز</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header bg-warning text-dark"><h5 class="mb-0">تفاصيل النزاع</h5></div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="DisputeType" class="form-label">نوع النزاع</label>
                        <select asp-for="DisputeType" class="form-select">
                            <option value="">-- اختر --</option>
                            <option value="ملكية">نزاع ملكية</option>
                            <option value="حدود">نزاع حدود</option>
                            <option value="استثمار">نزاع استثماري</option>
                            <option value="إزالة تجاوز">إزالة تجاوز</option>
                            <option value="تعويضات">تعويضات</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label asp-for="DisputeSubject" class="form-label">موضوع النزاع</label>
                        <input asp-for="DisputeSubject" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="DisputeDescription" class="form-label">وصف النزاع</label>
                        <textarea asp-for="DisputeDescription" class="form-control" rows="4"></textarea>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ClaimAmount" class="form-label">قيمة المطالبة</label>
                        <input asp-for="ClaimAmount" type="number" step="0.01" class="form-control" />
                    </div>
                </div>
            </div>
        </div>

        <!-- الأطراف والمحامي -->
        <div class="col-md-6">
            <div class="card mb-4">
                <div class="card-header bg-success text-white"><h5 class="mb-0">أطراف الدعوى</h5></div>
                <div class="card-body">
                    <h6 class="text-success">المدعي:</h6>
                    <div class="mb-2"><label asp-for="PlaintiffName" class="form-label small">الاسم</label><input asp-for="PlaintiffName" class="form-control" /></div>
                    <div class="mb-2"><label asp-for="PlaintiffPhone" class="form-label small">الهاتف</label><input asp-for="PlaintiffPhone" class="form-control" /></div>
                    <div class="mb-3"><label asp-for="PlaintiffAddress" class="form-label small">العنوان</label><textarea asp-for="PlaintiffAddress" class="form-control" rows="2"></textarea></div>
                    <hr class="my-3"/>
                    <h6 class="text-danger">المدعى عليه:</h6>
                    <div class="mb-2"><label asp-for="DefendantName" class="form-label small">الاسم</label><input asp-for="DefendantName" class="form-control" /></div>
                    <div class="mb-2"><label asp-for="DefendantPhone" class="form-label small">الهاتف</label><input asp-for="DefendantPhone" class="form-control" /></div>
                    <div class="mb-3"><label asp-for="DefendantAddress" class="form-label small">العنوان</label><textarea asp-for="DefendantAddress" class="form-control" rows="2"></textarea></div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header bg-secondary text-white"><h5 class="mb-0">بيانات المحامي</h5></div>
                <div class="card-body">
                    <div class="mb-2"><label asp-for="LawyerName" class="form-label small">الاسم</label><input asp-for="LawyerName" class="form-control" /></div>
                    <div class="mb-2"><label asp-for="LawyerPhone" class="form-label small">الهاتف</label><input asp-for="LawyerPhone" class="form-control" /></div>
                    <div class="mb-2"><label asp-for="LawyerLicenseNumber" class="form-label small">رقم الإجازة</label><input asp-for="LawyerLicenseNumber" class="form-control" /></div>
                    <div class="mb-2"><label asp-for="LegalCosts" class="form-label small">التكاليف القانونية</label><input asp-for="LegalCosts" type="number" step="0.01" class="form-control" /></div>
                </div>
            </div>
        </div>
    </div>

    <!-- الحالة -->
    <div class="card mb-4">
        <div class="card-header bg-info text-white"><h5 class="mb-0">الحالة والجلسات</h5></div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="CaseStatus" class="form-label">حالة الدعوى</label>
                    <select asp-for="CaseStatus" class="form-select">
                        <option value="جارية">جارية</option>
                        <option value="متوقفة">متوقفة</option>
                        <option value="منتهية">منتهية</option>
                    </select>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="CurrentStage" class="form-label">المرحلة الحالية</label>
                    <select asp-for="CurrentStage" class="form-select">
                        <option value="ابتدائية">ابتدائية</option>
                        <option value="استئنافية">استئنافية</option>
                        <option value="تمييزية">تمييزية</option>
                        <option value="تنفيذية">تنفيذية</option>
                    </select>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="NextHearingDate" class="form-label">تاريخ الجلسة القادمة</label>
                    <input asp-for="NextHearingDate" type="date" class="form-control" />
                </div>
            </div>
        </div>
    </div>

    <div class="text-center mb-4">
        <button type="submit" class="btn btn-warning btn-lg">
            <i class="fas fa-save me-2"></i>حفظ التعديلات
        </button>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary btn-lg ms-2">
            <i class="fas fa-times me-2"></i>إلغاء
        </a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
