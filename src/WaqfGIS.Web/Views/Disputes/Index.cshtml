@model IEnumerable<WaqfGIS.Core.Entities.LegalDispute>

@{
    ViewData["Title"] = "إدارة الدعاوى القضائية";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-gavel"></i> إدارة الدعاوى القضائية</h2>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus"></i> إضافة دعوى جديدة
        </a>
    </div>

    <!-- Summary Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-primary">
                <div class="card-body text-center">
                    <h3 class="text-primary">@Model.Count(d => d.CaseStatus == "جارية")</h3>
                    <p class="mb-0">دعاوى جارية</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-warning">
                <div class="card-body text-center">
                    <h3 class="text-warning">@Model.Count(d => d.NextHearingDate.HasValue && d.NextHearingDate <= DateTime.Now.AddDays(7))</h3>
                    <p class="mb-0">جلسات هذا الأسبوع</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-success">
                <div class="card-body text-center">
                    <h3 class="text-success">@Model.Count(d => d.HasVerdict && d.VerdictResult == "لصالح الوقف")</h3>
                    <p class="mb-0">لصالح الوقف</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-danger">
                <div class="card-body text-center">
                    <h3 class="text-danger">@Model.Count(d => d.HasVerdict && d.VerdictResult == "ضد الوقف")</h3>
                    <p class="mb-0">ضد الوقف</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">حالة الدعوى</label>
                    <select name="status" class="form-select">
                        <option value="">الكل</option>
                        <option value="جارية" selected="@(ViewBag.Status == "جارية")">جارية</option>
                        <option value="متوقفة" selected="@(ViewBag.Status == "متوقفة")">متوقفة</option>
                        <option value="منتهية" selected="@(ViewBag.Status == "منتهية")">منتهية</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">نوع النزاع</label>
                    <select name="disputeType" class="form-select">
                        <option value="">الكل</option>
                        <option value="ملكية" selected="@(ViewBag.DisputeType == "ملكية")">ملكية</option>
                        <option value="حدود" selected="@(ViewBag.DisputeType == "حدود")">حدود</option>
                        <option value="استثمار" selected="@(ViewBag.DisputeType == "استثمار")">استثمار</option>
                        <option value="إزالة تجاوز" selected="@(ViewBag.DisputeType == "إزالة تجاوز")">إزالة تجاوز</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">&nbsp;</label>
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-search"></i> بحث
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Disputes Table -->
    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>رقم الدعوى</th>
                            <th>الكيان</th>
                            <th>نوع النزاع</th>
                            <th>المحكمة</th>
                            <th>المرحلة</th>
                            <th>الجلسة القادمة</th>
                            <th>الحالة</th>
                            <th>الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            @foreach (var dispute in Model)
                            {
                                var statusClass = dispute.CaseStatus == "جارية" ? "primary" : 
                                                 dispute.CaseStatus == "منتهية" ? "secondary" : "warning";
                                <tr>
                                    <td>
                                        <strong>@dispute.CaseNumber</strong><br/>
                                        <small class="text-muted">@dispute.CaseDate.ToString("yyyy/MM/dd")</small>
                                    </td>
                                    <td>
                                        <span class="badge bg-info">@dispute.EntityType</span><br/>
                                        <small>@dispute.EntityName</small>
                                    </td>
                                    <td><span class="badge bg-secondary">@dispute.DisputeType</span></td>
                                    <td>
                                        <strong>@dispute.CourtName</strong><br/>
                                        <small class="text-muted">@dispute.CourtType</small>
                                    </td>
                                    <td>@dispute.CurrentStage</td>
                                    <td>
                                        @if (dispute.NextHearingDate.HasValue)
                                        {
                                            var daysUntil = (dispute.NextHearingDate.Value - DateTime.Now).Days;
                                            <span class="@(daysUntil <= 7 ? "text-warning" : "")">
                                                @dispute.NextHearingDate.Value.ToString("yyyy/MM/dd")
                                            </span>
                                            if (daysUntil > 0 && daysUntil <= 7)
                                            {
                                                <br/><small class="text-warning">بعد @daysUntil يوم</small>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td><span class="badge bg-@statusClass">@dispute.CaseStatus</span></td>
                                    <td>
                                        <a asp-action="Details" asp-route-id="@dispute.Id" class="btn btn-sm btn-info">
                                            <i class="fas fa-eye"></i> عرض
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center py-5">
                                    <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                                    <p class="text-muted">لا توجد دعاوى قضائية</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
