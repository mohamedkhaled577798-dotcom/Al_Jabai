@model WaqfGIS.Core.Entities.MaintenanceRecord
@{
    ViewData["Title"] = "إضافة سجل صيانة";
    var isEdit = Model.Id > 0;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-bold">
        <i class="fas fa-tools me-2 text-warning"></i>
        @(isEdit ? "تعديل سجل الصيانة" : "إضافة سجل صيانة جديد")
    </h4>
    <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-arrow-right me-1"></i>العودة
    </a>
</div>

<form asp-action="@(isEdit ? "Edit" : "Create")" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    @if (isEdit) { <input type="hidden" asp-for="Id" /> }

    <div class="row g-3">
        <!-- Right Column: بيانات الصيانة -->
        <div class="col-lg-8">

            <!-- الكيان الوقفي -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-warning bg-opacity-10">
                    <h6 class="mb-0 text-warning"><i class="fas fa-mosque me-2"></i>الكيان الوقفي</h6>
                </div>
                <div class="card-body">
                    @await Html.PartialAsync("_WaqfEntitySelector", new WaqfGIS.Web.Models.WaqfEntitySelectorModel {
                        EntityTypeFieldId = "EntityType",
                        EntityIdFieldId   = "EntityId",
                        EntityNameFieldId = "EntityName",
                        CurrentEntityType = Model.EntityType,
                        CurrentEntityId   = Model.EntityId,
                        CurrentEntityName = Model.EntityName,
                        UniqueId          = "maint"
                    })
                </div>
            </div>

            <!-- بيانات الصيانة الأساسية -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header">
                    <h6 class="mb-0"><i class="fas fa-info-circle me-2 text-primary"></i>تفاصيل الصيانة</h6>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Title" class="form-label fw-bold">عنوان الصيانة <span class="text-danger">*</span></label>
                            <input asp-for="Title" class="form-control" placeholder="مثال: صيانة نظام الكهرباء الرئيسي" required />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="MaintenanceType" class="form-label fw-bold">نوع الصيانة <span class="text-danger">*</span></label>
                            <select asp-for="MaintenanceType" class="form-select" required>
                                <option value="">-- اختر --</option>
                                @foreach (var t in ViewBag.MaintenanceTypes as List<string>)
                                {<option value="@t">@t</option>}
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Priority" class="form-label fw-bold">الأولوية</label>
                            <select asp-for="Priority" class="form-select">
                                @foreach (var p in ViewBag.Priorities as List<string>)
                                {<option value="@p">@p</option>}
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Status" class="form-label fw-bold">الحالة</label>
                            <select asp-for="Status" class="form-select">
                                @foreach (var s in ViewBag.Statuses as List<string>)
                                {<option value="@s">@s</option>}
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ScheduledDate" class="form-label fw-bold">التاريخ المجدول <span class="text-danger">*</span></label>
                            <input asp-for="ScheduledDate" type="date" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Location" class="form-label fw-bold">الموقع داخل العقار</label>
                            <input asp-for="Location" class="form-control" placeholder="مثال: الطابق الأول، السطح، المدخل..." />
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label fw-bold">وصف الصيانة <span class="text-danger">*</span></label>
                            <textarea asp-for="Description" class="form-control" rows="3" required
                                      placeholder="وصف تفصيلي للمشكلة والأعمال المطلوبة..."></textarea>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ProvinceId" class="form-label fw-bold">المحافظة</label>
                            @Html.DropDownListFor(m => m.ProvinceId, ViewBag.Provinces as SelectList,
                                "-- اختر المحافظة --", new { @class = "form-select" })
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EstimatedCost" class="form-label fw-bold">التكلفة التقديرية (د.ع)</label>
                            <input asp-for="EstimatedCost" type="number" class="form-control" min="0" step="1000" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- الصيانة الدورية -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header">
                    <h6 class="mb-0"><i class="fas fa-redo me-2 text-info"></i>الصيانة الدورية</h6>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <div class="form-check form-switch">
                                <input asp-for="IsRecurring" class="form-check-input" id="isRecurring"
                                       onchange="toggleRecurring(this.checked)" />
                                <label class="form-check-label fw-bold" for="isRecurring">صيانة دورية متكررة</label>
                            </div>
                        </div>
                        <div class="col-md-4" id="recurrenceDiv" style="display:@(Model.IsRecurring?"block":"none")">
                            <label asp-for="RecurrenceInterval" class="form-label fw-bold">الدورية</label>
                            <select asp-for="RecurrenceInterval" class="form-select">
                                <option value="">-- اختر --</option>
                                @foreach (var r in ViewBag.Recurrences as List<string>)
                                {<option value="@r">@r</option>}
                            </select>
                        </div>
                        <div class="col-md-4" id="nextDateDiv" style="display:@(Model.IsRecurring?"block":"none")">
                            <label asp-for="NextScheduledDate" class="form-label fw-bold">الصيانة القادمة</label>
                            <input asp-for="NextScheduledDate" type="date" class="form-control" />
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- Left Column: المقاول + الضمان + الصور -->
        <div class="col-lg-4">

            <!-- المقاول -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header">
                    <h6 class="mb-0"><i class="fas fa-hard-hat me-2 text-secondary"></i>بيانات المقاول</h6>
                </div>
                <div class="card-body">
                    <div class="mb-2">
                        <label asp-for="ContractorName" class="form-label small fw-bold">اسم المقاول/الشركة</label>
                        <input asp-for="ContractorName" class="form-control form-control-sm" />
                    </div>
                    <div class="mb-2">
                        <label asp-for="ContractorCompany" class="form-label small fw-bold">اسم الشركة</label>
                        <input asp-for="ContractorCompany" class="form-control form-control-sm" />
                    </div>
                    <div class="mb-2">
                        <label asp-for="ContractorPhone" class="form-label small fw-bold">رقم الهاتف</label>
                        <input asp-for="ContractorPhone" class="form-control form-control-sm" type="tel" />
                    </div>
                    <div class="mb-2">
                        <label asp-for="ContractorLicense" class="form-label small fw-bold">رقم الترخيص</label>
                        <input asp-for="ContractorLicense" class="form-control form-control-sm" />
                    </div>
                    <div class="mb-2">
                        <label asp-for="InvoiceNumber" class="form-label small fw-bold">رقم الفاتورة</label>
                        <input asp-for="InvoiceNumber" class="form-control form-control-sm" />
                    </div>
                </div>
            </div>

            <!-- الضمان -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header">
                    <h6 class="mb-0"><i class="fas fa-shield-alt me-2 text-success"></i>الضمان</h6>
                </div>
                <div class="card-body">
                    <div class="form-check form-switch mb-2">
                        <input asp-for="IsWarranty" class="form-check-input" id="isWarranty"
                               onchange="toggleWarranty(this.checked)" />
                        <label class="form-check-label" for="isWarranty">يوجد ضمان</label>
                    </div>
                    <div id="warrantyDiv" style="display:@(Model.IsWarranty?"block":"none")">
                        <label asp-for="WarrantyMonths" class="form-label small fw-bold">مدة الضمان (شهر)</label>
                        <input asp-for="WarrantyMonths" type="number" class="form-control form-control-sm" min="1" />
                    </div>
                </div>
            </div>

            <!-- الصور -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header">
                    <h6 class="mb-0"><i class="fas fa-camera me-2 text-info"></i>الصور</h6>
                </div>
                <div class="card-body">
                    @if (isEdit && Model.Photos.Any())
                    {
                    <div class="row g-1 mb-2">
                        @foreach (var photo in Model.Photos)
                        {
                        <div class="col-4 position-relative">
                            <img src="@photo.FilePath" class="img-fluid rounded" style="height:70px;object-fit:cover;width:100%;" />
                            <span class="badge bg-dark position-absolute top-0 start-0" style="font-size:9px;">@photo.PhotoType</span>
                            <form asp-action="DeletePhoto" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="photoId" value="@photo.Id" />
                                <input type="hidden" name="maintenanceId" value="@Model.Id" />
                                <button type="submit" class="btn btn-danger btn-sm position-absolute top-0 end-0 p-0"
                                        style="width:18px;height:18px;font-size:10px;line-height:1;">×</button>
                            </form>
                        </div>
                        }
                    </div>
                    }
                    @if (isEdit)
                    {
                    <div class="mb-2">
                        <label class="form-label small fw-bold">نوع الصورة الجديدة</label>
                        <select name="PhotoType" class="form-select form-select-sm">
                            @foreach (var pt in ViewBag.PhotoTypes as List<string>)
                            {<option value="@pt">@pt</option>}
                        </select>
                    </div>
                    }
                    <label class="form-label small fw-bold">@(isEdit ? "إضافة صور" : "صور الصيانة")</label>
                    <input type="file" name="@(isEdit?"NewPhotos":"Photos")" class="form-control form-control-sm"
                           multiple accept="image/*" />
                    <small class="text-muted">JPG, PNG. يمكن رفع عدة صور.</small>
                </div>
            </div>

            <!-- الملاحظات -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header">
                    <h6 class="mb-0"><i class="fas fa-sticky-note me-2"></i>ملاحظات</h6>
                </div>
                <div class="card-body">
                    <textarea asp-for="Notes" class="form-control form-control-sm" rows="3"
                              placeholder="أي ملاحظات إضافية..."></textarea>
                </div>
            </div>

        </div>
    </div>

    <!-- أزرار الحفظ -->
    <div class="d-flex gap-2 justify-content-end mt-3">
        <a href="@Url.Action("Index")" class="btn btn-outline-secondary">إلغاء</a>
        <button type="submit" class="btn btn-warning px-4">
            <i class="fas fa-save me-2"></i>@(isEdit ? "حفظ التعديلات" : "إضافة السجل")
        </button>
    </div>

</form>

@section Scripts {
<script>
function toggleRecurring(val) {
    document.getElementById('recurrenceDiv').style.display = val ? 'block' : 'none';
    document.getElementById('nextDateDiv').style.display   = val ? 'block' : 'none';
}
function toggleWarranty(val) {
    document.getElementById('warrantyDiv').style.display = val ? 'block' : 'none';
}
</script>
}
