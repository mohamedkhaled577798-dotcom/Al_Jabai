@model IEnumerable<WaqfGIS.Core.Entities.Road>
@{ ViewData["Title"] = "إدارة الطرق"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4><i class="fas fa-road text-secondary me-2"></i>إدارة الطرق</h4>
    <div>
        <a asp-action="Map" class="btn btn-info me-2"><i class="fas fa-map me-1"></i>خريطة</a>
        <a asp-action="Create" class="btn btn-success"><i class="fas fa-plus me-1"></i>إضافة طريق</a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show"><i class="fas fa-check me-2"></i>@TempData["Success"]<button class="btn-close" data-bs-dismiss="alert"></button></div>
}

<div class="card mb-4">
    <div class="card-header bg-light"><h6 class="mb-0"><i class="fas fa-filter me-2"></i>البحث والتصفية</h6></div>
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-3">
                <input type="text" name="search" class="form-control" placeholder="بحث..." value="@ViewBag.CurrentSearch">
            </div>
            <div class="col-md-3">
                <select name="provinceId" class="form-select" asp-items="@ViewBag.Provinces"><option value="">كل المحافظات</option></select>
            </div>
            <div class="col-md-3">
                <select name="roadType" class="form-select" asp-items="@ViewBag.RoadTypes"><option value="">كل الأنواع</option></select>
            </div>
            <div class="col-md-3">
                <button class="btn btn-primary w-100"><i class="fas fa-search me-1"></i>بحث</button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>الكود</th>
                        <th>الاسم</th>
                        <th>المحافظة</th>
                        <th>النوع</th>
                        <th>الطول</th>
                        <th>العرض</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var road in Model)
                    {
                        var typeClass = road.RoadType switch { "Highway" => "bg-danger", "Main" => "bg-warning", "Secondary" => "bg-info", _ => "bg-secondary" };
                        <tr>
                            <td><code>@road.Code</code></td>
                            <td><strong>@road.NameAr</strong></td>
                            <td>@(road.Province?.NameAr ?? "-")</td>
                            <td><span class="badge @typeClass">@road.RoadType</span></td>
                            <td>@(road.LengthMeters?.ToString("N0") ?? "-") م</td>
                            <td>@(road.WidthMeters?.ToString("N1") ?? "-") م</td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Details" asp-route-id="@road.Id" class="btn btn-outline-info"><i class="fas fa-eye"></i></a>
                                    <a asp-action="Edit" asp-route-id="@road.Id" class="btn btn-outline-warning"><i class="fas fa-edit"></i></a>
                                    <a asp-action="Delete" asp-route-id="@road.Id" class="btn btn-outline-danger"><i class="fas fa-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer text-muted">إجمالي: @Model.Count() طريق</div>
</div>
