<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - نظام الحصر الجغرافي لبنايات الوقف السني</title>
    
    <!-- Bootstrap RTL -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
    <!-- Leaflet CSS -->
    <link href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" rel="stylesheet">
    <!-- Custom CSS -->
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="d-flex" id="wrapper">
            <!-- Sidebar -->
            <div class="sidebar bg-dark text-white" id="sidebar">
                <div class="sidebar-header p-3 border-bottom border-secondary">
                    <h5 class="mb-0">
                        <i class="fas fa-mosque me-2"></i>
                        نظام الأوقاف GIS
                    </h5>
                </div>
                <nav class="nav flex-column p-3">
                    <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active bg-primary rounded" : "")" 
                       asp-controller="Home" asp-action="Index">
                        <i class="fas fa-tachometer-alt me-2"></i> لوحة التحكم
                    </a>
                    <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Map" ? "active bg-primary rounded" : "")" 
                       asp-controller="Map" asp-action="Index">
                        <i class="fas fa-map-marked-alt me-2"></i> الخريطة التفاعلية
                    </a>
                    <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Mosques" ? "active bg-primary rounded" : "")" 
                       asp-controller="Mosques" asp-action="Index">
                        <i class="fas fa-mosque me-2"></i> المساجد والجوامع
                    </a>
                    <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Properties" ? "active bg-primary rounded" : "")" 
                       asp-controller="Properties" asp-action="Index">
                        <i class="fas fa-building me-2"></i> العقارات الوقفية
                    </a>
                    <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Offices" ? "active bg-primary rounded" : "")" 
                       asp-controller="Offices" asp-action="Index">
                        <i class="fas fa-landmark me-2"></i> الدوائر الوقفية
                    </a>
                    <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reports" ? "active bg-primary rounded" : "")" 
                       asp-controller="Reports" asp-action="Index">
                        <i class="fas fa-chart-bar me-2"></i> التقارير
                    </a>
                    <hr class="border-secondary">
                    <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Users" ? "active bg-primary rounded" : "")" 
                       asp-controller="Users" asp-action="Index">
                        <i class="fas fa-users-cog me-2"></i> إدارة المستخدمين
                    </a>
                </nav>
            </div>

            <!-- Page Content -->
            <div class="flex-grow-1" id="page-content">
                <!-- Top Navbar -->
                <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm">
                    <div class="container-fluid">
                        <button class="btn btn-link" id="sidebarToggle">
                            <i class="fas fa-bars"></i>
                        </button>
                        <span class="navbar-text fw-bold text-primary">
                            @ViewData["Title"]
                        </span>
                        <ul class="navbar-nav ms-auto">
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="userDropdown" 
                                   role="button" data-bs-toggle="dropdown">
                                    <i class="fas fa-user-circle me-1"></i>
                                    @User.Identity?.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-start">
                                    <li><a class="dropdown-item" href="#"><i class="fas fa-user me-2"></i>الملف الشخصي</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post">
                                            <button type="submit" class="dropdown-item text-danger">
                                                <i class="fas fa-sign-out-alt me-2"></i>تسجيل الخروج
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        </ul>
                    </div>
                </nav>

                <!-- Main Content -->
                <main class="p-4">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }
                    @RenderBody()
                </main>
            </div>
        </div>
    }
    else
    {
        @RenderBody()
    }

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
