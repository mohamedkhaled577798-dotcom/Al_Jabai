@model Dictionary<string, List<WaqfGIS.Core.Entities.InvestmentContract>>

@{
    ViewData["Title"] = "تنبيهات العقود";
    var sixMonths = Model.ContainsKey("SixMonths") ? Model["SixMonths"] : new List<WaqfGIS.Core.Entities.InvestmentContract>();
    var threeMonths = Model.ContainsKey("ThreeMonths") ? Model["ThreeMonths"] : new List<WaqfGIS.Core.Entities.InvestmentContract>();
    var oneMonth = Model.ContainsKey("OneMonth") ? Model["OneMonth"] : new List<WaqfGIS.Core.Entities.InvestmentContract>();
    var expired = Model.ContainsKey("Expired") ? Model["Expired"] : new List<WaqfGIS.Core.Entities.InvestmentContract>();
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-bell"></i> تنبيهات العقود</h2>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="fas fa-arrow-right"></i> رجوع
        </a>
    </div>

    <!-- Summary Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-danger">
                <div class="card-body text-center">
                    <h3 class="text-danger">@expired.Count</h3>
                    <p class="mb-0">عقود منتهية</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-warning">
                <div class="card-body text-center">
                    <h3 class="text-warning">@oneMonth.Count</h3>
                    <p class="mb-0">تنتهي خلال شهر</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-info">
                <div class="card-body text-center">
                    <h3 class="text-info">@threeMonths.Count</h3>
                    <p class="mb-0">تنتهي خلال 3 أشهر</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-success">
                <div class="card-body text-center">
                    <h3 class="text-success">@sixMonths.Count</h3>
                    <p class="mb-0">تنتهي خلال 6 أشهر</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Expired Contracts -->
    @if (expired.Any())
    {
        <div class="card border-danger mb-4">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0">
                    <i class="fas fa-exclamation-circle"></i> عقود منتهية (@expired.Count)
                </h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>رقم العقد</th>
                                <th>المستثمر</th>
                                <th>الكيان</th>
                                <th>تاريخ الانتهاء</th>
                                <th>منذ</th>
                                <th>الإجراءات</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var contract in expired.OrderBy(c => c.EndDate))
                            {
                                var daysAgo = Math.Abs((contract.EndDate - DateTime.Now).Days);
                                <tr>
                                    <td><strong>@contract.ContractNumber</strong></td>
                                    <td>@contract.InvestorName</td>
                                    <td>@contract.EntityName</td>
                                    <td>@contract.EndDate.ToString("yyyy/MM/dd")</td>
                                    <td><span class="badge bg-danger">@daysAgo يوم</span></td>
                                    <td>
                                        <a asp-action="Details" asp-route-id="@contract.Id" class="btn btn-sm btn-info">
                                            <i class="fas fa-eye"></i> عرض
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    <!-- One Month -->
    @if (oneMonth.Any())
    {
        <div class="card border-warning mb-4">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0">
                    <i class="fas fa-clock"></i> تنتهي خلال شهر (@oneMonth.Count)
                </h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>رقم العقد</th>
                                <th>المستثمر</th>
                                <th>الكيان</th>
                                <th>تاريخ الانتهاء</th>
                                <th>متبقي</th>
                                <th>الإجراءات</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var contract in oneMonth.OrderBy(c => c.EndDate))
                            {
                                var daysLeft = (contract.EndDate - DateTime.Now).Days;
                                <tr>
                                    <td><strong>@contract.ContractNumber</strong></td>
                                    <td>@contract.InvestorName</td>
                                    <td>@contract.EntityName</td>
                                    <td>@contract.EndDate.ToString("yyyy/MM/dd")</td>
                                    <td><span class="badge bg-warning">@daysLeft يوم</span></td>
                                    <td>
                                        <a asp-action="Details" asp-route-id="@contract.Id" class="btn btn-sm btn-info">
                                            <i class="fas fa-eye"></i> عرض
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    <!-- Three Months -->
    @if (threeMonths.Any())
    {
        <div class="card border-info mb-4">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0">
                    <i class="fas fa-calendar-check"></i> تنتهي خلال 3 أشهر (@threeMonths.Count)
                </h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>رقم العقد</th>
                                <th>المستثمر</th>
                                <th>الكيان</th>
                                <th>تاريخ الانتهاء</th>
                                <th>متبقي</th>
                                <th>الإجراءات</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var contract in threeMonths.OrderBy(c => c.EndDate))
                            {
                                var daysLeft = (contract.EndDate - DateTime.Now).Days;
                                <tr>
                                    <td><strong>@contract.ContractNumber</strong></td>
                                    <td>@contract.InvestorName</td>
                                    <td>@contract.EntityName</td>
                                    <td>@contract.EndDate.ToString("yyyy/MM/dd")</td>
                                    <td><span class="badge bg-info">@daysLeft يوم</span></td>
                                    <td>
                                        <a asp-action="Details" asp-route-id="@contract.Id" class="btn btn-sm btn-info">
                                            <i class="fas fa-eye"></i> عرض
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    @if (!expired.Any() && !oneMonth.Any() && !threeMonths.Any())
    {
        <div class="card">
            <div class="card-body text-center py-5">
                <i class="fas fa-check-circle fa-4x text-success mb-3"></i>
                <h4>لا توجد تنبيهات</h4>
                <p class="text-muted">جميع العقود في حالة جيدة</p>
            </div>
        </div>
    }
</div>
