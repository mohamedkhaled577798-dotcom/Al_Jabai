@model WaqfGIS.Web.Models.WaqfLandViewModel
@{
    ViewData["Title"] = "إضافة أرض وقف جديدة";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0"><i class="fas fa-plus-circle text-success me-2"></i>إضافة أرض وقف جديدة</h4>
        <small class="text-muted">أدخل بيانات الأرض وارسم الحدود على الخريطة</small>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-right me-1"></i>العودة للقائمة
    </a>
</div>

<form asp-action="Create" method="post" id="landForm">
    <div class="row">
        <!-- Form Section -->
        <div class="col-lg-5">
            <!-- Basic Info -->
            <div class="card mb-3">
                <div class="card-header bg-success text-white">
                    <h6 class="mb-0"><i class="fas fa-info-circle me-2"></i>البيانات الأساسية</h6>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="NameAr" class="form-label"></label>
                        <input asp-for="NameAr" class="form-control" placeholder="أدخل اسم الأرض">
                        <span asp-validation-for="NameAr" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="NameEn" class="form-label"></label>
                        <input asp-for="NameEn" class="form-control" placeholder="Enter land name">
                    </div>
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                    </div>
                </div>
            </div>

            <!-- Location -->
            <div class="card mb-3">
                <div class="card-header bg-info text-white">
                    <h6 class="mb-0"><i class="fas fa-map-marker-alt me-2"></i>الموقع</h6>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="ProvinceId" class="form-label"></label>
                            <select asp-for="ProvinceId" asp-items="Model.Provinces" class="form-select">
                                <option value="">-- اختر المحافظة --</option>
                            </select>
                            <span asp-validation-for="ProvinceId" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DistrictId" class="form-label"></label>
                            <select asp-for="DistrictId" asp-items="Model.Districts" class="form-select">
                                <option value="">-- اختر القضاء --</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="WaqfOfficeId" class="form-label"></label>
                            <select asp-for="WaqfOfficeId" asp-items="Model.WaqfOffices" class="form-select">
                                <option value="">-- اختر الدائرة --</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Neighborhood" class="form-label"></label>
                            <input asp-for="Neighborhood" class="form-control">
                        </div>
                        <div class="col-12">
                            <label asp-for="Address" class="form-label"></label>
                            <input asp-for="Address" class="form-control">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Classification -->
            <div class="card mb-3">
                <div class="card-header bg-warning">
                    <h6 class="mb-0"><i class="fas fa-tags me-2"></i>التصنيف</h6>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="LandType" class="form-label"></label>
                            <select asp-for="LandType" asp-items="WaqfGIS.Web.Models.WaqfLandViewModel.LandTypes" class="form-select"></select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LandUse" class="form-label"></label>
                            <select asp-for="LandUse" asp-items="WaqfGIS.Web.Models.WaqfLandViewModel.LandUses" class="form-select"></select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ZoningCode" class="form-label"></label>
                            <input asp-for="ZoningCode" class="form-control">
                        </div>
                        <div class="col-md-6">
                            <label asp-for="OwnershipStatus" class="form-label"></label>
                            <select asp-for="OwnershipStatus" asp-items="WaqfGIS.Web.Models.WaqfLandViewModel.OwnershipStatuses" class="form-select">
                                <option value="">-- اختر --</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Legal & Financial -->
            <div class="card mb-3">
                <div class="card-header bg-secondary text-white">
                    <h6 class="mb-0"><i class="fas fa-file-contract me-2"></i>البيانات القانونية والمالية</h6>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="DeedNumber" class="form-label"></label>
                            <input asp-for="DeedNumber" class="form-control">
                        </div>
                        <div class="col-md-6">
                            <label asp-for="RegistrationNumber" class="form-label"></label>
                            <input asp-for="RegistrationNumber" class="form-control">
                        </div>
                        <div class="col-md-6">
                            <label asp-for="RegistrationDate" class="form-label"></label>
                            <input asp-for="RegistrationDate" type="date" class="form-control">
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LegalAreaSqm" class="form-label"></label>
                            <div class="input-group">
                                <input asp-for="LegalAreaSqm" class="form-control" type="number" step="0.01">
                                <span class="input-group-text">م²</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EstimatedValue" class="form-label"></label>
                            <div class="input-group">
                                <input asp-for="EstimatedValue" class="form-control" type="number">
                                <span class="input-group-text">د.ع</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="AnnualRevenue" class="form-label"></label>
                            <div class="input-group">
                                <input asp-for="AnnualRevenue" class="form-control" type="number">
                                <span class="input-group-text">د.ع</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Notes -->
            <div class="card mb-3">
                <div class="card-body">
                    <label asp-for="Notes" class="form-label"></label>
                    <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                </div>
            </div>
        </div>

        <!-- Map Section -->
        <div class="col-lg-7">
            <div class="card sticky-top" style="top: 20px;">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h6 class="mb-0"><i class="fas fa-draw-polygon me-2"></i>رسم حدود الأرض</h6>
                    <div>
                        <button type="button" class="btn btn-sm btn-light me-1" onclick="enableDraw()">
                            <i class="fas fa-pencil-alt"></i> رسم
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-light" onclick="clearDrawing()">
                            <i class="fas fa-eraser"></i> مسح
                        </button>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div id="map" style="height: 400px;"></div>
                </div>
                <div class="card-footer">
                    <div class="row text-center">
                        <div class="col-4">
                            <small class="text-muted">المساحة</small>
                            <h5 class="mb-0 text-primary" id="displayArea">--</h5>
                            <small>م²</small>
                        </div>
                        <div class="col-4">
                            <small class="text-muted">المساحة بالدونم</small>
                            <h5 class="mb-0 text-success" id="displayDonum">--</h5>
                            <small>دونم</small>
                        </div>
                        <div class="col-4">
                            <small class="text-muted">المحيط</small>
                            <h5 class="mb-0 text-info" id="displayPerimeter">--</h5>
                            <small>م</small>
                        </div>
                    </div>
                </div>
            </div>

            <input type="hidden" asp-for="BoundaryGeoJson" id="BoundaryGeoJson" />
            <input type="hidden" asp-for="CenterLatitude" id="CenterLatitude" />
            <input type="hidden" asp-for="CenterLongitude" id="CenterLongitude" />

            <!-- تحديد مركز الخريطة يدوياً -->
            <div class="card mt-3 border-info">
                <div class="card-header bg-info bg-opacity-10 py-2">
                    <h6 class="mb-0 text-info"><i class="fas fa-crosshairs me-2"></i>تحديد مركز الخريطة / استخراج من رابط</h6>
                </div>
                <div class="card-body py-2">
                    <div class="mb-2">
                        <label class="form-label small fw-bold"><i class="fab fa-google me-1"></i>استخراج من رابط خرائط Google أو Apple Maps</label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text"><i class="fas fa-link"></i></span>
                            <input type="text" id="mapsLink_land_create" class="form-control"
                                   placeholder="الصق رابط خرائط هنا..."
                                   oninput="extractLandCoords()" />
                            <button type="button" class="btn btn-outline-success" onclick="extractLandCoords()">
                                <i class="fas fa-magic me-1"></i>استخراج
                            </button>
                            <button type="button" class="btn btn-outline-secondary" onclick="clearLandLink()"><i class="fas fa-times"></i></button>
                        </div>
                        <div id="linkResult_land_create" class="mt-1" style="display:none;"></div>
                    </div>
                    <div class="row g-2">
                        <div class="col-5">
                            <label class="form-label small"><i class="fas fa-arrows-alt-v text-danger me-1"></i>خط العرض</label>
                            <div class="input-group input-group-sm">
                                <input type="text" id="manualLat" class="form-control" placeholder="33.315000" />
                                <span class="input-group-text">°N</span>
                            </div>
                        </div>
                        <div class="col-5">
                            <label class="form-label small"><i class="fas fa-arrows-alt-h text-primary me-1"></i>خط الطول</label>
                            <div class="input-group input-group-sm">
                                <input type="text" id="manualLng" class="form-control" placeholder="44.361000" />
                                <span class="input-group-text">°E</span>
                            </div>
                        </div>
                        <div class="col-2 d-flex align-items-end">
                            <button type="button" class="btn btn-sm btn-primary w-100" onclick="flyToManualLandCoords()" title="الذهاب للموقع">
                                <i class="fas fa-map-pin"></i>
                            </button>
                        </div>
                    </div>
                    <small class="text-muted d-block mt-1"><i class="fas fa-info-circle me-1"></i>هذا لتحديد مركز عرض الخريطة - ارسم الحدود باستخدام أدوات الرسم أعلاه</small>
                </div>
            </div>

            <div class="d-grid gap-2 mt-3">
                <button type="submit" class="btn btn-success btn-lg">
                    <i class="fas fa-save me-2"></i>حفظ أرض الوقف
                </button>
            </div>
        </div>
    </div>
</form>

@section Scripts {
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet.draw/1.0.4/leaflet.draw.css" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet.draw/1.0.4/leaflet.draw.js"></script>
<script src="~/js/coordinates-helper.js"></script>

<script>
var osmLandCreate = L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '© OpenStreetMap' });
var satLandCreate = L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', { attribution: '© Esri' });
var map = L.map('map', { layers: [osmLandCreate] }).setView([@Model.CenterLatitude, @Model.CenterLongitude], 7);
var drawnItems = new L.FeatureGroup();
map.addLayer(drawnItems);

// دوال مساعد الإحداثيات للأراضي

function extractLandCoords() {
    var input = document.getElementById('mapsLink_land_create');
    var resultDiv = document.getElementById('linkResult_land_create');
    var url = input.value.trim();
    if (!url) { resultDiv.style.display = 'none'; return; }
    var result = parseMapLink(url);
    if (result) {
        document.getElementById('manualLat').value = result.lat.toFixed(6);
        document.getElementById('manualLng').value = result.lng.toFixed(6);
        map.flyTo([result.lat, result.lng], 16, {duration: 0.8});
        resultDiv.style.display = 'block';
        resultDiv.innerHTML = `<div class="alert alert-success p-2 mb-0 small">✅ تم استخراج الإحداثيات: ${result.lat.toFixed(6)}, ${result.lng.toFixed(6)}</div>`;
    } else if (url.length > 10) {
        resultDiv.style.display = 'block';
        resultDiv.innerHTML = '<div class="alert alert-warning p-2 mb-0 small">⚠️ تعذّر استخراج الإحداثيات</div>';
    }
}

function clearLandLink() {
    document.getElementById('mapsLink_land_create').value = '';
    document.getElementById('linkResult_land_create').style.display = 'none';
}

function flyToManualLandCoords() {
    var lat = parseFloat(document.getElementById('manualLat').value);
    var lng = parseFloat(document.getElementById('manualLng').value);
    if (!isNaN(lat) && !isNaN(lng) && lat !== 0) {
        map.flyTo([lat, lng], 16, {duration: 0.8});
    } else {
        alert('يرجى إدخال إحداثيات صحيحة');
    }
}

var drawControl = new L.Control.Draw({
    position: 'topright',
    draw: {
        polygon: {
            allowIntersection: false,
            showArea: true,
            shapeOptions: {
                color: '#ff9800',
                fillColor: '#ff9800',
                fillOpacity: 0.3
            }
        },
        polyline: false,
        circle: false,
        circlemarker: false,
        marker: false,
        rectangle: false
    },
    edit: {
        featureGroup: drawnItems,
        remove: true
    }
});
map.addControl(drawControl);

map.on(L.Draw.Event.CREATED, function(e) {
    drawnItems.clearLayers();
    drawnItems.addLayer(e.layer);
    updateGeometry(e.layer);
});

map.on(L.Draw.Event.EDITED, function(e) {
    e.layers.eachLayer(function(layer) {
        updateGeometry(layer);
    });
});

map.on(L.Draw.Event.DELETED, function() {
    document.getElementById('BoundaryGeoJson').value = '';
    document.getElementById('displayArea').textContent = '--';
    document.getElementById('displayDonum').textContent = '--';
    document.getElementById('displayPerimeter').textContent = '--';
});

function updateGeometry(layer) {
    var geoJson = layer.toGeoJSON();
    document.getElementById('BoundaryGeoJson').value = JSON.stringify(geoJson.geometry);
    
    // Calculate area
    var area = L.GeometryUtil.geodesicArea(layer.getLatLngs()[0]);
    var donum = area / 2500;
    
    // Calculate perimeter
    var perimeter = 0;
    var latlngs = layer.getLatLngs()[0];
    for (var i = 0; i < latlngs.length - 1; i++) {
        perimeter += latlngs[i].distanceTo(latlngs[i + 1]);
    }
    perimeter += latlngs[latlngs.length - 1].distanceTo(latlngs[0]);
    
    // Update center
    var center = layer.getBounds().getCenter();
    document.getElementById('CenterLatitude').value = center.lat;
    document.getElementById('CenterLongitude').value = center.lng;
    
    // Display
    document.getElementById('displayArea').textContent = area.toFixed(2);
    document.getElementById('displayDonum').textContent = donum.toFixed(2);
    document.getElementById('displayPerimeter').textContent = perimeter.toFixed(2);
}

function enableDraw() {
    new L.Draw.Polygon(map, drawControl.options.draw.polygon).enable();
}

function clearDrawing() {
    drawnItems.clearLayers();
    document.getElementById('BoundaryGeoJson').value = '';
    document.getElementById('displayArea').textContent = '--';
    document.getElementById('displayDonum').textContent = '--';
    document.getElementById('displayPerimeter').textContent = '--';
}

// Form validation
document.getElementById('landForm').addEventListener('submit', function(e) {
    var boundary = document.getElementById('BoundaryGeoJson').value;
    if (!boundary) {
        if (!confirm('لم ترسم حدود الأرض. هل تريد المتابعة بدون حدود؟')) {
            e.preventDefault();
        }
    }
});
</script>
}
