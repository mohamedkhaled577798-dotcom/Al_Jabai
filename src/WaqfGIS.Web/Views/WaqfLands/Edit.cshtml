@model WaqfGIS.Web.Models.WaqfLandViewModel
@using WaqfGIS.Core.Entities
@{
    ViewData["Title"] = "تعديل أرض الوقف";
    var regFiles = ViewBag.RegistrationFiles as IEnumerable<WaqfLandRegistrationFile> ?? new List<WaqfLandRegistrationFile>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0"><i class="fas fa-edit text-warning me-2"></i>تعديل أرض الوقف</h4>
        <small class="text-muted">@Model.Code - @Model.NameAr</small>
    </div>
    <div>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-primary me-2">
            <i class="fas fa-eye me-1"></i>التفاصيل
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-right me-1"></i>العودة للقائمة
        </a>
    </div>
</div>

<form asp-action="Edit" method="post" id="landForm" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="Code" />
    
    <div class="row">
        <!-- Form Section -->
        <div class="col-lg-5">
            <!-- Basic Info -->
            <div class="card mb-3">
                <div class="card-header bg-success text-white">
                    <h6 class="mb-0"><i class="fas fa-info-circle me-2"></i>البيانات الأساسية</h6>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">الكود</label>
                        <input type="text" class="form-control" value="@Model.Code" readonly disabled>
                    </div>
                    <div class="mb-3">
                        <label asp-for="NameAr" class="form-label"></label>
                        <input asp-for="NameAr" class="form-control">
                        <span asp-validation-for="NameAr" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="NameEn" class="form-label"></label>
                        <input asp-for="NameEn" class="form-control">
                    </div>
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                    </div>
                </div>
            </div>

            <!-- Location -->
            <div class="card mb-3">
                <div class="card-header bg-info text-white">
                    <h6 class="mb-0"><i class="fas fa-map-marker-alt me-2"></i>الموقع</h6>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="ProvinceId" class="form-label"></label>
                            <select asp-for="ProvinceId" asp-items="Model.Provinces" class="form-select">
                                <option value="">-- اختر المحافظة --</option>
                            </select>
                            <span asp-validation-for="ProvinceId" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DistrictId" class="form-label"></label>
                            <select asp-for="DistrictId" asp-items="Model.Districts" class="form-select">
                                <option value="">-- اختر القضاء --</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="WaqfOfficeId" class="form-label"></label>
                            <select asp-for="WaqfOfficeId" asp-items="Model.WaqfOffices" class="form-select">
                                <option value="">-- اختر الدائرة --</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Neighborhood" class="form-label"></label>
                            <input asp-for="Neighborhood" class="form-control">
                        </div>
                        <div class="col-12">
                            <label asp-for="Address" class="form-label"></label>
                            <input asp-for="Address" class="form-control">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Classification -->
            <div class="card mb-3">
                <div class="card-header bg-warning">
                    <h6 class="mb-0"><i class="fas fa-tags me-2"></i>التصنيف</h6>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="LandType" class="form-label"></label>
                            <select asp-for="LandType" asp-items="WaqfGIS.Web.Models.WaqfLandViewModel.LandTypes" class="form-select"></select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LandUse" class="form-label"></label>
                            <select asp-for="LandUse" asp-items="WaqfGIS.Web.Models.WaqfLandViewModel.LandUses" class="form-select"></select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ZoningCode" class="form-label"></label>
                            <input asp-for="ZoningCode" class="form-control">
                        </div>
                        <div class="col-md-6">
                            <label asp-for="OwnershipStatus" class="form-label"></label>
                            <select asp-for="OwnershipStatus" asp-items="WaqfGIS.Web.Models.WaqfLandViewModel.OwnershipStatuses" class="form-select">
                                <option value="">-- اختر --</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Legal & Financial -->
            <div class="card mb-3">
                <div class="card-header bg-secondary text-white">
                    <h6 class="mb-0"><i class="fas fa-file-contract me-2"></i>البيانات القانونية والمالية</h6>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="DeedNumber" class="form-label"></label>
                            <input asp-for="DeedNumber" class="form-control">
                        </div>
                        <div class="col-md-6">
                            <label asp-for="RegistrationNumber" class="form-label"></label>
                            <input asp-for="RegistrationNumber" class="form-control">
                        </div>
                        <div class="col-md-6">
                            <label asp-for="RegistrationDate" class="form-label"></label>
                            <input asp-for="RegistrationDate" type="date" class="form-control">
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LegalAreaSqm" class="form-label"></label>
                            <div class="input-group">
                                <input asp-for="LegalAreaSqm" class="form-control" type="number" step="0.01">
                                <span class="input-group-text">م²</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EstimatedValue" class="form-label"></label>
                            <div class="input-group">
                                <input asp-for="EstimatedValue" class="form-control" type="number">
                                <span class="input-group-text">د.ع</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="AnnualRevenue" class="form-label"></label>
                            <div class="input-group">
                                <input asp-for="AnnualRevenue" class="form-control" type="number">
                                <span class="input-group-text">د.ع</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Notes -->
            <div class="card mb-3">
                <div class="card-body">
                    <label asp-for="Notes" class="form-label"></label>
                    <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                </div>
            </div>

            <!-- أهلية الوقف وتجاوزات -->
            <div class="card mb-3">
                <div class="card-header" style="background:#6f42c1;color:#fff"><h6 class="mb-0"><i class="fas fa-clipboard-check me-2"></i>أهلية الوقف ومعلومات خاصة</h6></div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="WaqfNature" class="form-label fw-bold">طبيعة الوقف</label>
                            <select asp-for="WaqfNature" class="form-select" id="waqfNatureSelect" onchange="toggleAdminReceived()">
                                <option value="Khairi">خيري</option>
                                <option value="Ahli">أهلي</option>
                            </select>
                        </div>
                        <div class="col-md-4" id="adminReceivedGroup" style="display:@(Model.WaqfNature=="Ahli"?"block":"none")">
                            <label class="form-label fw-bold">مستلمة إدارياً</label>
                            <div class="d-flex gap-3 mt-2">
                                <div class="form-check"><input class="form-check-input" type="radio" name="IsAdminReceived" value="true" @(Model.IsAdminReceived==true?"checked":"") /><label class="form-check-label">نعم</label></div>
                                <div class="form-check"><input class="form-check-input" type="radio" name="IsAdminReceived" value="false" @(Model.IsAdminReceived==false?"checked":"") /><label class="form-check-label">لا</label></div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="WaqfCondition" class="form-label fw-bold">شرط الوقف</label>
                            <select asp-for="WaqfCondition" class="form-select" id="waqfConditionSelect" onchange="toggleConditionText()">
                                <option value="WithoutCondition">بدون شرط</option>
                                <option value="WithCondition">بشرط</option>
                            </select>
                        </div>
                    </div>
                    <!-- بيانات الواقف الأصلي -->
                    <hr class="my-2" />
                    <h6 class="text-muted mb-2"><i class="fas fa-user-shield me-2"></i>بيانات الواقف الأصلي</h6>
                    <div class="row g-2">
                        <div class="col-md-6">
                            <label asp-for="WaqifName" class="form-label small">اسم الواقف</label>
                            <input asp-for="WaqifName" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="WaqfDocumentDate" class="form-label small">تاريخ الوثيقة</label>
                            <input asp-for="WaqfDocumentDate" class="form-control form-control-sm" type="date" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="WaqfDocumentNumber" class="form-label small">رقم الوثيقة</label>
                            <input asp-for="WaqfDocumentNumber" class="form-control form-control-sm" />
                        </div>
                        <div class="col-12" id="waqfConditionTextGroup" style="display:@(Model.WaqfCondition=="WithCondition"?"block":"none")">
                            <label asp-for="WaqfConditionText" class="form-label small fw-bold text-primary">نص شرط الواقف</label>
                            <textarea asp-for="WaqfConditionText" class="form-control form-control-sm" rows="3"></textarea>
                        </div>
                    </div>
                    <hr class="my-3" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" asp-for="HasEncroachment" id="hasEncr" />
                                <label class="form-check-label text-danger fw-bold" for="hasEncr"><i class="fas fa-exclamation-circle me-1"></i>يوجد تجاوز على الأرض</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <label asp-for="EncroachmentNotes" class="form-label">ملاحظات التجاوز</label>
                            <textarea asp-for="EncroachmentNotes" class="form-control" rows="2"></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <!-- مستندات وملفات التسجيل -->
            <div class="card mb-3">
                <div class="card-header bg-warning text-dark"><h6 class="mb-0"><i class="fas fa-file-alt me-2"></i>مستندات وملفات التسجيل</h6></div>
                <div class="card-body">
                    @if (regFiles.Any())
                    {
                        <div class="table-responsive mb-3">
                            <table class="table table-sm table-bordered">
                                <thead class="table-light"><tr><th>نوع المستند</th><th>اسم الملف</th><th>تاريخ الرفع</th><th></th></tr></thead>
                                <tbody>
                                    @foreach (var rf in regFiles)
                                    {
                                        <tr>
                                            <td><span class="badge bg-secondary">@rf.DocumentType</span></td>
                                            <td><a href="@rf.FilePath" target="_blank">@rf.FileName</a></td>
                                            <td><small>@rf.UploadedAt.ToLocalTime().ToString("dd/MM/yyyy")</small></td>
                                            <td>
                                                <form asp-action="DeleteRegistrationFile" method="post" class="d-inline" onsubmit="return confirm('حذف الملف؟')">
                                                    <input type="hidden" name="fileId" value="@rf.Id" />
                                                    <input type="hidden" name="landId" value="@Model.Id" />
                                                    <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    <div class="row g-3">
                        <div class="col-md-5">
                            <label class="form-label">نوع المستند</label>
                            <select name="regDocType" class="form-select">
                                <option value="سند ملكية">سند ملكية</option>
                                <option value="قرار تخصيص">قرار تخصيص</option>
                                <option value="عقد إيجار">عقد إيجار</option>
                                <option value="وثيقة وقف">وثيقة وقف</option>
                                <option value="أخرى">أخرى</option>
                            </select>
                        </div>
                        <div class="col-md-7">
                            <label class="form-label">إضافة ملف جديد</label>
                            <input type="file" name="regFiles" class="form-control" multiple accept=".pdf,.doc,.docx,.jpg,.jpeg,.png,.xlsx" />
                            <small class="text-muted">يقبل PDF, Word, صور, Excel</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Map Section -->
        <div class="col-lg-7">
            <div class="card sticky-top" style="top: 20px;">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h6 class="mb-0"><i class="fas fa-draw-polygon me-2"></i>تعديل حدود الأرض</h6>
                    <div>
                        <button type="button" class="btn btn-sm btn-light me-1" onclick="enableDraw()">
                            <i class="fas fa-pencil-alt"></i> رسم جديد
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-light" onclick="clearDrawing()">
                            <i class="fas fa-eraser"></i> مسح
                        </button>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div id="map" style="height: 400px;"></div>
                </div>
                <div class="card-footer">
                    <div class="row text-center">
                        <div class="col-4">
                            <small class="text-muted">المساحة</small>
                            <h5 class="mb-0 text-primary" id="displayArea">@(Model.CalculatedAreaSqm?.ToString("N2") ?? "--")</h5>
                            <small>م²</small>
                        </div>
                        <div class="col-4">
                            <small class="text-muted">المساحة بالدونم</small>
                            <h5 class="mb-0 text-success" id="displayDonum">@(Model.AreaDonum?.ToString("N2") ?? "--")</h5>
                            <small>دونم</small>
                        </div>
                        <div class="col-4">
                            <small class="text-muted">المحيط</small>
                            <h5 class="mb-0 text-info" id="displayPerimeter">@(Model.PerimeterMeters?.ToString("N2") ?? "--")</h5>
                            <small>م</small>
                        </div>
                    </div>
                </div>
            </div>

            <input type="hidden" asp-for="BoundaryGeoJson" id="BoundaryGeoJson" />
            <input type="hidden" asp-for="CenterLatitude" id="CenterLatitude" />
            <input type="hidden" asp-for="CenterLongitude" id="CenterLongitude" />

            <!-- تحديد مركز الخريطة يدوياً -->
            <div class="card mt-3 border-warning">
                <div class="card-header bg-warning bg-opacity-20 py-2">
                    <h6 class="mb-0"><i class="fas fa-crosshairs me-2"></i>تحديد مركز الخريطة / استخراج من رابط</h6>
                </div>
                <div class="card-body py-2">
                    <div class="mb-2">
                        <label class="form-label small fw-bold"><i class="fab fa-google me-1"></i>استخراج من رابط خرائط Google أو Apple Maps</label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text"><i class="fas fa-link"></i></span>
                            <input type="text" id="mapsLink_land_edit" class="form-control"
                                   placeholder="الصق رابط خرائط هنا..."
                                   oninput="extractLandEditCoords()" />
                            <button type="button" class="btn btn-outline-success" onclick="extractLandEditCoords()">
                                <i class="fas fa-magic me-1"></i>استخراج
                            </button>
                            <button type="button" class="btn btn-outline-secondary" onclick="clearLandEditLink()"><i class="fas fa-times"></i></button>
                        </div>
                        <div id="linkResult_land_edit" class="mt-1" style="display:none;"></div>
                    </div>
                    <div class="row g-2">
                        <div class="col-5">
                            <label class="form-label small"><i class="fas fa-arrows-alt-v text-danger me-1"></i>خط العرض</label>
                            <div class="input-group input-group-sm">
                                <input type="text" id="manualLatEdit" class="form-control" placeholder="33.315000" />
                                <span class="input-group-text">°N</span>
                            </div>
                        </div>
                        <div class="col-5">
                            <label class="form-label small"><i class="fas fa-arrows-alt-h text-primary me-1"></i>خط الطول</label>
                            <div class="input-group input-group-sm">
                                <input type="text" id="manualLngEdit" class="form-control" placeholder="44.361000" />
                                <span class="input-group-text">°E</span>
                            </div>
                        </div>
                        <div class="col-2 d-flex align-items-end">
                            <button type="button" class="btn btn-sm btn-warning w-100" onclick="flyToManualLandEditCoords()" title="الذهاب للموقع">
                                <i class="fas fa-map-pin"></i>
                            </button>
                        </div>
                    </div>
                    <small class="text-muted d-block mt-1">هذا لتحديد مركز عرض الخريطة - ارسم الحدود باستخدام أدوات الرسم</small>
                </div>
            </div>

            <div class="d-grid gap-2 mt-3">
                <button type="submit" class="btn btn-warning btn-lg">
                    <i class="fas fa-save me-2"></i>حفظ التعديلات
                </button>
            </div>
        </div>
    </div>
</form>

@section Scripts {
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet.draw/1.0.4/leaflet.draw.css" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet.draw/1.0.4/leaflet.draw.js"></script>
<script src="~/js/coordinates-helper.js"></script>

<script>
var centerLat = @(Model.CenterLatitude ?? 33.3);
var centerLng = @(Model.CenterLongitude ?? 44.4);
var existingGeoJson = @Html.Raw(Model.BoundaryGeoJson ?? "null");

var osmLandEdit = L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '© OpenStreetMap' });
var satLandEdit = L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', { attribution: '© Esri' });
var map = L.map('map', { layers: [osmLandEdit] }).setView([centerLat, centerLng], existingGeoJson ? 15 : 7);
var drawnItems = new L.FeatureGroup();
map.addLayer(drawnItems);

// دوال مساعد الإحداثيات لتعديل الأراضي
function extractLandEditCoords() {
    var input = document.getElementById('mapsLink_land_edit');
    var resultDiv = document.getElementById('linkResult_land_edit');
    var url = input.value.trim();
    if (!url) { resultDiv.style.display = 'none'; return; }
    var result = parseMapLink(url);
    if (result) {
        document.getElementById('manualLatEdit').value = result.lat.toFixed(6);
        document.getElementById('manualLngEdit').value = result.lng.toFixed(6);
        map.flyTo([result.lat, result.lng], 16, {duration: 0.8});
        resultDiv.style.display = 'block';
        resultDiv.innerHTML = `<div class="alert alert-success p-2 mb-0 small">✅ تم استخراج الإحداثيات: ${result.lat.toFixed(6)}, ${result.lng.toFixed(6)}</div>`;
    } else if (url.length > 10) {
        resultDiv.style.display = 'block';
        resultDiv.innerHTML = '<div class="alert alert-warning p-2 mb-0 small">⚠️ تعذّر استخراج الإحداثيات</div>';
    }
}

function clearLandEditLink() {
    document.getElementById('mapsLink_land_edit').value = '';
    document.getElementById('linkResult_land_edit').style.display = 'none';
}

function flyToManualLandEditCoords() {
    var lat = parseFloat(document.getElementById('manualLatEdit').value);
    var lng = parseFloat(document.getElementById('manualLngEdit').value);
    if (!isNaN(lat) && !isNaN(lng) && lat !== 0) {
        map.flyTo([lat, lng], 16, {duration: 0.8});
    } else {
        alert('يرجى إدخال إحداثيات صحيحة');
    }
}

// Load existing boundary
if (existingGeoJson) {
    var layer = L.geoJSON(existingGeoJson, {
        style: {
            color: '#ff9800',
            fillColor: '#ff9800',
            fillOpacity: 0.3
        }
    });
    
    layer.eachLayer(function(l) {
        drawnItems.addLayer(l);
    });
    
    map.fitBounds(drawnItems.getBounds());
}

var drawControl = new L.Control.Draw({
    position: 'topright',
    draw: {
        polygon: {
            allowIntersection: false,
            showArea: true,
            shapeOptions: {
                color: '#ff9800',
                fillColor: '#ff9800',
                fillOpacity: 0.3
            }
        },
        polyline: false,
        circle: false,
        circlemarker: false,
        marker: false,
        rectangle: false
    },
    edit: {
        featureGroup: drawnItems,
        remove: true
    }
});
map.addControl(drawControl);

map.on(L.Draw.Event.CREATED, function(e) {
    drawnItems.clearLayers();
    drawnItems.addLayer(e.layer);
    updateGeometry(e.layer);
});

map.on(L.Draw.Event.EDITED, function(e) {
    e.layers.eachLayer(function(layer) {
        updateGeometry(layer);
    });
});

map.on(L.Draw.Event.DELETED, function() {
    document.getElementById('BoundaryGeoJson').value = '';
    document.getElementById('displayArea').textContent = '--';
    document.getElementById('displayDonum').textContent = '--';
    document.getElementById('displayPerimeter').textContent = '--';
});

function updateGeometry(layer) {
    var geoJson = layer.toGeoJSON();
    document.getElementById('BoundaryGeoJson').value = JSON.stringify(geoJson.geometry);
    
    var latlngs = layer.getLatLngs ? layer.getLatLngs()[0] : layer.feature.geometry.coordinates[0].map(c => L.latLng(c[1], c[0]));
    
    if (layer.getLatLngs) {
        var area = L.GeometryUtil.geodesicArea(latlngs);
        var donum = area / 2500;
        
        var perimeter = 0;
        for (var i = 0; i < latlngs.length - 1; i++) {
            perimeter += latlngs[i].distanceTo(latlngs[i + 1]);
        }
        perimeter += latlngs[latlngs.length - 1].distanceTo(latlngs[0]);
        
        var center = layer.getBounds().getCenter();
        document.getElementById('CenterLatitude').value = center.lat;
        document.getElementById('CenterLongitude').value = center.lng;
        
        document.getElementById('displayArea').textContent = area.toFixed(2);
        document.getElementById('displayDonum').textContent = donum.toFixed(2);
        document.getElementById('displayPerimeter').textContent = perimeter.toFixed(2);
    }
}

function enableDraw() {
    new L.Draw.Polygon(map, drawControl.options.draw.polygon).enable();
}

function clearDrawing() {
    drawnItems.clearLayers();
    document.getElementById('BoundaryGeoJson').value = '';
    document.getElementById('displayArea').textContent = '--';
    document.getElementById('displayDonum').textContent = '--';
    document.getElementById('displayPerimeter').textContent = '--';
}

function toggleAdminReceived() {
    var sel = document.getElementById('waqfNatureSelect');
    var grp = document.getElementById('adminReceivedGroup');
    if (sel && grp) grp.style.display = sel.value === 'Ahli' ? 'block' : 'none';
}

function toggleConditionText() {
    var sel = document.getElementById('waqfConditionSelect');
    var grp = document.getElementById('waqfConditionTextGroup');
    if (sel && grp) grp.style.display = sel.value === 'WithCondition' ? 'block' : 'none';
}
</script>
}
