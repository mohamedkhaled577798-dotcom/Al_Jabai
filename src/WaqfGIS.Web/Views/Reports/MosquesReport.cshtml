@model MosquesReportViewModel
@{
    ViewData["Title"] = "تقرير الجوامع";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4><i class="fas fa-mosque text-primary me-2"></i>تقرير المساجد والجوامع</h4>
    <div>
        <a asp-action="ExportMosques" class="btn btn-outline-success"><i class="fas fa-file-excel me-1"></i>تصدير Excel</a>
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-right me-1"></i>رجوع</a>
    </div>
</div>

<!-- ملخص -->
<div class="row g-3 mb-4">
    <div class="col-md-3"><div class="card bg-primary text-white"><div class="card-body text-center"><h3>@Model.TotalMosques</h3><small>إجمالي المساجد</small></div></div></div>
    <div class="col-md-3"><div class="card bg-success text-white"><div class="card-body text-center"><h3>@Model.TotalCapacity.ToString("N0")</h3><small>إجمالي السعة</small></div></div></div>
    <div class="col-md-3"><div class="card bg-info text-white"><div class="card-body text-center"><h3>@Model.WithFridayPrayer</h3><small>بصلاة الجمعة</small></div></div></div>
    <div class="col-md-3"><div class="card bg-warning"><div class="card-body text-center"><h3>@(Model.TotalMosques > 0 ? (Model.TotalCapacity / Model.TotalMosques).ToString("N0") : "0")</h3><small>متوسط السعة</small></div></div></div>
</div>
<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card"><div class="card-header">حسب النوع</div><div class="card-body">
            <ul class="list-group list-group-flush">
                @foreach(var item in Model.ByType)
                {<li class="list-group-item d-flex justify-content-between">@item.Name<span class="badge bg-primary">@item.Count</span></li>}
            </ul>
        </div></div>
    </div>
    <div class=\"col-md-4\">
        <div class=\"card\"><div class=\"card-header\">حسب الحالة</div><div class=\"card-body\">
            <ul class=\"list-group list-group-flush\">
                @foreach(var item in Model.ByStatus)
                {<li class=\"list-group-item d-flex justify-content-between\">@item.Name<span class=\"badge bg-info\">`
}

@item.Count</span></li>}
            </ul>
        </div></div>
    </div>
    <div class="col-md-4">
        <div class="card"><div class="card-header">أكثر 10 محافظات</div><div class="card-body">
            <ul class="list-group list-group-flush">
                @foreach (var item in Model.ByProvince.Take(10))
                {
                    <li class="list-group-item d-flex justify-content-between">
                        @item.Name
                        <span class="badge bg-success">@item.Count</span>
                    </li>
                }
            </ul>
        </div></div>
    </div>
</div>

<!-- جدول البيانات -->
<div class="card">
    <div class="card-header bg-white"><h6 class="mb-0">قائمة المساجد (@Model.Mosques.Count)</h6></div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light">
                    <tr><th>الكود</th><th>الاسم</th><th>النوع</th><th>الحالة</th><th>المحافظة</th><th>السعة</th><th>صلاة الجمعة</th></tr>
                </thead>
                <tbody>
                    @foreach(var m in Model.Mosques)
                    {
                        <tr>
                            <td><code>@m.Code</code></td>
                            <td>@m.NameAr</td>
                            <td><span class="badge bg-primary">@m.MosqueType?.NameAr</span></td>
                            <td><span class="badge" style="background:@(m.MosqueStatus?.ColorCode ?? "#6c757d")">@(m.MosqueStatus?.NameAr ?? "-")</span></td>
                            <td>@m.Province?.NameAr</td>
                            <td>@(m.Capacity?.ToString("N0") ?? "-")</td>
                            <td>@(m.HasFridayPrayer ? "✓" : "-")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
