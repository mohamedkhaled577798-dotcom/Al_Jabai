@model IEnumerable<WaqfProperty>
@{
    ViewData["Title"] = "العقارات الوقفية";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0"><i class="fas fa-building text-success me-2"></i>العقارات الوقفية</h4>
        <small class="text-muted">إدارة بيانات العقارات الوقفية</small>
    </div>
    <div>
        <a asp-action="Export" class="btn btn-outline-success me-2">
            <i class="fas fa-file-excel me-1"></i>تصدير Excel
        </a>
        <a asp-action="Create" class="btn btn-success">
            <i class="fas fa-plus me-2"></i>إضافة عقار جديد
        </a>
    </div>
</div>

<!-- Filters -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label">البحث</label>
                <input type="text" name="search" class="form-control" placeholder="ابحث بالاسم أو الكود..." value="@ViewBag.CurrentSearch">
            </div>
            <div class="col-md-3">
                <label class="form-label">المحافظة</label>
                <select name="provinceId" class="form-select" asp-items="@ViewBag.Provinces">
                    <option value="">جميع المحافظات</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">نوع العقار</label>
                <select name="typeId" class="form-select" asp-items="@ViewBag.PropertyTypes">
                    <option value="">جميع الأنواع</option>
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-outline-success me-2"><i class="fas fa-search me-1"></i>بحث</button>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-redo me-1"></i>إعادة</a>
            </div>
        </form>
    </div>
</div>

<!-- Data Table -->
<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>الكود</th>
                        <th>الاسم</th>
                        <th>النوع</th>
                        <th>الاستخدام</th>
                        <th>المحافظة</th>
                        <th>المساحة</th>
                        <th>القيمة</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr><td colspan="9" class="text-center py-4"><i class="fas fa-inbox fa-3x text-muted mb-3 d-block"></i><p class="text-muted">لا توجد عقارات</p></td></tr>
                    }
                    else
                    {
                        var count = 0;
                        foreach (var property in Model)
                        {
                            count++;
                            <tr>
                                <td>@count</td>
                                <td><code>@property.Code</code></td>
                                <td><strong>@property.NameAr</strong></td>
                                <td><span class="badge bg-success">@property.PropertyType?.NameAr</span></td>
                                <td>@(property.UsageType?.NameAr ?? "-")</td>
                                <td>@property.Province?.NameAr</td>
                                <td>@(property.AreaSqm?.ToString("N0") ?? "-") م²</td>
                                <td>@(property.EstimatedValue?.ToString("N0") ?? "-") د.ع</td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="Details" asp-route-id="@property.Id" class="btn btn-outline-info"><i class="fas fa-eye"></i></a>
                                        <a asp-action="Edit" asp-route-id="@property.Id" class="btn btn-outline-primary"><i class="fas fa-edit"></i></a>
                                        <button type="button" class="btn btn-outline-danger" onclick="confirmDelete(@property.Id, '@property.NameAr')"><i class="fas fa-trash"></i></button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer bg-light"><small class="text-muted">إجمالي العقارات: <strong>@Model.Count()</strong></small></div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white"><h5 class="modal-title">تأكيد الحذف</h5></div>
            <div class="modal-body"><p>هل أنت متأكد من حذف: <strong id="deleteItemName"></strong>؟</p></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
                <form id="deleteForm" method="post"><button type="submit" class="btn btn-danger">حذف</button></form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function confirmDelete(id, name) {
    document.getElementById('deleteItemName').textContent = name;
    document.getElementById('deleteForm').action = '/Properties/Delete/' + id;
    new bootstrap.Modal(document.getElementById('deleteModal')).show();
}
</script>
}
