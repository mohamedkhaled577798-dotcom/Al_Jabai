@model PropertyViewModel
@using WaqfGIS.Core.Entities
@{
    ViewData["Title"] = "تعديل عقار";
    var boundaryGeoJson = ViewBag.BoundaryGeoJson as string;
    var images = ViewBag.Images as IEnumerable<PropertyImage> ?? new List<PropertyImage>();
    var regFiles = ViewBag.RegistrationFiles as IEnumerable<PropertyRegistrationFile> ?? new List<PropertyRegistrationFile>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0"><i class="fas fa-edit text-success me-2"></i>تعديل بيانات العقار</h4>
        <small class="text-muted">@Model.NameAr</small>
    </div>
    <div>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-info me-2"><i class="fas fa-eye me-1"></i>عرض</a>
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-right me-1"></i>رجوع</a>
    </div>
</div>

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" id="BoundaryGeoJson" name="BoundaryGeoJson" value="@boundaryGeoJson" />
    
    <div class="row">
        <div class="col-lg-5">
            <!-- البيانات الأساسية -->
            <div class="card mb-3">
                <div class="card-header bg-success text-white"><h6 class="mb-0"><i class="fas fa-info-circle me-2"></i>البيانات الأساسية</h6></div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6"><label asp-for="NameAr" class="form-label"></label><input asp-for="NameAr" class="form-control" /><span asp-validation-for="NameAr" class="text-danger small"></span></div>
                        <div class="col-md-6"><label asp-for="NameEn" class="form-label"></label><input asp-for="NameEn" class="form-control" /></div>
                        <div class="col-md-6"><label asp-for="PropertyTypeId" class="form-label"></label><select asp-for="PropertyTypeId" class="form-select" asp-items="@ViewBag.PropertyTypes"><option value="">--</option></select></div>
                        <div class="col-md-6"><label asp-for="UsageTypeId" class="form-label"></label><select asp-for="UsageTypeId" class="form-select" asp-items="@ViewBag.UsageTypes"><option value="">--</option></select></div>
                        <div class="col-md-6"><label asp-for="WaqfOfficeId" class="form-label"></label><select asp-for="WaqfOfficeId" class="form-select" asp-items="@ViewBag.WaqfOffices"><option value="">--</option></select></div>
                        <div class="col-md-6"><label asp-for="ProvinceId" class="form-label"></label><select asp-for="ProvinceId" class="form-select" asp-items="@ViewBag.Provinces"><option value="">--</option></select></div>
                        <div class="col-12"><label asp-for="Address" class="form-label"></label><textarea asp-for="Address" class="form-control" rows="2"></textarea></div>
                    </div>
                </div>
            </div>

            <!-- المواصفات -->
            <div class="card mb-3">
                <div class="card-header bg-warning"><h6 class="mb-0"><i class="fas fa-ruler-combined me-2"></i>المواصفات</h6></div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6"><label asp-for="AreaSqm" class="form-label"></label><input asp-for="AreaSqm" id="areaSqmInput" class="form-control" type="number" step="0.01" /></div>
                        <div class="col-md-6"><label asp-for="FloorsCount" class="form-label"></label><input asp-for="FloorsCount" class="form-control" type="number" /></div>
                        <div class="col-md-6"><label asp-for="EstimatedValue" class="form-label"></label><input asp-for="EstimatedValue" class="form-control" type="number" /></div>
                        <div class="col-md-6"><label asp-for="DeedNumber" class="form-label"></label><input asp-for="DeedNumber" class="form-control" /></div>
                        <div class="col-md-6"><label asp-for="ConditionStatus" class="form-label"></label>
                            <select asp-for="ConditionStatus" class="form-select">
                                <option value="">--</option><option>ممتاز</option><option>جيد</option><option>متوسط</option><option>يحتاج صيانة</option>
                            </select>
                        </div>
                        <div class="col-md-6"><label asp-for="RentalStatus" class="form-label"></label>
                            <select asp-for="RentalStatus" class="form-select">
                                <option value="">--</option><option>مؤجر</option><option>شاغر</option><option>قيد الصيانة</option>
                            </select>
                        </div>
                        <div class="col-md-6"><label asp-for="MonthlyRent" class="form-label"></label><input asp-for="MonthlyRent" class="form-control" type="number" /></div>
                        <div class="col-12"><label asp-for="Notes" class="form-label"></label><textarea asp-for="Notes" class="form-control" rows="2"></textarea></div>
                    </div>
                </div>
            </div>

            <!-- الصور -->
            @if (images.Any())
            {
                <div class="card mb-3">
                    <div class="card-header bg-info text-white"><h6 class="mb-0"><i class="fas fa-images me-2"></i>صور العقار (@images.Count())</h6></div>
                    <div class="card-body">
                        <div class="row g-2">
                            @foreach (var img in images)
                            {
                                <div class="col-4">
                                    <img src="@img.FilePath" class="img-fluid rounded" style="height:60px;width:100%;object-fit:cover;" />
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }

            <!-- أهلية الوقف وحقول خاصة -->
            <div class="card mb-3">
                <div class="card-header" style="background:#6f42c1;color:#fff"><h6 class="mb-0"><i class="fas fa-clipboard-check me-2"></i>أهلية الوقف ومعلومات خاصة</h6></div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="WaqfNature" class="form-label fw-bold">طبيعة الوقف</label>
                            <select asp-for="WaqfNature" class="form-select" id="waqfNatureSelect" onchange="toggleAdminReceived()">
                                <option value="Khairi">خيري</option>
                                <option value="Ahli">أهلي</option>
                            </select>
                        </div>
                        <div class="col-md-4" id="adminReceivedGroup" style="display:@(Model.WaqfNature=="Ahli"?"block":"none")">
                            <label class="form-label fw-bold">مستلمة إدارياً</label>
                            <div class="d-flex gap-3 mt-2">
                                <div class="form-check"><input class="form-check-input" type="radio" name="IsAdminReceived" value="true" @(Model.IsAdminReceived==true?"checked":"") /><label class="form-check-label">نعم</label></div>
                                <div class="form-check"><input class="form-check-input" type="radio" name="IsAdminReceived" value="false" @(Model.IsAdminReceived==false?"checked":"") /><label class="form-check-label">لا</label></div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="WaqfCondition" class="form-label fw-bold">شرط الوقف</label>
                            <select asp-for="WaqfCondition" class="form-select" id="waqfConditionSelect" onchange="toggleConditionText()">
                                <option value="WithoutCondition">بدون شرط</option>
                                <option value="WithCondition">بشرط</option>
                            </select>
                        </div>
                    </div>
                    <!-- بيانات الواقف الأصلي -->
                    <hr class="my-2" />
                    <h6 class="text-muted mb-2"><i class="fas fa-user-shield me-2"></i>بيانات الواقف الأصلي</h6>
                    <div class="row g-2">
                        <div class="col-md-6">
                            <label asp-for="WaqifName" class="form-label small">اسم الواقف</label>
                            <input asp-for="WaqifName" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="WaqfDocumentDate" class="form-label small">تاريخ الوثيقة</label>
                            <input asp-for="WaqfDocumentDate" class="form-control form-control-sm" type="date" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="WaqfDocumentNumber" class="form-label small">رقم الوثيقة</label>
                            <input asp-for="WaqfDocumentNumber" class="form-control form-control-sm" />
                        </div>
                        <div class="col-12" id="waqfConditionTextGroup" style="display:@(Model.WaqfCondition=="WithCondition"?"block":"none")">
                            <label asp-for="WaqfConditionText" class="form-label small fw-bold text-primary">نص شرط الواقف</label>
                            <textarea asp-for="WaqfConditionText" class="form-control form-control-sm" rows="3"></textarea>
                        </div>
                    </div>
                    <hr class="my-3" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" asp-for="HasEncroachment" />
                                <label class="form-check-label text-danger fw-bold" for="HasEncroachment"><i class="fas fa-exclamation-circle me-1"></i>يوجد تجاوز على العقار</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <label asp-for="EncroachmentNotes" class="form-label">ملاحظات التجاوز</label>
                            <textarea asp-for="EncroachmentNotes" class="form-control" rows="2"></textarea>
                        </div>
                        <!-- نظام الإشغال السكني -->
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" asp-for="IsResidentialOccupancy" id="isResidentialOccupancy" onchange="toggleOccupancy()" />
                                <label class="form-check-label fw-bold text-info" for="isResidentialOccupancy"><i class="fas fa-home me-1"></i>مشغول سكنياً من قبل موظف</label>
                            </div>
                        </div>
                        <div id="occupancySection" style="display:@(Model.IsResidentialOccupancy?"block":"none")" class="col-12">
                            <div class="border border-info rounded p-3 bg-info bg-opacity-10">
                                <h6 class="text-info mb-3"><i class="fas fa-id-card me-2"></i>بيانات الموظف الشاغل</h6>
                                <div class="row g-2">
                                    <div class="col-md-6">
                                        <label asp-for="OccupantEmployeeName" class="form-label small">اسم الموظف</label>
                                        <input asp-for="OccupantEmployeeName" class="form-control form-control-sm" />
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="OccupantMinistry" class="form-label small">الوزارة / الجهة</label>
                                        <input asp-for="OccupantMinistry" class="form-control form-control-sm" />
                                    </div>
                                    <div class="col-md-4">
                                        <label asp-for="OccupantNationalId" class="form-label small">رقم الهوية</label>
                                        <input asp-for="OccupantNationalId" class="form-control form-control-sm" />
                                    </div>
                                    <div class="col-md-4">
                                        <label asp-for="OccupantPhone" class="form-label small">رقم الهاتف</label>
                                        <input asp-for="OccupantPhone" class="form-control form-control-sm" />
                                    </div>
                                    <div class="col-md-4">
                                        <label asp-for="OccupantStartDate" class="form-label small">تاريخ بدء الإشغال</label>
                                        <input asp-for="OccupantStartDate" class="form-control form-control-sm" type="date" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label small">حالة الموظف</label>
                                        <div class="d-flex gap-3 mt-1">
                                            <div class="form-check"><input class="form-check-input" type="radio" name="IsOccupantRetired" value="false" @(Model.IsOccupantRetired==false||Model.IsOccupantRetired==null?"checked":"") /><label class="form-check-label">عامل</label></div>
                                            <div class="form-check"><input class="form-check-input" type="radio" name="IsOccupantRetired" value="true" @(Model.IsOccupantRetired==true?"checked":"") /><label class="form-check-label">متقاعد</label></div>
                                        </div>
                                    </div>
                                    <div class="col-12">
                                        <label asp-for="OccupancyNotes" class="form-label small">ملاحظات الإشغال</label>
                                        <textarea asp-for="OccupancyNotes" class="form-control form-control-sm" rows="2"></textarea>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- مستندات وملفات التسجيل -->
            <div class="card mb-3">
                <div class="card-header bg-warning text-dark"><h6 class="mb-0"><i class="fas fa-file-alt me-2"></i>مستندات وملفات التسجيل</h6></div>
                <div class="card-body">
                    @if (regFiles.Any())
                    {
                        <div class="table-responsive mb-3">
                            <table class="table table-sm table-bordered">
                                <thead class="table-light"><tr><th>نوع المستند</th><th>اسم الملف</th><th>تاريخ الرفع</th><th></th></tr></thead>
                                <tbody>
                                    @foreach (var rf in regFiles)
                                    {
                                        <tr>
                                            <td><span class="badge bg-secondary">@rf.DocumentType</span></td>
                                            <td><a href="@rf.FilePath" target="_blank" class="text-decoration-none"><i class="fas fa-file me-1"></i>@rf.FileName</a></td>
                                            <td><small>@rf.UploadedAt.ToLocalTime().ToString("dd/MM/yyyy")</small></td>
                                            <td>
                                                <form asp-action="DeleteRegistrationFile" method="post" class="d-inline" onsubmit="return confirm('حذف الملف؟')">
                                                    <input type="hidden" name="fileId" value="@rf.Id" />
                                                    <input type="hidden" name="propertyId" value="@Model.Id" />
                                                    <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    <div class="row g-3">
                        <div class="col-md-5">
                            <label class="form-label">نوع المستند</label>
                            <select name="regDocType" class="form-select">
                                <option value="سند ملكية">سند ملكية</option>
                                <option value="قرار تخصيص">قرار تخصيص</option>
                                <option value="عقد إيجار">عقد إيجار</option>
                                <option value="وثيقة وقف">وثيقة وقف</option>
                                <option value="أخرى">أخرى</option>
                            </select>
                        </div>
                        <div class="col-md-7">
                            <label class="form-label">إضافة ملف جديد</label>
                            <input type="file" name="regFiles" class="form-control" multiple accept=".pdf,.doc,.docx,.jpg,.jpeg,.png,.xlsx" />
                            <small class="text-muted">يقبل PDF, Word, صور, Excel</small>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-success btn-lg"><i class="fas fa-save me-2"></i>حفظ التعديلات</button>
            </div>
        </div>

        <div class="col-lg-7">
            <!-- الموقع والحدود -->
            <div class="card sticky-top" style="top:10px;">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h6 class="mb-0"><i class="fas fa-map-marker-alt me-2"></i>الموقع وحدود العقار</h6>
                    <div class="btn-group btn-group-sm">
                        <button type="button" class="btn btn-light" onclick="setBaseMap('osm')" title="خريطة عادية"><i class="fas fa-map"></i></button>
                        <button type="button" class="btn btn-light active" onclick="setBaseMap('satellite')" title="صور جوية"><i class="fas fa-satellite"></i></button>
                        <button type="button" class="btn btn-light" onclick="setBaseMap('hybrid')" title="هجين"><i class="fas fa-layer-group"></i></button>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div id="locationMap" style="height:450px;"></div>
                </div>
                <div class="card-footer">
                    <!-- مساعد الإحداثيات -->
                    <div class="mb-2">
                        <label class="form-label small fw-bold"><i class="fab fa-google me-1 text-danger"></i>استخراج من رابط خرائط</label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text"><i class="fas fa-link"></i></span>
                            <input type="text" id="mapsLink_prop_edit" class="form-control"
                                   placeholder="الصق رابط Google أو Apple Maps..."
                                   oninput="extractCoordsFromLink('prop_edit','latitude','longitude')" />
                            <button type="button" class="btn btn-outline-success" onclick="extractCoordsFromLink('prop_edit','latitude','longitude')">
                                <i class="fas fa-magic me-1"></i>استخراج
                            </button>
                            <button type="button" class="btn btn-outline-secondary" onclick="clearMapsLink('prop_edit')"><i class="fas fa-times"></i></button>
                        </div>
                        <div id="linkResult_prop_edit" class="mt-1" style="display:none;"></div>
                    </div>
                    <div class="row align-items-center g-2">
                        <div class="col-md-3">
                            <label class="form-label small mb-1"><i class="fas fa-arrows-alt-v text-danger me-1"></i>خط العرض</label>
                            <div class="input-group input-group-sm">
                                <input asp-for="Latitude" id="latitude" class="form-control"
                                       placeholder="33.315"
                                       oninput="onManualCoordInput('prop_edit','latitude','longitude')" />
                                <span class="input-group-text" style="font-size:10px;">°N</span>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small mb-1"><i class="fas fa-arrows-alt-h text-primary me-1"></i>خط الطول</label>
                            <div class="input-group input-group-sm">
                                <input asp-for="Longitude" id="longitude" class="form-control"
                                       placeholder="44.361"
                                       oninput="onManualCoordInput('prop_edit','latitude','longitude')" />
                                <span class="input-group-text" style="font-size:10px;">°E</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small mb-1">أدوات الرسم</label>
                            <div class="btn-group btn-group-sm w-100">
                                <button type="button" class="btn btn-outline-primary" onclick="enableDrawPolygon()" title="رسم حدود"><i class="fas fa-draw-polygon me-1"></i>رسم</button>
                                <button type="button" class="btn btn-outline-warning" onclick="enableEditMode()" title="تعديل"><i class="fas fa-edit me-1"></i>تعديل</button>
                                <button type="button" class="btn btn-outline-danger" onclick="clearBoundary()" title="مسح"><i class="fas fa-eraser me-1"></i>مسح</button>
                            </div>
                        </div>
                    </div>
                    <div id="boundaryInfo" class="mt-2 p-2 bg-light rounded" style="display:none;">
                        <div class="row text-center">
                            <div class="col-6">
                                <small class="text-muted">المساحة</small>
                                <h6 class="mb-0 text-success" id="displayArea">--</h6>
                            </div>
                            <div class="col-6">
                                <small class="text-muted">المحيط</small>
                                <h6 class="mb-0 text-info" id="displayPerimeter">--</h6>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet.draw/1.0.4/leaflet.draw.css" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet.draw/1.0.4/leaflet.draw.js"></script>
<script src="~/js/coordinates-helper.js"></script>

<script>
var lat = @(Model.Latitude.ToString(System.Globalization.CultureInfo.InvariantCulture));
var lng = @(Model.Longitude.ToString(System.Globalization.CultureInfo.InvariantCulture));
var existingBoundary = @Html.Raw(boundaryGeoJson ?? "null");

// Base Maps
var osmLayer = L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '© OpenStreetMap' });
var satelliteLayer = L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', { attribution: '© Esri' });
var hybridLayer = L.layerGroup([
    L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}'),
    L.tileLayer('https://{s}.basemaps.cartocdn.com/light_only_labels/{z}/{x}/{y}{r}.png')
]);

var map = L.map('locationMap', { layers: [satelliteLayer] }).setView([lat, lng], 18);
var drawnItems = new L.FeatureGroup().addTo(map);

// Marker
var marker = L.marker([lat, lng], { draggable: true }).addTo(map);
marker.on('dragend', function() {
    var ll = marker.getLatLng();
    document.getElementById('latitude').value = ll.lat.toFixed(6);
    document.getElementById('longitude').value = ll.lng.toFixed(6);
});

map.on('click', function(e) {
    marker.setLatLng(e.latlng);
    document.getElementById('latitude').value = e.latlng.lat.toFixed(6);
    document.getElementById('longitude').value = e.latlng.lng.toFixed(6);
    var rd = document.getElementById('linkResult_prop_edit');
    if (rd) rd.style.display = 'none';
});

// دالة override لتحديث الخريطة من مساعد الإحداثيات
function updateMapMarker(uniqueId, newLat, newLng, flyToMap) {
    marker.setLatLng([newLat, newLng]);
    document.getElementById('latitude').value = newLat.toFixed(6);
    document.getElementById('longitude').value = newLng.toFixed(6);
    if (flyToMap !== false) map.flyTo([newLat, newLng], Math.max(map.getZoom(), 17), {duration: 0.8});
}

// Load existing boundary
if (existingBoundary) {
    var layer = L.geoJSON(existingBoundary, {
        style: { color: '#43a047', fillColor: '#66bb6a', fillOpacity: 0.3, weight: 3 }
    });
    layer.eachLayer(function(l) { drawnItems.addLayer(l); });
    updateBoundaryInfo(layer.getLayers()[0]);
    document.getElementById('boundaryInfo').style.display = 'block';
    map.fitBounds(layer.getBounds());
}

// Draw Control
var drawControl = new L.Control.Draw({
    position: 'topright',
    draw: {
        polygon: { allowIntersection: false, showArea: true, shapeOptions: { color: '#43a047', fillColor: '#66bb6a', fillOpacity: 0.3 } },
        polyline: false, circle: false, circlemarker: false, marker: false, rectangle: false
    },
    edit: { featureGroup: drawnItems, remove: true }
});
map.addControl(drawControl);

map.on(L.Draw.Event.CREATED, function(e) {
    drawnItems.clearLayers();
    drawnItems.addLayer(e.layer);
    updateBoundaryInfo(e.layer);
    saveBoundaryToInput(e.layer);
});

map.on(L.Draw.Event.EDITED, function(e) {
    e.layers.eachLayer(function(layer) {
        updateBoundaryInfo(layer);
        saveBoundaryToInput(layer);
    });
});

map.on(L.Draw.Event.DELETED, function() {
    document.getElementById('BoundaryGeoJson').value = '';
    document.getElementById('boundaryInfo').style.display = 'none';
});

function updateBoundaryInfo(layer) {
    if (!layer.getLatLngs) return;
    var latlngs = layer.getLatLngs()[0];
    var area = L.GeometryUtil.geodesicArea(latlngs);
    var perimeter = 0;
    for (var i = 0; i < latlngs.length - 1; i++) perimeter += latlngs[i].distanceTo(latlngs[i + 1]);
    perimeter += latlngs[latlngs.length - 1].distanceTo(latlngs[0]);
    
    document.getElementById('displayArea').textContent = area.toFixed(2) + ' م²';
    document.getElementById('displayPerimeter').textContent = perimeter.toFixed(2) + ' م';
    document.getElementById('boundaryInfo').style.display = 'block';
    document.getElementById('areaSqmInput').value = area.toFixed(2);
}

function saveBoundaryToInput(layer) {
    var geoJson = layer.toGeoJSON();
    document.getElementById('BoundaryGeoJson').value = JSON.stringify(geoJson.geometry);
}

function setBaseMap(type) {
    map.removeLayer(osmLayer); map.removeLayer(satelliteLayer); map.removeLayer(hybridLayer);
    if (type === 'osm') map.addLayer(osmLayer);
    else if (type === 'satellite') map.addLayer(satelliteLayer);
    else if (type === 'hybrid') map.addLayer(hybridLayer);
}

function enableDrawPolygon() { new L.Draw.Polygon(map, drawControl.options.draw.polygon).enable(); }
function enableEditMode() { drawnItems.eachLayer(function(l) { if (l.editing) l.editing.enable(); }); }
function clearBoundary() {
    drawnItems.clearLayers();
    document.getElementById('BoundaryGeoJson').value = '';
    document.getElementById('boundaryInfo').style.display = 'none';
}

function toggleAdminReceived() {
    var sel = document.getElementById('waqfNatureSelect');
    var grp = document.getElementById('adminReceivedGroup');
    if (sel && grp) grp.style.display = sel.value === 'Ahli' ? 'block' : 'none';
}

function toggleConditionText() {
    var sel = document.getElementById('waqfConditionSelect');
    var grp = document.getElementById('waqfConditionTextGroup');
    if (sel && grp) grp.style.display = sel.value === 'WithCondition' ? 'block' : 'none';
}

function toggleOccupancy() {
    var chk = document.getElementById('isResidentialOccupancy');
    var sec = document.getElementById('occupancySection');
    if (chk && sec) sec.style.display = chk.checked ? 'block' : 'none';
}
</script>

@await Html.PartialAsync("_CascadingDistricts")
}
