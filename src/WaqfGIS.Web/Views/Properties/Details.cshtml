@model WaqfProperty
@using WaqfGIS.Core.Entities
@using WaqfGIS.Web.Helpers
@{
    ViewData["Title"] = $"تفاصيل - {Model.NameAr}";
    var images = ViewBag.Images as IEnumerable<PropertyImage> ?? new List<PropertyImage>();
    var regFiles = ViewBag.RegistrationFiles as IEnumerable<PropertyRegistrationFile> ?? new List<PropertyRegistrationFile>();
    var boundaryGeoJson = ViewBag.BoundaryGeoJson as string;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4><i class="fas fa-building text-success me-2"></i>@Model.NameAr</h4>
        <small class="text-muted">@Model.Code</small>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="fas fa-edit me-1"></i>تعديل</a>
        <a asp-controller="Encroachements" asp-action="Create" asp-route-entityType="WaqfProperty" asp-route-entityId="@Model.Id" class="btn btn-outline-danger" title="تسجيل تجاوز جديد"><i class="fas fa-exclamation-triangle me-1"></i>تسجيل تجاوز</a>
        <a asp-controller="Encroachements" asp-action="Index" asp-route-entityType="WaqfProperty" class="btn btn-outline-warning" title="عرض سجل التجاوزات"><i class="fas fa-list me-1"></i>سجل التجاوزات</a>
        <a asp-controller="Maintenance" asp-action="Create" asp-route-entityType="WaqfProperty" asp-route-entityId="@Model.Id" asp-route-entityName="@Model.NameAr" class="btn btn-outline-secondary" title="إضافة صيانة"><i class="fas fa-tools me-1"></i>صيانة</a>
        <a asp-controller="Reports" asp-action="ExportPropertyPdf" asp-route-id="@Model.Id" class="btn btn-outline-danger" target="_blank" title="تصدير PDF"><i class="fas fa-file-pdf me-1"></i>PDF</a>
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-right me-1"></i>رجوع</a>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card mb-4">
            <div class="card-header bg-success text-white"><h6 class="mb-0">البيانات الأساسية</h6></div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 mb-3"><label class="text-muted small">الاسم</label><p class="fw-bold">@Model.NameAr</p></div>
                    <div class="col-md-6 mb-3"><label class="text-muted small">النوع</label><p><span class="badge bg-success">@Model.PropertyType?.NameAr</span></p></div>
                    <div class="col-md-6 mb-3"><label class="text-muted small">الاستخدام</label><p>@(Model.UsageType?.NameAr ?? "-")</p></div>
                    <div class="col-md-6 mb-3"><label class="text-muted small">المحافظة</label><p>@Model.Province?.NameAr</p></div>
                    <div class="col-md-6 mb-3"><label class="text-muted small">الدائرة الوقفية</label><p>@Model.WaqfOffice?.NameAr</p></div>
                    <div class="col-12"><label class="text-muted small">العنوان</label><p>@(Model.Address ?? "-")</p></div>
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header bg-info text-white"><h6 class="mb-0">الموقع</h6></div>
            <div class="card-body p-0"><div id="map" style="height:300px;"></div></div>
        </div>

        <div class="card mb-4">
            <div class="card-header bg-warning"><h6 class="mb-0">المواصفات والقيمة</h6></div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 mb-3"><label class="text-muted small">المساحة</label><p>@(Model.AreaSqm?.ToString("N0") ?? "-") م²</p></div>
                    <div class="col-md-4 mb-3"><label class="text-muted small">عدد الطوابق</label><p>@(Model.FloorsCount ?? 0)</p></div>
                    <div class="col-md-4 mb-3"><label class="text-muted small">القيمة التقديرية</label><p>@(Model.EstimatedValue?.ToString("N0") ?? "-") د.ع</p></div>
                    <div class="col-md-4 mb-3"><label class="text-muted small">رقم الصك</label><p>@(Model.DeedNumber ?? "-")</p></div>
                    <div class="col-md-4 mb-3"><label class="text-muted small">حالة العقار</label><p>@(Model.ConditionStatus ?? "-")</p></div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card mb-4">
            <div class="card-header bg-primary text-white"><h6 class="mb-0">بيانات الإيجار</h6></div>
            <div class="card-body">
                <p><strong>حالة الإيجار:</strong> @(Model.RentalStatus ?? "-")</p>
                <p><strong>الإيجار الشهري:</strong> @(Model.MonthlyRent?.ToString("N0") ?? "-") د.ع</p>
                <p><strong>المستأجر:</strong> @(Model.TenantName ?? "-")</p>
                <p><strong>هاتف المستأجر:</strong> @(Model.TenantPhone ?? "-")</p>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header bg-secondary text-white"><h6 class="mb-0">الإحداثيات</h6></div>
            <div class="card-body">
                <p><strong>خط العرض:</strong> @Model.Location?.Y.ToString("F6")</p>
                <p><strong>خط الطول:</strong> @Model.Location?.X.ToString("F6")</p>
            </div>
        </div>

        <!-- مستندات -->
        <div class="card mb-3">
            <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="fas fa-file-alt me-2"></i>مستندات وملفات التسجيل</h6>
                <span class="badge bg-dark">@regFiles.Count()</span>
            </div>
            <div class="card-body">
                @if (regFiles.Any())
                {
                    <div class="list-group list-group-flush">
                        @foreach (var rf in regFiles)
                        {
                            var icon = rf.MimeType != null && rf.MimeType.Contains("pdf") ? "fa-file-pdf text-danger" :
                                       rf.MimeType != null && (rf.MimeType.Contains("word") || rf.MimeType.Contains("doc")) ? "fa-file-word text-primary" :
                                       rf.MimeType != null && rf.MimeType.Contains("image") ? "fa-file-image text-success" :
                                       rf.MimeType != null && rf.MimeType.Contains("sheet") ? "fa-file-excel text-success" : "fa-file text-secondary";
                            var sizeKb = rf.FileSize.HasValue ? (rf.FileSize.Value / 1024.0).ToString("F1") + " KB" : "";
                            var rfExt  = rf.MimeType?.Contains("pdf")==true ? ".pdf" : System.IO.Path.GetExtension(rf.FileName ?? "");
                            var rfUrl  = FileHelper.Url(rf.FilePath, rfExt, true);
                            <div class="list-group-item px-0 py-2">
                                <div class="d-flex align-items-center justify-content-between">
                                    <div>
                                        <i class="fas @icon me-2"></i>
                                        <a href="@rfUrl" target="_blank" class="text-decoration-none fw-bold">@rf.FileName</a><br/>
                                        <small class="text-muted ms-4">
                                            <span class="badge bg-secondary me-1">@rf.DocumentType</span>
                                            @rf.UploadedAt.ToLocalTime().ToString("dd/MM/yyyy")
                                            @if (!string.IsNullOrEmpty(sizeKb)) { <text> · @sizeKb</text> }
                                        </small>
                                    </div>
                                    <a href="@rfUrl" target="_blank" class="btn btn-sm btn-outline-primary"><i class="fas fa-download"></i></a>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center text-muted py-3">
                        <i class="fas fa-folder-open fa-2x mb-2 d-block"></i>
                        <small>لا توجد مستندات مرفقة</small>
                    </div>
                }
                <div class="mt-2 text-end">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-warning">
                        <i class="fas fa-paperclip me-1"></i>إضافة مستندات
                    </a>
                </div>
            </div>
        </div>

        <!-- أهلية الوقف وبيانات الواقف -->
        <div class="card mb-4">
            <div class="card-header" style="background:#6f42c1;color:#fff"><h6 class="mb-0"><i class="fas fa-clipboard-check me-2"></i>أهلية الوقف</h6></div>
            <div class="card-body">
                <div class="row mb-2">
                    <div class="col-6"><label class="text-muted small">طبيعة الوقف</label><p class="mb-0">@if (Model.WaqfNature == "Ahli") { <span class="badge bg-warning text-dark">أهلي</span> } else { <span class="badge bg-success">خيري</span> }</p></div>
                    <div class="col-6"><label class="text-muted small">شرط الوقف</label><p class="mb-0">@if (Model.WaqfCondition == "WithCondition") { <span class="badge bg-info">بشرط</span> } else { <span class="badge bg-secondary">بدون شرط</span> }</p></div>
                </div>
                @if (Model.HasEncroachment) {
                <div class="alert alert-danger py-2 mb-2"><i class="fas fa-exclamation-circle me-1"></i>يوجد تجاوز على العقار
                    @if (!string.IsNullOrEmpty(Model.EncroachmentNotes)) { <br/><small>@Model.EncroachmentNotes</small> }
                </div>}
                @if (Model.IsResidentialOccupancy) {
                <div class="mt-2 p-2 border border-info rounded bg-info bg-opacity-10">
                    <h6 class="text-info mb-2"><i class="fas fa-home me-1"></i>الإشغال السكني</h6>
                    <div class="row">
                        @if (!string.IsNullOrEmpty(Model.OccupantEmployeeName)) {
                        <div class="col-12 mb-1"><label class="text-muted small">اسم الموظف</label><p class="mb-0 fw-bold">@Model.OccupantEmployeeName
                            @if (Model.IsOccupantRetired == true) { <span class="badge bg-secondary ms-1">متقاعد</span> }
                            else if (Model.IsOccupantRetired == false) { <span class="badge bg-success ms-1">موظف مستمر</span> }
                        </p></div>}
                        @if (!string.IsNullOrEmpty(Model.OccupantMinistry)) {
                        <div class="col-6 mb-1"><label class="text-muted small">الوزارة/الجهة</label><p class="mb-0">@Model.OccupantMinistry</p></div>}
                        @if (!string.IsNullOrEmpty(Model.OccupantNationalId)) {
                        <div class="col-6 mb-1"><label class="text-muted small">رقم الهوية</label><p class="mb-0 font-monospace">@Model.OccupantNationalId</p></div>}
                        @if (!string.IsNullOrEmpty(Model.OccupantPhone)) {
                        <div class="col-6 mb-1"><label class="text-muted small">الهاتف</label><p class="mb-0"><a href="tel:@Model.OccupantPhone">@Model.OccupantPhone</a></p></div>}
                        @if (Model.OccupantStartDate.HasValue) {
                        <div class="col-6 mb-1"><label class="text-muted small">بداية الإشغال</label><p class="mb-0">@Model.OccupantStartDate.Value.ToString("dd/MM/yyyy")</p></div>}
                        @if (!string.IsNullOrEmpty(Model.OccupancyNotes)) {
                        <div class="col-12"><label class="text-muted small">ملاحظات</label><p class="mb-0 small">@Model.OccupancyNotes</p></div>}
                    </div>
                </div>}
                @if (!string.IsNullOrEmpty(Model.WaqifName) || Model.WaqfDocumentDate.HasValue || !string.IsNullOrEmpty(Model.WaqfDocumentNumber)) {
                <hr class="my-2"/>
                <h6 class="text-muted small fw-bold"><i class="fas fa-user-shield me-1"></i>بيانات الواقف الأصلي</h6>
                <div class="row">
                    @if (!string.IsNullOrEmpty(Model.WaqifName)) {
                    <div class="col-12 mb-1"><label class="text-muted small">اسم الواقف</label><p class="mb-0 fw-bold">@Model.WaqifName</p></div>}
                    @if (Model.WaqfDocumentDate.HasValue) {
                    <div class="col-6 mb-1"><label class="text-muted small">تاريخ الوثيقة</label><p class="mb-0">@Model.WaqfDocumentDate.Value.ToString("dd/MM/yyyy")</p></div>}
                    @if (!string.IsNullOrEmpty(Model.WaqfDocumentNumber)) {
                    <div class="col-6 mb-1"><label class="text-muted small">رقم الوثيقة</label><p class="mb-0 font-monospace">@Model.WaqfDocumentNumber</p></div>}
                </div>}
                @if (Model.WaqfCondition == "WithCondition" && !string.IsNullOrEmpty(Model.WaqfConditionText)) {
                <div class="mt-2 p-2 bg-info bg-opacity-10 border border-info rounded">
                    <small class="text-info fw-bold"><i class="fas fa-scroll me-1"></i>نص شرط الواقف:</small>
                    <p class="mb-0 mt-1 small" style="white-space:pre-wrap;">@Model.WaqfConditionText</p>
                </div>}
            </div>
        </div>

        <div class="card">
            <div class="card-header bg-light"><h6 class="mb-0">التدقيق</h6></div>
            <div class="card-body small">
                <p><strong>تاريخ الإنشاء:</strong> @Model.CreatedAt.ToString("yyyy/MM/dd")</p>
                <p><strong>أنشئ بواسطة:</strong> @(Model.CreatedBy ?? "-")</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    var map = L.map('map').setView([@Model.Location?.Y, @Model.Location?.X], 15);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
    L.marker([@Model.Location?.Y, @Model.Location?.X]).addTo(map).bindPopup('@Model.NameAr').openPopup();
</script>
}
