@model WaqfProperty
@using WaqfGIS.Core.Entities
@{
    ViewData["Title"] = $"تفاصيل - {Model.NameAr}";
    var images = ViewBag.Images as IEnumerable<PropertyImage> ?? new List<PropertyImage>();
    var regFiles = ViewBag.RegistrationFiles as IEnumerable<PropertyRegistrationFile> ?? new List<PropertyRegistrationFile>();
    var boundaryGeoJson = ViewBag.BoundaryGeoJson as string;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4><i class="fas fa-building text-success me-2"></i>@Model.NameAr</h4>
        <small class="text-muted">@Model.Code</small>
    </div>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="fas fa-edit me-1"></i>تعديل</a>
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-right me-1"></i>رجوع</a>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card mb-4">
            <div class="card-header bg-success text-white"><h6 class="mb-0">البيانات الأساسية</h6></div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 mb-3"><label class="text-muted small">الاسم</label><p class="fw-bold">@Model.NameAr</p></div>
                    <div class="col-md-6 mb-3"><label class="text-muted small">النوع</label><p><span class="badge bg-success">@Model.PropertyType?.NameAr</span></p></div>
                    <div class="col-md-6 mb-3"><label class="text-muted small">الاستخدام</label><p>@(Model.UsageType?.NameAr ?? "-")</p></div>
                    <div class="col-md-6 mb-3"><label class="text-muted small">المحافظة</label><p>@Model.Province?.NameAr</p></div>
                    <div class="col-md-6 mb-3"><label class="text-muted small">الدائرة الوقفية</label><p>@Model.WaqfOffice?.NameAr</p></div>
                    <div class="col-12"><label class="text-muted small">العنوان</label><p>@(Model.Address ?? "-")</p></div>
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header bg-info text-white"><h6 class="mb-0">الموقع</h6></div>
            <div class="card-body p-0"><div id="map" style="height:300px;"></div></div>
        </div>

        <div class="card mb-4">
            <div class="card-header bg-warning"><h6 class="mb-0">المواصفات والقيمة</h6></div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 mb-3"><label class="text-muted small">المساحة</label><p>@(Model.AreaSqm?.ToString("N0") ?? "-") م²</p></div>
                    <div class="col-md-4 mb-3"><label class="text-muted small">عدد الطوابق</label><p>@(Model.FloorsCount ?? 0)</p></div>
                    <div class="col-md-4 mb-3"><label class="text-muted small">القيمة التقديرية</label><p>@(Model.EstimatedValue?.ToString("N0") ?? "-") د.ع</p></div>
                    <div class="col-md-4 mb-3"><label class="text-muted small">رقم الصك</label><p>@(Model.DeedNumber ?? "-")</p></div>
                    <div class="col-md-4 mb-3"><label class="text-muted small">حالة العقار</label><p>@(Model.ConditionStatus ?? "-")</p></div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card mb-4">
            <div class="card-header bg-primary text-white"><h6 class="mb-0">بيانات الإيجار</h6></div>
            <div class="card-body">
                <p><strong>حالة الإيجار:</strong> @(Model.RentalStatus ?? "-")</p>
                <p><strong>الإيجار الشهري:</strong> @(Model.MonthlyRent?.ToString("N0") ?? "-") د.ع</p>
                <p><strong>المستأجر:</strong> @(Model.TenantName ?? "-")</p>
                <p><strong>هاتف المستأجر:</strong> @(Model.TenantPhone ?? "-")</p>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header bg-secondary text-white"><h6 class="mb-0">الإحداثيات</h6></div>
            <div class="card-body">
                <p><strong>خط العرض:</strong> @Model.Location?.Y.ToString("F6")</p>
                <p><strong>خط الطول:</strong> @Model.Location?.X.ToString("F6")</p>
            </div>
        </div>

        <!-- مستندات -->
        <div class="card mb-3">
            <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="fas fa-file-alt me-2"></i>مستندات وملفات التسجيل</h6>
                <span class="badge bg-dark">@regFiles.Count()</span>
            </div>
            <div class="card-body">
                @if (regFiles.Any())
                {
                    <div class="list-group list-group-flush">
                        @foreach (var rf in regFiles)
                        {
                            var icon = rf.MimeType != null && rf.MimeType.Contains("pdf") ? "fa-file-pdf text-danger" :
                                       rf.MimeType != null && (rf.MimeType.Contains("word") || rf.MimeType.Contains("doc")) ? "fa-file-word text-primary" :
                                       rf.MimeType != null && rf.MimeType.Contains("image") ? "fa-file-image text-success" :
                                       rf.MimeType != null && rf.MimeType.Contains("sheet") ? "fa-file-excel text-success" : "fa-file text-secondary";
                            var sizeKb = rf.FileSize.HasValue ? (rf.FileSize.Value / 1024.0).ToString("F1") + " KB" : "";
                            <div class="list-group-item px-0 py-2">
                                <div class="d-flex align-items-center justify-content-between">
                                    <div>
                                        <i class="fas @icon me-2"></i>
                                        <a href="@rf.FilePath" target="_blank" class="text-decoration-none fw-bold">@rf.FileName</a><br/>
                                        <small class="text-muted ms-4">
                                            <span class="badge bg-secondary me-1">@rf.DocumentType</span>
                                            @rf.UploadedAt.ToLocalTime().ToString("dd/MM/yyyy")
                                            @if (!string.IsNullOrEmpty(sizeKb)) { <text> · @sizeKb</text> }
                                        </small>
                                    </div>
                                    <a href="@rf.FilePath" target="_blank" class="btn btn-sm btn-outline-primary"><i class="fas fa-download"></i></a>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center text-muted py-3">
                        <i class="fas fa-folder-open fa-2x mb-2 d-block"></i>
                        <small>لا توجد مستندات مرفقة</small>
                    </div>
                }
                <div class="mt-2 text-end">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-warning">
                        <i class="fas fa-paperclip me-1"></i>إضافة مستندات
                    </a>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header bg-light"><h6 class="mb-0">التدقيق</h6></div>
            <div class="card-body small">
                <p><strong>تاريخ الإنشاء:</strong> @Model.CreatedAt.ToString("yyyy/MM/dd")</p>
                <p><strong>أنشئ بواسطة:</strong> @(Model.CreatedBy ?? "-")</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    var map = L.map('map').setView([@Model.Location?.Y, @Model.Location?.X], 15);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
    L.marker([@Model.Location?.Y, @Model.Location?.X]).addTo(map).bindPopup('@Model.NameAr').openPopup();
</script>
}
