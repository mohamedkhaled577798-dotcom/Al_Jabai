@model PropertyViewModel
@{
    ViewData["Title"] = "إضافة عقار جديد";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0"><i class="fas fa-plus text-success me-2"></i>إضافة عقار جديد</h4>
        <small class="text-muted">إدخال بيانات العقار الوقفي</small>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-right me-2"></i>العودة</a>
</div>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    <div class="row">
        <div class="col-lg-8">
            <!-- البيانات الأساسية -->
            <div class="card mb-4">
                <div class="card-header bg-success text-white"><h6 class="mb-0"><i class="fas fa-info-circle me-2"></i>البيانات الأساسية</h6></div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="NameAr" class="form-label"></label>
                            <input asp-for="NameAr" class="form-control" />
                            <span asp-validation-for="NameAr" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NameEn" class="form-label"></label>
                            <input asp-for="NameEn" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PropertyTypeId" class="form-label"></label>
                            <select asp-for="PropertyTypeId" class="form-select" asp-items="@ViewBag.PropertyTypes">
                                <option value="">-- اختر النوع --</option>
                            </select>
                            <span asp-validation-for="PropertyTypeId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="UsageTypeId" class="form-label"></label>
                            <select asp-for="UsageTypeId" class="form-select" asp-items="@ViewBag.UsageTypes">
                                <option value="">-- اختر الاستخدام --</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="WaqfOfficeId" class="form-label"></label>
                            <select asp-for="WaqfOfficeId" class="form-select" asp-items="@ViewBag.WaqfOffices">
                                <option value="">-- اختر الدائرة --</option>
                            </select>
                            <span asp-validation-for="WaqfOfficeId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ProvinceId" class="form-label"></label>
                            <select asp-for="ProvinceId" class="form-select" asp-items="@ViewBag.Provinces">
                                <option value="">-- اختر المحافظة --</option>
                            </select>
                            <span asp-validation-for="ProvinceId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DistrictId" class="form-label"></label>
                            <select asp-for="DistrictId" class="form-select" asp-items="@ViewBag.Districts">
                                <option value="">-- اختر القضاء --</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label asp-for="Address" class="form-label"></label>
                            <textarea asp-for="Address" class="form-control" rows="2"></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <!-- الموقع -->
            <div class="card mb-4">
                <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                    <h6 class="mb-0"><i class="fas fa-map-marker-alt me-2"></i>الموقع الجغرافي</h6>
                    <div class="btn-group btn-group-sm">
                        <button type="button" class="btn btn-light" onclick="setPropBaseMap('osm')" title="عادية"><i class="fas fa-map"></i></button>
                        <button type="button" class="btn btn-light" onclick="setPropBaseMap('satellite')" title="فضائية"><i class="fas fa-satellite"></i></button>
                    </div>
                </div>
                <div class="card-body">
                    <!-- مساعد الإحداثيات -->
                    <div class="card mb-3 border-info">
                        <div class="card-header bg-info bg-opacity-10 py-2">
                            <h6 class="mb-0 text-info"><i class="fas fa-crosshairs me-2"></i>تحديد الموقع الجغرافي</h6>
                        </div>
                        <div class="card-body py-2">
                            <div class="mb-2">
                                <label class="form-label small fw-bold"><i class="fab fa-google me-1"></i>استخراج من رابط خرائط</label>
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text"><i class="fas fa-link"></i></span>
                                    <input type="text" id="mapsLink_prop_create" class="form-control"
                                           placeholder="الصق رابط Google أو Apple Maps هنا..."
                                           oninput="extractCoordsFromLink('prop_create','latitude','longitude')" />
                                    <button type="button" class="btn btn-outline-success" onclick="extractCoordsFromLink('prop_create','latitude','longitude')">
                                        <i class="fas fa-magic me-1"></i>استخراج
                                    </button>
                                    <button type="button" class="btn btn-outline-secondary" onclick="clearMapsLink('prop_create')"><i class="fas fa-times"></i></button>
                                </div>
                                <div id="linkResult_prop_create" class="mt-1" style="display:none;"></div>
                            </div>
                            <div class="row g-2">
                                <div class="col-md-5">
                                    <label class="form-label small"><i class="fas fa-arrows-alt-v text-danger me-1"></i>خط العرض</label>
                                    <div class="input-group input-group-sm">
                                        <input asp-for="Latitude" id="latitude" class="form-control" placeholder="33.315000"
                                               oninput="onManualCoordInput('prop_create','latitude','longitude')" />
                                        <span class="input-group-text">°N</span>
                                    </div>
                                </div>
                                <div class="col-md-5">
                                    <label class="form-label small"><i class="fas fa-arrows-alt-h text-primary me-1"></i>خط الطول</label>
                                    <div class="input-group input-group-sm">
                                        <input asp-for="Longitude" id="longitude" class="form-control" placeholder="44.361000"
                                               oninput="onManualCoordInput('prop_create','latitude','longitude')" />
                                        <span class="input-group-text">°E</span>
                                    </div>
                                </div>
                                <div class="col-md-2 d-flex align-items-end">
                                    <button type="button" class="btn btn-sm btn-primary w-100"
                                            onclick="goToManualCoords('prop_create','latitude','longitude')" title="الذهاب للإحداثيات">
                                        <i class="fas fa-map-pin"></i>
                                    </button>
                                </div>
                            </div>
                            <small class="text-muted d-block mt-1">يمكن النقر على الخريطة أو إدخال الإحداثيات يدوياً أو لصق رابط</small>
                        </div>
                    </div>
                    <div id="locationMap" style="height: 320px; border-radius: 8px;"></div>
                </div>
            </div>

            <!-- المواصفات -->
            <div class="card mb-4">
                <div class="card-header bg-warning"><h6 class="mb-0"><i class="fas fa-ruler-combined me-2"></i>المواصفات والقيمة</h6></div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label asp-for="AreaSqm" class="form-label"></label>
                            <input asp-for="AreaSqm" class="form-control" type="number" step="0.01" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="BuiltAreaSqm" class="form-label"></label>
                            <input asp-for="BuiltAreaSqm" class="form-control" type="number" step="0.01" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="FloorsCount" class="form-label"></label>
                            <input asp-for="FloorsCount" class="form-control" type="number" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="RoomsCount" class="form-label"></label>
                            <input asp-for="RoomsCount" class="form-control" type="number" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="EstimatedValue" class="form-label"></label>
                            <div class="input-group">
                                <input asp-for="EstimatedValue" class="form-control" type="number" />
                                <span class="input-group-text">د.ع</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="DeedNumber" class="form-label"></label>
                            <input asp-for="DeedNumber" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="ConditionStatus" class="form-label"></label>
                            <select asp-for="ConditionStatus" class="form-select">
                                <option value="">-- اختر الحالة --</option>
                                <option value="ممتاز">ممتاز</option>
                                <option value="جيد">جيد</option>
                                <option value="متوسط">متوسط</option>
                                <option value="يحتاج صيانة">يحتاج صيانة</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- الشريط الجانبي -->
        <div class="col-lg-4">
            <!-- بيانات الإيجار -->
            <div class="card mb-4">
                <div class="card-header bg-primary text-white"><h6 class="mb-0"><i class="fas fa-money-bill me-2"></i>بيانات الإيجار</h6></div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="RentalStatus" class="form-label"></label>
                        <select asp-for="RentalStatus" class="form-select">
                            <option value="">-- اختر --</option>
                            <option value="مؤجر">مؤجر</option>
                            <option value="فارغ">فارغ</option>
                            <option value="مستثمر">مستثمر</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label asp-for="MonthlyRent" class="form-label"></label>
                        <div class="input-group">
                            <input asp-for="MonthlyRent" class="form-control" type="number" />
                            <span class="input-group-text">د.ع</span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="TenantName" class="form-label"></label>
                        <input asp-for="TenantName" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="TenantPhone" class="form-label"></label>
                        <input asp-for="TenantPhone" class="form-control" />
                    </div>
                </div>
            </div>

            <!-- ملاحظات -->
            <div class="card mb-4">
                <div class="card-header bg-secondary text-white"><h6 class="mb-0"><i class="fas fa-sticky-note me-2"></i>ملاحظات</h6></div>
                <div class="card-body">
                    <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                </div>
            </div>

            <!-- أهلية الوقف وحقول خاصة -->
            <div class="card mb-4">
                <div class="card-header" style="background:#6f42c1;color:#fff"><h6 class="mb-0"><i class="fas fa-clipboard-check me-2"></i>أهلية الوقف ومعلومات خاصة</h6></div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="WaqfNature" class="form-label fw-bold">طبيعة الوقف</label>
                            <select asp-for="WaqfNature" class="form-select" id="waqfNatureSelect" onchange="toggleAdminReceived()">
                                <option value="Khairi">خيري</option>
                                <option value="Ahli">أهلي</option>
                            </select>
                        </div>
                        <div class="col-md-4" id="adminReceivedGroup" style="display:none">
                            <label class="form-label fw-bold">مستلمة إدارياً</label>
                            <div class="d-flex gap-3 mt-2">
                                <div class="form-check"><input class="form-check-input" type="radio" name="IsAdminReceived" value="true" /><label class="form-check-label">نعم</label></div>
                                <div class="form-check"><input class="form-check-input" type="radio" name="IsAdminReceived" value="false" /><label class="form-check-label">لا</label></div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="WaqfCondition" class="form-label fw-bold">شرط الوقف</label>
                            <select asp-for="WaqfCondition" class="form-select" id="waqfConditionSelect" onchange="toggleConditionText()">
                                <option value="WithoutCondition">بدون شرط</option>
                                <option value="WithCondition">بشرط</option>
                            </select>
                        </div>
                    </div>
                    <!-- بيانات الواقف الأصلي -->
                    <hr class="my-2" />
                    <h6 class="text-muted mb-2"><i class="fas fa-user-shield me-2"></i>بيانات الواقف الأصلي</h6>
                    <div class="row g-2">
                        <div class="col-md-6">
                            <label asp-for="WaqifName" class="form-label small">اسم الواقف</label>
                            <input asp-for="WaqifName" class="form-control form-control-sm" placeholder="اسم الواقف..." />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="WaqfDocumentDate" class="form-label small">تاريخ الوثيقة</label>
                            <input asp-for="WaqfDocumentDate" class="form-control form-control-sm" type="date" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="WaqfDocumentNumber" class="form-label small">رقم الوثيقة</label>
                            <input asp-for="WaqfDocumentNumber" class="form-control form-control-sm" placeholder="رقم..." />
                        </div>
                        <div class="col-12" id="waqfConditionTextGroup" style="display:none">
                            <label asp-for="WaqfConditionText" class="form-label small fw-bold text-primary">نص شرط الواقف</label>
                            <textarea asp-for="WaqfConditionText" class="form-control form-control-sm" rows="3"
                                placeholder="نص شرط الواقف..."></textarea>
                        </div>
                    </div>
                    <hr class="my-3" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" asp-for="HasEncroachment" id="hasEncr" />
                                <label class="form-check-label text-danger fw-bold" for="hasEncr"><i class="fas fa-exclamation-circle me-1"></i>يوجد تجاوز على العقار</label>
                            </div>
                        </div>
                        <div class="col-md-12">
                            <label asp-for="EncroachmentNotes" class="form-label">ملاحظات التجاوز (وصف التجاوزات والمباني)</label>
                            <textarea asp-for="EncroachmentNotes" class="form-control" rows="2" placeholder="وصف التجاوزات أو التعديات على العقار..."></textarea>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="OccupantEmployeeName" class="form-label">اسم الموظف الشاغل للسكن</label>
                            <input asp-for="OccupantEmployeeName" class="form-control" placeholder="اترك فارغاً إن لم ينطبق" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">حالة الموظف</label>
                            <div class="d-flex gap-3 mt-2">
                                <div class="form-check"><input class="form-check-input" type="radio" name="IsOccupantRetired" value="true" /><label class="form-check-label">متقاعد</label></div>
                                <div class="form-check"><input class="form-check-input" type="radio" name="IsOccupantRetired" value="false" /><label class="form-check-label">عامل</label></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ملفات التسجيل -->
            <div class="card mb-4">
                <div class="card-header bg-warning text-dark"><h6 class="mb-0"><i class="fas fa-file-alt me-2"></i>مستندات وملفات التسجيل</h6></div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-5">
                            <label class="form-label">نوع المستند</label>
                            <select name="regDocType" class="form-select">
                                <option value="سند ملكية">سند ملكية</option>
                                <option value="قرار تخصيص">قرار تخصيص</option>
                                <option value="عقد إيجار">عقد إيجار</option>
                                <option value="وثيقة وقف">وثيقة وقف</option>
                                <option value="أخرى">أخرى</option>
                            </select>
                        </div>
                        <div class="col-md-7">
                            <label class="form-label">اختيار الملف (أو عدة ملفات)</label>
                            <input type="file" name="regFiles" class="form-control" multiple accept=".pdf,.doc,.docx,.jpg,.jpeg,.png,.xlsx" />
                            <small class="text-muted">يقبل PDF, Word, صور, Excel</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- صور العقار -->
            <div class="card mb-4">
                <div class="card-header bg-info text-white"><h6 class="mb-0"><i class="fas fa-images me-2"></i>صور العقار</h6></div>
                <div class="card-body">
                    <input type="file" name="images" class="form-control" multiple accept="image/*" />
                    <small class="text-muted">يمكنك اختيار عدة صور (الحد الأقصى 10MB لكل صورة)</small>
                </div>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-success btn-lg"><i class="fas fa-save me-2"></i>حفظ العقار</button>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-times me-2"></i>إلغاء</a>
            </div>
        </div>
    </div>
</form>

@section Scripts {
<script src="~/js/coordinates-helper.js"></script>
<script>
    var osmProp = L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '© OpenStreetMap' });
    var satProp = L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', { attribution: '© Esri' });
    var map = L.map('locationMap', { layers: [osmProp] }).setView([33.3, 44.4], 7);
    var marker = null;

    function setPropBaseMap(type) {
        map.removeLayer(osmProp); map.removeLayer(satProp);
        if (type === 'osm') map.addLayer(osmProp); else map.addLayer(satProp);
    }

    map.on('click', function(e) {
        if (marker) marker.setLatLng(e.latlng);
        else { marker = L.marker(e.latlng, {draggable: true}).addTo(map); marker.on('dragend', updateCoords); }
        updateCoords();
        var rd = document.getElementById('linkResult_prop_create');
        if (rd) rd.style.display = 'none';
    });

    function updateCoords() {
        if (marker) {
            var ll = marker.getLatLng();
            document.getElementById('latitude').value = ll.lat.toFixed(6);
            document.getElementById('longitude').value = ll.lng.toFixed(6);
        }
    }

    function updateMapMarker(uniqueId, lat, lng, flyToMap) {
        if (marker) marker.setLatLng([lat, lng]);
        else {
            marker = L.marker([lat, lng], {draggable: true}).addTo(map);
            marker.on('dragend', updateCoords);
        }
        document.getElementById('latitude').value = lat.toFixed(6);
        document.getElementById('longitude').value = lng.toFixed(6);
        if (flyToMap !== false) map.flyTo([lat, lng], Math.max(map.getZoom(), 16), {duration: 0.8});
    }

    function toggleAdminReceived() {
        var sel = document.getElementById('waqfNatureSelect');
        var grp = document.getElementById('adminReceivedGroup');
        if (sel && grp) grp.style.display = sel.value === 'Ahli' ? 'block' : 'none';
    }
    toggleAdminReceived();

    function toggleConditionText() {
        var sel = document.getElementById('waqfConditionSelect');
        var grp = document.getElementById('waqfConditionTextGroup');
        if (sel && grp) grp.style.display = sel.value === 'WithCondition' ? 'block' : 'none';
    }
    toggleConditionText();
</script>

@await Html.PartialAsync("_CascadingDistricts")
}
