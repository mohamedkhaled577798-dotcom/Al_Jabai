@model CreateUserViewModel
@{
    ViewData["Title"] = "إضافة مستخدم جديد";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4><i class="fas fa-user-plus text-primary me-2"></i>إضافة مستخدم جديد</h4>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-right me-1"></i>رجوع</a>
</div>

<div class="row">
    <div class="col-lg-8">
        <form asp-action="Create" method="post">
            <div class="card mb-4">
                <div class="card-header bg-primary text-white"><h6 class="mb-0"><i class="fas fa-user me-2"></i>بيانات الحساب</h6></div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6"><label asp-for="UserName" class="form-label"></label><input asp-for="UserName" class="form-control" /><span asp-validation-for="UserName" class="text-danger small"></span></div>
                        <div class="col-md-6"><label asp-for="Email" class="form-label"></label><input asp-for="Email" class="form-control" type="email" /><span asp-validation-for="Email" class="text-danger small"></span></div>
                        <div class="col-md-6"><label asp-for="Password" class="form-label"></label><input asp-for="Password" class="form-control" type="password" /><span asp-validation-for="Password" class="text-danger small"></span></div>
                        <div class="col-md-6"><label asp-for="ConfirmPassword" class="form-label"></label><input asp-for="ConfirmPassword" class="form-control" type="password" /><span asp-validation-for="ConfirmPassword" class="text-danger small"></span></div>
                    </div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header bg-info text-white"><h6 class="mb-0"><i class="fas fa-id-card me-2"></i>البيانات الشخصية</h6></div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6"><label asp-for="FullNameAr" class="form-label"></label><input asp-for="FullNameAr" class="form-control" /><span asp-validation-for="FullNameAr" class="text-danger small"></span></div>
                        <div class="col-md-6"><label asp-for="FullNameEn" class="form-label"></label><input asp-for="FullNameEn" class="form-control" /></div>
                        <div class="col-md-6"><label asp-for="Phone" class="form-label"></label><input asp-for="Phone" class="form-control" /></div>
                        <div class="col-md-6"><label asp-for="JobTitle" class="form-label"></label><input asp-for="JobTitle" class="form-control" /></div>
                    </div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header bg-warning"><h6 class="mb-0"><i class="fas fa-shield-alt me-2"></i>الصلاحيات</h6></div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="PermissionLevel" class="form-label"></label>
                            <select asp-for="PermissionLevel" class="form-select" asp-items="@ViewBag.PermissionLevels" id="permissionLevel" onchange="toggleScopeFields()">
                            </select>
                            <span asp-validation-for="PermissionLevel" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Role" class="form-label"></label>
                            <select asp-for="Role" class="form-select" asp-items="@ViewBag.Roles">
                                <option value="">-- اختر --</option>
                            </select>
                            <span asp-validation-for="Role" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6" id="provinceField" style="display:none;">
                            <label asp-for="ProvinceId" class="form-label">المحافظة المسؤول عنها</label>
                            <select asp-for="ProvinceId" class="form-select" asp-items="@ViewBag.Provinces">
                                <option value="">-- اختر المحافظة --</option>
                            </select>
                        </div>
                        <div class="col-md-6" id="officeField" style="display:none;">
                            <label asp-for="WaqfOfficeId" class="form-label">الدائرة المسؤول عنها</label>
                            <select asp-for="WaqfOfficeId" class="form-select" asp-items="@ViewBag.WaqfOffices">
                                <option value="">-- اختر الدائرة --</option>
                            </select>
                        </div>
                    </div>
                    <div class="alert alert-info mt-3 small">
                        <strong>مستويات الصلاحيات:</strong><br>
                        • <strong>مدير النظام:</strong> صلاحية كاملة على جميع البيانات<br>
                        • <strong>مدير:</strong> صلاحية إدارية على جميع البيانات<br>
                        • <strong>مسؤول محافظة:</strong> يرى ويعدل بيانات محافظته فقط<br>
                        • <strong>مسؤول دائرة:</strong> يرى ويعدل بيانات دائرته فقط<br>
                        • <strong>عرض فقط:</strong> يرى جميع البيانات بدون تعديل
                    </div>
                </div>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary btn-lg"><i class="fas fa-save me-2"></i>إنشاء الحساب</button>
                <a asp-action="Index" class="btn btn-outline-secondary">إلغاء</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
function toggleScopeFields() {
    var level = document.getElementById('permissionLevel').value;
    document.getElementById('provinceField').style.display = (level == '2') ? 'block' : 'none';
    document.getElementById('officeField').style.display = (level == '3') ? 'block' : 'none';
}
toggleScopeFields();
</script>
}
