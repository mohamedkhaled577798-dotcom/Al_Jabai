@model IEnumerable<WaqfOffice>
@{
    ViewData["Title"] = "الدوائر الوقفية";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0"><i class="fas fa-landmark text-warning me-2"></i>الدوائر الوقفية</h4>
        <small class="text-muted">إدارة الدوائر والمكاتب الوقفية</small>
    </div>
    <div>
        <a asp-action="Export" class="btn btn-outline-warning me-2"><i class="fas fa-file-excel me-1"></i>تصدير Excel</a>
        <a asp-action="Create" class="btn btn-warning"><i class="fas fa-plus me-2"></i>إضافة دائرة جديدة</a>
    </div>
</div>

<!-- Filters -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label">البحث</label>
                <input type="text" name="search" class="form-control" placeholder="ابحث..." value="@ViewBag.CurrentSearch">
            </div>
            <div class="col-md-3">
                <label class="form-label">المحافظة</label>
                <select name="provinceId" class="form-select" asp-items="@ViewBag.Provinces"><option value="">الكل</option></select>
            </div>
            <div class="col-md-3">
                <label class="form-label">نوع المكتب</label>
                <select name="typeId" class="form-select" asp-items="@ViewBag.OfficeTypes"><option value="">الكل</option></select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-outline-warning"><i class="fas fa-search"></i></button>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-redo"></i></a>
            </div>
        </form>
    </div>
</div>

<!-- Table -->
<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th><th>الكود</th><th>الاسم</th><th>النوع</th><th>المحافظة</th><th>المدير</th><th>الهاتف</th><th>الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr><td colspan="8" class="text-center py-4"><i class="fas fa-inbox fa-3x text-muted"></i><p class="text-muted mt-2">لا توجد دوائر</p></td></tr>
                    }
                    else
                    {
                        var count = 0;
                        foreach (var office in Model)
                        {
                            count++;
                            <tr>
                                <td>@count</td>
                                <td><code>@office.Code</code></td>
                                <td>
                                    <strong>@office.NameAr</strong>
                                    @if (office.ParentOffice != null)
                                    {
                                        <br><small class="text-muted">تابع لـ: @office.ParentOffice.NameAr</small>
                                    }
                                </td>
                                <td><span class="badge bg-warning text-dark">@office.OfficeType?.NameAr</span></td>
                                <td>@(office.Province?.NameAr ?? "-")</td>
                                <td>@(office.ManagerName ?? "-")</td>
                                <td>@(office.Phone ?? "-")</td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="Details" asp-route-id="@office.Id" class="btn btn-outline-info"><i class="fas fa-eye"></i></a>
                                        <a asp-action="Edit" asp-route-id="@office.Id" class="btn btn-outline-primary"><i class="fas fa-edit"></i></a>
                                        <button class="btn btn-outline-danger" onclick="confirmDelete(@office.Id, '@office.NameAr')"><i class="fas fa-trash"></i></button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer bg-light"><small>إجمالي الدوائر: <strong>@Model.Count()</strong></small></div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog"><div class="modal-content">
        <div class="modal-header bg-danger text-white"><h5 class="modal-title">تأكيد الحذف</h5></div>
        <div class="modal-body"><p>هل أنت متأكد من حذف: <strong id="deleteItemName"></strong>؟</p></div>
        <div class="modal-footer">
            <button class="btn btn-secondary" data-bs-dismiss="modal">إلغاء</button>
            <form id="deleteForm" method="post"><button class="btn btn-danger">حذف</button></form>
        </div>
    </div></div>
</div>

@section Scripts {
<script>
function confirmDelete(id, name) {
    document.getElementById('deleteItemName').textContent = name;
    document.getElementById('deleteForm').action = '/Offices/Delete/' + id;
    new bootstrap.Modal(document.getElementById('deleteModal')).show();
}
</script>
}
