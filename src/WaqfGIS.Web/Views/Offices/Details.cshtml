@model WaqfOffice
@{
    ViewData["Title"] = $"تفاصيل - {Model.NameAr}";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div><h4><i class="fas fa-landmark text-warning me-2"></i>@Model.NameAr</h4><small class="text-muted">@Model.Code</small></div>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="fas fa-edit me-1"></i>تعديل</a>
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-right me-1"></i>رجوع</a>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card mb-4">
            <div class="card-header bg-warning"><h6 class="mb-0">البيانات الأساسية</h6></div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 mb-3"><label class="text-muted small">الاسم بالعربية</label><p class="fw-bold">@Model.NameAr</p></div>
                    <div class="col-md-6 mb-3"><label class="text-muted small">الاسم بالإنجليزية</label><p>@(Model.NameEn ?? "-")</p></div>
                    <div class="col-md-6 mb-3"><label class="text-muted small">نوع المكتب</label><p><span class="badge bg-warning text-dark">@Model.OfficeType?.NameAr</span></p></div>
                    <div class="col-md-6 mb-3"><label class="text-muted small">المحافظة</label><p>@(Model.Province?.NameAr ?? "-")</p></div>
                    @if (Model.ParentOffice != null)
                    {
                        <div class="col-md-6 mb-3"><label class="text-muted small">تابع لـ</label><p>@Model.ParentOffice.NameAr</p></div>
                    }
                    <div class="col-12"><label class="text-muted small">العنوان</label><p>@(Model.Address ?? "-")</p></div>
                </div>
            </div>
        </div>

        @if (Model.Location != null)
        {
            <div class="card mb-4">
                <div class="card-header bg-info text-white"><h6 class="mb-0">الموقع</h6></div>
                <div class="card-body p-0"><div id="map" style="height:300px;"></div></div>
            </div>
        }

        @if (Model.ChildOffices.Any())
        {
            <div class="card mb-4">
                <div class="card-header bg-secondary text-white"><h6 class="mb-0">المكاتب التابعة (@Model.ChildOffices.Count)</h6></div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        <thead><tr><th>الكود</th><th>الاسم</th><th>النوع</th></tr></thead>
                        <tbody>
                            @foreach(var child in Model.ChildOffices)
                            {<tr><td>@child.Code</td><td><a asp-action="Details" asp-route-id="@child.Id">@child.NameAr</a></td><td>@child.OfficeType?.NameAr</td></tr>}
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>

    <div class="col-lg-4">
        <div class="card mb-4">
            <div class="card-header bg-primary text-white"><h6 class="mb-0">بيانات التواصل</h6></div>
            <div class="card-body">
                <p><i class="fas fa-phone me-2 text-muted"></i>@(Model.Phone ?? "-")</p>
                <p><i class="fas fa-envelope me-2 text-muted"></i>@(Model.Email ?? "-")</p>
                <p><i class="fas fa-user me-2 text-muted"></i>المدير: @(Model.ManagerName ?? "-")</p>
                <p><i class="fas fa-mobile me-2 text-muted"></i>هاتف المدير: @(Model.ManagerPhone ?? "-")</p>
            </div>
        </div>

        <div class="card">
            <div class="card-header bg-light"><h6 class="mb-0">التدقيق</h6></div>
            <div class="card-body small">
                <p><strong>تاريخ الإنشاء:</strong> @Model.CreatedAt.ToString("yyyy/MM/dd")</p>
                <p><strong>أنشئ بواسطة:</strong> @(Model.CreatedBy ?? "-")</p>
            </div>
        </div>
    </div>
</div>

@if (Model.Location != null)
{
    @section Scripts {
    <script>
        var map = L.map('map').setView([@Model.Location.Y, @Model.Location.X], 15);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
        L.marker([@Model.Location.Y, @Model.Location.X]).addTo(map).bindPopup('@Model.NameAr').openPopup();
    </script>
    }
}
