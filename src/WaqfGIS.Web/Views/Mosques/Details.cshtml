@model Mosque
@{
    ViewData["Title"] = $"تفاصيل - {Model.NameAr}";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0"><i class="fas fa-mosque text-primary me-2"></i>@Model.NameAr</h4>
        <small class="text-muted">@Model.Code</small>
    </div>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
            <i class="fas fa-edit me-2"></i>تعديل
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-right me-2"></i>العودة للقائمة
        </a>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <!-- Basic Info -->
        <div class="card mb-4">
            <div class="card-header bg-primary text-white">
                <h6 class="mb-0"><i class="fas fa-info-circle me-2"></i>البيانات الأساسية</h6>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="text-muted small">الاسم بالعربية</label>
                        <p class="mb-0 fw-bold">@Model.NameAr</p>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="text-muted small">الاسم بالإنجليزية</label>
                        <p class="mb-0">@(Model.NameEn ?? "-")</p>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="text-muted small">نوع المسجد</label>
                        <p class="mb-0"><span class="badge bg-primary">@Model.MosqueType?.NameAr</span></p>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="text-muted small">الحالة</label>
                        <p class="mb-0">
                            <span class="badge" style="background-color: @(Model.MosqueStatus?.ColorCode ?? "#6c757d")">
                                @(Model.MosqueStatus?.NameAr ?? "غير محدد")
                            </span>
                        </p>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="text-muted small">المحافظة</label>
                        <p class="mb-0">@Model.Province?.NameAr</p>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="text-muted small">الدائرة الوقفية</label>
                        <p class="mb-0">@Model.WaqfOffice?.NameAr</p>
                    </div>
                    <div class="col-12">
                        <label class="text-muted small">العنوان</label>
                        <p class="mb-0">@(Model.Address ?? "-")</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Location Map -->
        <div class="card mb-4">
            <div class="card-header bg-success text-white">
                <h6 class="mb-0"><i class="fas fa-map-marker-alt me-2"></i>الموقع على الخريطة</h6>
            </div>
            <div class="card-body p-0">
                <div id="detailsMap" style="height: 300px;"></div>
            </div>
        </div>

        <!-- Specifications -->
        <div class="card mb-4">
            <div class="card-header bg-info text-white">
                <h6 class="mb-0"><i class="fas fa-cogs me-2"></i>المواصفات</h6>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="text-muted small">السعة</label>
                        <p class="mb-0 fw-bold">@(Model.Capacity?.ToString("N0") ?? "-") مصلي</p>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="text-muted small">المساحة</label>
                        <p class="mb-0">@(Model.AreaSqm?.ToString("N2") ?? "-") م²</p>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="text-muted small">سنة التأسيس</label>
                        <p class="mb-0">@(Model.EstablishedYear?.ToString() ?? "-")</p>
                    </div>
                </div>
                <hr>
                <div class="row">
                    <div class="col-md-4">
                        <span class="@(Model.HasFridayPrayer ? "text-success" : "text-muted")">
                            <i class="fas @(Model.HasFridayPrayer ? "fa-check-circle" : "fa-times-circle") me-1"></i>
                            صلاة الجمعة
                        </span>
                    </div>
                    <div class="col-md-4">
                        <span class="@(Model.HasMinaret ? "text-success" : "text-muted")">
                            <i class="fas @(Model.HasMinaret ? "fa-check-circle" : "fa-times-circle") me-1"></i>
                            مئذنة
                        </span>
                    </div>
                    <div class="col-md-4">
                        <span class="@(Model.HasDome ? "text-success" : "text-muted")">
                            <i class="fas @(Model.HasDome ? "fa-check-circle" : "fa-times-circle") me-1"></i>
                            قبة
                        </span>
                    </div>
                    <div class="col-md-4">
                        <span class="@(Model.HasParking ? "text-success" : "text-muted")">
                            <i class="fas @(Model.HasParking ? "fa-check-circle" : "fa-times-circle") me-1"></i>
                            موقف سيارات
                        </span>
                    </div>
                    <div class="col-md-4">
                        <span class="@(Model.HasWomenSection ? "text-success" : "text-muted")">
                            <i class="fas @(Model.HasWomenSection ? "fa-check-circle" : "fa-times-circle") me-1"></i>
                            قسم نسائي
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Sidebar -->
    <div class="col-lg-4">
        <!-- Imam Info -->
        <div class="card mb-4">
            <div class="card-header bg-warning">
                <h6 class="mb-0"><i class="fas fa-user me-2"></i>بيانات الإمام</h6>
            </div>
            <div class="card-body">
                <p class="mb-2"><strong>الاسم:</strong> @(Model.ImamName ?? "-")</p>
                <p class="mb-0"><strong>الهاتف:</strong> @(Model.ImamPhone ?? "-")</p>
            </div>
        </div>

        <!-- Coordinates -->
        <div class="card mb-4">
            <div class="card-header bg-secondary text-white">
                <h6 class="mb-0"><i class="fas fa-crosshairs me-2"></i>الإحداثيات</h6>
            </div>
            <div class="card-body">
                <p class="mb-2"><strong>خط العرض:</strong> @Model.Location?.Y.ToString("F6")</p>
                <p class="mb-0"><strong>خط الطول:</strong> @Model.Location?.X.ToString("F6")</p>
            </div>
        </div>

        <!-- Audit Info -->
        <div class="card">
            <div class="card-header bg-light">
                <h6 class="mb-0"><i class="fas fa-history me-2"></i>معلومات التدقيق</h6>
            </div>
            <div class="card-body small">
                <p class="mb-2"><strong>تاريخ الإنشاء:</strong> @Model.CreatedAt.ToString("yyyy/MM/dd HH:mm")</p>
                <p class="mb-2"><strong>أنشئ بواسطة:</strong> @(Model.CreatedBy ?? "-")</p>
                @if (Model.UpdatedAt.HasValue)
                {
                    <p class="mb-2"><strong>آخر تعديل:</strong> @Model.UpdatedAt.Value.ToString("yyyy/MM/dd HH:mm")</p>
                    <p class="mb-0"><strong>عدّل بواسطة:</strong> @(Model.UpdatedBy ?? "-")</p>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var lat = @Model.Location?.Y.ToString(System.Globalization.CultureInfo.InvariantCulture);
        var lng = @Model.Location?.X.ToString(System.Globalization.CultureInfo.InvariantCulture);
        
        var map = L.map('detailsMap').setView([lat, lng], 15);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
        L.marker([lat, lng]).addTo(map).bindPopup('<strong>@Model.NameAr</strong>').openPopup();
    </script>
}
