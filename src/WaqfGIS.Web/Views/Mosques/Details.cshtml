@model Mosque
@using WaqfGIS.Core.Entities
@{
    ViewData["Title"] = "تفاصيل المسجد";
    var images = ViewBag.Images as IEnumerable<MosqueImage> ?? new List<MosqueImage>();
    var mainImage = images.FirstOrDefault(i => i.IsMain) ?? images.FirstOrDefault();
    var boundaryGeoJson = ViewBag.BoundaryGeoJson as string;
    var boundaryArea = ViewBag.BoundaryArea as double?;
    var regFiles = ViewBag.RegistrationFiles as IEnumerable<MosqueRegistrationFile> ?? new List<MosqueRegistrationFile>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0"><i class="fas fa-mosque text-primary me-2"></i>@Model.NameAr</h4>
        <small class="text-muted">@Model.NameEn</small>
    </div>
    <div>
        @if (ViewBag.CanEdit == true)
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary me-1"><i class="fas fa-edit me-1"></i>تعديل</a>
            <a asp-controller="Encroachements" asp-action="Create" asp-route-entityType="Mosque" asp-route-entityId="@Model.Id" class="btn btn-outline-danger me-1" title="تسجيل تجاوز جديد"><i class="fas fa-exclamation-triangle me-1"></i>تسجيل تجاوز</a>
        }
        <a asp-controller="Encroachements" asp-action="Index" asp-route-entityType="Mosque" class="btn btn-outline-warning me-1"><i class="fas fa-list me-1"></i>سجل التجاوزات</a>
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-right me-1"></i>العودة</a>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        @if (mainImage != null)
        {
            <div class="card mb-4">
                <img src="@mainImage.FilePath" class="card-img-top" style="height:350px;object-fit:cover;cursor:pointer;" onclick="showImage('@mainImage.FilePath')" />
            </div>
        }

        <div class="card mb-4">
            <div class="card-header bg-primary text-white"><h6 class="mb-0"><i class="fas fa-info-circle me-2"></i>البيانات الأساسية</h6></div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 mb-3"><label class="text-muted small">الاسم بالعربية</label><p class="fw-bold mb-0">@Model.NameAr</p></div>
                    <div class="col-md-6 mb-3"><label class="text-muted small">الاسم بالإنجليزية</label><p class="mb-0">@(Model.NameEn ?? "-")</p></div>
                    <div class="col-md-4 mb-3"><label class="text-muted small">نوع المسجد</label><p class="mb-0"><span class="badge bg-primary">@(Model.MosqueType?.NameAr ?? "-")</span></p></div>
                    <div class="col-md-4 mb-3"><label class="text-muted small">الحالة</label><p class="mb-0"><span class="badge" style="background-color:@(Model.MosqueStatus?.ColorCode ?? "#6c757d")">@(Model.MosqueStatus?.NameAr ?? "غير محدد")</span></p></div>
                    <div class="col-md-4 mb-3"><label class="text-muted small">الكود</label><p class="mb-0 font-monospace">@Model.Code</p></div>
                    <div class="col-md-4 mb-3"><label class="text-muted small">المحافظة</label><p class="mb-0">@(Model.Province?.NameAr ?? "-")</p></div>
                    <div class="col-md-4 mb-3"><label class="text-muted small">القضاء</label><p class="mb-0">@(Model.District?.NameAr ?? "-")</p></div>
                    <div class="col-md-4 mb-3"><label class="text-muted small">الدائرة الوقفية</label><p class="mb-0">@(Model.WaqfOffice?.NameAr ?? "-")</p></div>
                    <div class="col-12 mb-3"><label class="text-muted small">العنوان</label><p class="mb-0">@(Model.Address ?? "-")</p></div>
                    <div class="col-md-6 mb-3"><label class="text-muted small">الحي/المنطقة</label><p class="mb-0">@(Model.Neighborhood ?? "-")</p></div>
                    <div class="col-md-6 mb-3"><label class="text-muted small">أقرب معلم</label><p class="mb-0">@(Model.NearestLandmark ?? "-")</p></div>
                </div>
            </div>
        </div>

        <!-- الموقع والحدود -->
        <div class="card mb-4">
            <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="fas fa-map-marker-alt me-2"></i>الموقع وحدود المسجد</h6>
                <div class="btn-group btn-group-sm">
                    <button type="button" class="btn btn-light" onclick="setBaseMap('osm')"><i class="fas fa-map"></i></button>
                    <button type="button" class="btn btn-light" onclick="setBaseMap('satellite')"><i class="fas fa-satellite"></i></button>
                </div>
            </div>
            <div class="card-body p-0">
                <div id="map" style="height:400px;"></div>
            </div>
            <div class="card-footer">
                <div class="row">
                    <div class="col-md-6">
                        <small><strong>الإحداثيات:</strong> @Model.Location?.Y.ToString("F6"), @Model.Location?.X.ToString("F6")</small>
                    </div>
                    <div class="col-md-6 text-end">
                        @if (boundaryArea.HasValue)
                        {
                            <span class="badge bg-success"><i class="fas fa-draw-polygon me-1"></i>مساحة الحدود: @boundaryArea.Value.ToString("N0") م²</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark"><i class="fas fa-exclamation-triangle me-1"></i>لم يتم رسم الحدود</span>
                        }
                        <a href="https://www.google.com/maps?q=@Model.Location?.Y,@Model.Location?.X" target="_blank" class="btn btn-sm btn-outline-success ms-2">
                            <i class="fas fa-external-link-alt"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header bg-info text-white"><h6 class="mb-0"><i class="fas fa-cogs me-2"></i>المواصفات والمرافق</h6></div>
            <div class="card-body">
                <div class="row mb-4">
                    <div class="col-md-3 text-center border-end"><h3 class="text-primary mb-0">@(Model.Capacity?.ToString("N0") ?? "-")</h3><small class="text-muted">مصلي</small></div>
                    <div class="col-md-3 text-center border-end"><h3 class="text-success mb-0">@(Model.AreaSqm?.ToString("N0") ?? "-")</h3><small class="text-muted">م²</small></div>
                    <div class="col-md-3 text-center border-end"><h3 class="text-info mb-0">@(Model.EstablishedYear?.ToString() ?? "-")</h3><small class="text-muted">سنة التأسيس</small></div>
                    <div class="col-md-3 text-center"><h3 class="text-warning mb-0">@(Model.LastRenovationYear?.ToString() ?? "-")</h3><small class="text-muted">آخر ترميم</small></div>
                </div>
                <hr>
                <h6 class="mb-3">المرافق</h6>
                <div class="row">
                    <div class="col-md-3 mb-2">@(Model.HasFridayPrayer ? "✅" : "❌") صلاة الجمعة</div>
                    <div class="col-md-3 mb-2">@(Model.HasMinaret ? "✅" : "❌") مئذنة</div>
                    <div class="col-md-3 mb-2">@(Model.HasDome ? "✅" : "❌") قبة</div>
                    <div class="col-md-3 mb-2">@(Model.HasParking ? "✅" : "❌") موقف سيارات</div>
                    <div class="col-md-3 mb-2">@(Model.HasWomenSection ? "✅" : "❌") قسم نسائي</div>
                    <div class="col-md-3 mb-2">@(Model.HasAirConditioning ? "✅" : "❌") تكييف</div>
                    <div class="col-md-3 mb-2">@(Model.HasAblutionFacility ? "✅" : "❌") مرافق وضوء</div>
                    <div class="col-md-3 mb-2">@(Model.HasLibrary ? "✅" : "❌") مكتبة</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card mb-4">
            <div class="card-header bg-warning"><h6 class="mb-0"><i class="fas fa-user-tie me-2"></i>بيانات الإمام</h6></div>
            <div class="card-body">
                <p class="mb-1"><strong>الاسم:</strong> @(Model.ImamName ?? "-")</p>
                <p class="mb-0"><strong>الهاتف:</strong> @if (!string.IsNullOrEmpty(Model.ImamPhone)){<a href="tel:@Model.ImamPhone" dir="ltr">@Model.ImamPhone</a>} else {<span>-</span>}</p>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header bg-secondary text-white"><h6 class="mb-0"><i class="fas fa-user me-2"></i>بيانات المؤذن</h6></div>
            <div class="card-body">
                <p class="mb-1"><strong>الاسم:</strong> @(Model.MuezzinName ?? "-")</p>
                <p class="mb-0"><strong>الهاتف:</strong> @if (!string.IsNullOrEmpty(Model.MuezzinPhone)){<a href="tel:@Model.MuezzinPhone" dir="ltr">@Model.MuezzinPhone</a>} else {<span>-</span>}</p>
            </div>
        </div>

        @if (images.Any())
        {
            <div class="card mb-4">
                <div class="card-header bg-info text-white"><h6 class="mb-0"><i class="fas fa-images me-2"></i>صور المسجد (@images.Count())</h6></div>
                <div class="card-body">
                    <div class="row g-2">
                        @foreach (var img in images){
                            <div class="col-4"><img src="@img.FilePath" class="img-fluid rounded @(img.IsMain ? "border border-2 border-primary" : "")" style="height:70px;width:100%;object-fit:cover;cursor:pointer;" onclick="showImage('@img.FilePath')" /></div>
                        }
                    </div>
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.Notes))
        {
            <div class="card mb-4">
                <div class="card-header bg-light"><h6 class="mb-0"><i class="fas fa-sticky-note me-2"></i>ملاحظات</h6></div>
                <div class="card-body"><p class="mb-0">@Model.Notes</p></div>
            </div>
        }

        <!-- مستندات وملفات التسجيل -->
        <div class="card mb-3">
            <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="fas fa-file-alt me-2"></i>مستندات وملفات التسجيل</h6>
                <span class="badge bg-dark">@regFiles.Count()</span>
            </div>
            <div class="card-body">
                @if (regFiles.Any())
                {
                    <div class="list-group list-group-flush">
                        @foreach (var rf in regFiles)
                        {
                            var icon = rf.MimeType != null && rf.MimeType.Contains("pdf") ? "fa-file-pdf text-danger" :
                                       rf.MimeType != null && (rf.MimeType.Contains("word") || rf.MimeType.Contains("doc")) ? "fa-file-word text-primary" :
                                       rf.MimeType != null && rf.MimeType.Contains("image") ? "fa-file-image text-success" :
                                       rf.MimeType != null && rf.MimeType.Contains("sheet") ? "fa-file-excel text-success" : "fa-file text-secondary";
                            var sizeKb = rf.FileSize.HasValue ? (rf.FileSize.Value / 1024.0).ToString("F1") + " KB" : "";
                            <div class="list-group-item px-0 py-2">
                                <div class="d-flex align-items-center justify-content-between">
                                    <div>
                                        <i class="fas @icon me-2"></i>
                                        <a href="@rf.FilePath" target="_blank" class="text-decoration-none fw-bold">@rf.FileName</a>
                                        <br/>
                                        <small class="text-muted ms-4">
                                            <span class="badge bg-secondary me-1">@rf.DocumentType</span>
                                            @rf.UploadedAt.ToLocalTime().ToString("dd/MM/yyyy")
                                            @if (!string.IsNullOrEmpty(sizeKb)) { <text> · @sizeKb</text> }
                                        </small>
                                    </div>
                                    <a href="@rf.FilePath" target="_blank" class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-download"></i>
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center text-muted py-3">
                        <i class="fas fa-folder-open fa-2x mb-2 d-block"></i>
                        <small>لا توجد مستندات مرفقة</small>
                    </div>
                }
                <div class="mt-2 text-end">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-warning">
                        <i class="fas fa-paperclip me-1"></i>إضافة مستندات
                    </a>
                </div>
            </div>
        </div>

        <!-- أهلية الوقف وبيانات الواقف -->
        <div class="card mb-4">
            <div class="card-header" style="background:#6f42c1;color:#fff"><h6 class="mb-0"><i class="fas fa-clipboard-check me-2"></i>أهلية الوقف وبيانات الواقف</h6></div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-6">
                        <label class="text-muted small">طبيعة الوقف</label>
                        <p class="mb-0">
                            @if (Model.WaqfNature == "Ahli") { <span class="badge bg-warning text-dark">أهلي</span> } else { <span class="badge bg-success">خيري</span> }
                        </p>
                    </div>
                    <div class="col-6">
                        <label class="text-muted small">شرط الوقف</label>
                        <p class="mb-0">
                            @if (Model.WaqfCondition == "WithCondition") { <span class="badge bg-info">بشرط</span> } else { <span class="badge bg-secondary">بدون شرط</span> }
                        </p>
                    </div>
                    @if (Model.WaqfNature == "Ahli") {
                    <div class="col-12 mt-2">
                        <label class="text-muted small">مستلمة إدارياً</label>
                        <p class="mb-0">@(Model.IsAdminReceived == true ? "✅ نعم" : Model.IsAdminReceived == false ? "❌ لا" : "-")</p>
                    </div>
                    }
                </div>
                <div class="row">
                    <div class="col-6">
                        <label class="text-muted small"><i class="fas fa-exclamation-triangle text-danger me-1"></i>مغتصب</label>
                        <p class="mb-0">@(Model.IsUsurped ? "<span class='badge bg-danger'>نعم</span>" : "<span class='badge bg-light text-dark'>لا</span>")</p>
                    </div>
                    <div class="col-6">
                        <label class="text-muted small"><i class="fas fa-lock text-warning me-1"></i>مغلق</label>
                        <p class="mb-0">@(Model.IsClosed ? "<span class='badge bg-warning text-dark'>نعم</span>" : "<span class='badge bg-light text-dark'>لا</span>")</p>
                    </div>
                    <div class="col-6 mt-2">
                        <label class="text-muted small"><i class="fas fa-gavel text-info me-1"></i>متنازع عليه</label>
                        <p class="mb-0">@(Model.IsContested ? "<span class='badge bg-info'>نعم</span>" : "<span class='badge bg-light text-dark'>لا</span>")</p>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(Model.WaqifName) || Model.WaqfDocumentDate.HasValue || !string.IsNullOrEmpty(Model.WaqfDocumentNumber)) {
                <hr />
                <h6 class="text-muted small fw-bold"><i class="fas fa-user-shield me-1"></i>بيانات الواقف الأصلي</h6>
                <div class="row">
                    @if (!string.IsNullOrEmpty(Model.WaqifName)) {
                    <div class="col-12 mb-2"><label class="text-muted small">اسم الواقف</label><p class="mb-0 fw-bold">@Model.WaqifName</p></div>
                    }
                    @if (Model.WaqfDocumentDate.HasValue) {
                    <div class="col-6 mb-2"><label class="text-muted small">تاريخ الوثيقة</label><p class="mb-0">@Model.WaqfDocumentDate.Value.ToString("dd/MM/yyyy")</p></div>
                    }
                    @if (!string.IsNullOrEmpty(Model.WaqfDocumentNumber)) {
                    <div class="col-6 mb-2"><label class="text-muted small">رقم الوثيقة</label><p class="mb-0 font-monospace">@Model.WaqfDocumentNumber</p></div>
                    }
                </div>
                }
                @if (Model.WaqfCondition == "WithCondition" && !string.IsNullOrEmpty(Model.WaqfConditionText)) {
                <div class="mt-2 p-2 bg-info bg-opacity-10 border border-info rounded">
                    <small class="text-info fw-bold"><i class="fas fa-scroll me-1"></i>نص شرط الواقف:</small>
                    <p class="mb-0 mt-1 small" style="white-space:pre-wrap;">@Model.WaqfConditionText</p>
                </div>
                }
            </div>
        </div>

        <div class="card">
            <div class="card-header bg-dark text-white"><h6 class="mb-0"><i class="fas fa-info me-2"></i>معلومات النظام</h6></div>
            <div class="card-body small">
                <p class="mb-1"><strong>تاريخ الإنشاء:</strong> @Model.CreatedAt.ToString("yyyy/MM/dd HH:mm")</p>
                <p class="mb-1"><strong>أنشأ بواسطة:</strong> @(Model.CreatedBy ?? "-")</p>
                @if (Model.UpdatedAt.HasValue){
                    <p class="mb-1"><strong>آخر تحديث:</strong> @Model.UpdatedAt.Value.ToString("yyyy/MM/dd HH:mm")</p>
                    <p class="mb-0"><strong>حُدث بواسطة:</strong> @(Model.UpdatedBy ?? "-")</p>
                }
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="imageModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content bg-transparent border-0">
            <div class="modal-body p-0 text-center">
                <img id="modalImage" src="" class="img-fluid" style="max-height:90vh;" />
                <button type="button" class="btn btn-light position-absolute top-0 end-0 m-2" data-bs-dismiss="modal"><i class="fas fa-times"></i></button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
var lat = @(Model.Location?.Y.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "33.3");
var lng = @(Model.Location?.X.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "44.4");
var boundaryGeoJson = @Html.Raw(boundaryGeoJson ?? "null");

var osmLayer = L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '© OpenStreetMap' });
var satelliteLayer = L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', { attribution: '© Esri' });

var map = L.map('map', { layers: [satelliteLayer] }).setView([lat, lng], 18);
L.marker([lat, lng]).addTo(map).bindPopup('<strong>@Model.NameAr</strong>').openPopup();

if (boundaryGeoJson) {
    var boundaryLayer = L.geoJSON(boundaryGeoJson, {
        style: { color: '#1565c0', fillColor: '#1e88e5', fillOpacity: 0.4, weight: 3 }
    }).addTo(map);
    map.fitBounds(boundaryLayer.getBounds());
}

function setBaseMap(type) {
    map.removeLayer(osmLayer); map.removeLayer(satelliteLayer);
    if (type === 'osm') map.addLayer(osmLayer);
    else map.addLayer(satelliteLayer);
}

function showImage(src) {
    document.getElementById('modalImage').src = src;
    new bootstrap.Modal(document.getElementById('imageModal')).show();
}
</script>
}
