@model MosqueViewModel
@{
    ViewData["Title"] = "تعديل مسجد";
    var images = ViewBag.Images as IEnumerable<MosqueImage> ?? new List<MosqueImage>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0"><i class="fas fa-edit text-primary me-2"></i>تعديل بيانات المسجد</h4>
        <small class="text-muted">@Model.NameAr</small>
    </div>
    <div>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-info me-2"><i class="fas fa-eye me-1"></i>عرض</a>
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-right me-1"></i>العودة</a>
    </div>
</div>

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />
    <div class="row">
        <div class="col-lg-8">
            <!-- البيانات الأساسية -->
            <div class="card mb-4">
                <div class="card-header bg-primary text-white"><h6 class="mb-0"><i class="fas fa-info-circle me-2"></i>البيانات الأساسية</h6></div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="NameAr" class="form-label"></label>
                            <input asp-for="NameAr" class="form-control" />
                            <span asp-validation-for="NameAr" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NameEn" class="form-label"></label>
                            <input asp-for="NameEn" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="MosqueTypeId" class="form-label"></label>
                            <select asp-for="MosqueTypeId" class="form-select" asp-items="@ViewBag.MosqueTypes">
                                <option value="">-- اختر --</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="MosqueStatusId" class="form-label"></label>
                            <select asp-for="MosqueStatusId" class="form-select" asp-items="@ViewBag.MosqueStatuses">
                                <option value="">-- اختر --</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="WaqfOfficeId" class="form-label"></label>
                            <select asp-for="WaqfOfficeId" class="form-select" asp-items="@ViewBag.WaqfOffices">
                                <option value="">-- اختر --</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ProvinceId" class="form-label"></label>
                            <select asp-for="ProvinceId" class="form-select" asp-items="@ViewBag.Provinces">
                                <option value="">-- اختر --</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DistrictId" class="form-label"></label>
                            <select asp-for="DistrictId" class="form-select" asp-items="@ViewBag.Districts">
                                <option value="">-- اختر --</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label asp-for="Address" class="form-label"></label>
                            <textarea asp-for="Address" class="form-control" rows="2"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Neighborhood" class="form-label"></label>
                            <input asp-for="Neighborhood" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NearestLandmark" class="form-label"></label>
                            <input asp-for="NearestLandmark" class="form-control" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- الموقع -->
            <div class="card mb-4">
                <div class="card-header bg-success text-white"><h6 class="mb-0"><i class="fas fa-map-marker-alt me-2"></i>الموقع</h6></div>
                <div class="card-body">
                    <div id="locationMap" style="height:300px;" class="mb-3"></div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Latitude" class="form-label"></label>
                            <input asp-for="Latitude" id="latitude" class="form-control" readonly />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Longitude" class="form-label"></label>
                            <input asp-for="Longitude" id="longitude" class="form-control" readonly />
                        </div>
                    </div>
                </div>
            </div>

            <!-- المواصفات -->
            <div class="card mb-4">
                <div class="card-header bg-info text-white"><h6 class="mb-0"><i class="fas fa-cogs me-2"></i>المواصفات</h6></div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label asp-for="Capacity" class="form-label"></label>
                            <input asp-for="Capacity" class="form-control" type="number" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="AreaSqm" class="form-label"></label>
                            <input asp-for="AreaSqm" class="form-control" type="number" step="0.01" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="EstablishedYear" class="form-label"></label>
                            <input asp-for="EstablishedYear" class="form-control" type="number" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="LastRenovationYear" class="form-label"></label>
                            <input asp-for="LastRenovationYear" class="form-control" type="number" />
                        </div>
                    </div>
                    <hr>
                    <div class="row">
                        <div class="col-md-3"><div class="form-check"><input asp-for="HasFridayPrayer" class="form-check-input" /><label asp-for="HasFridayPrayer" class="form-check-label"></label></div></div>
                        <div class="col-md-3"><div class="form-check"><input asp-for="HasMinaret" class="form-check-input" /><label asp-for="HasMinaret" class="form-check-label"></label></div></div>
                        <div class="col-md-3"><div class="form-check"><input asp-for="HasDome" class="form-check-input" /><label asp-for="HasDome" class="form-check-label"></label></div></div>
                        <div class="col-md-3"><div class="form-check"><input asp-for="HasParking" class="form-check-input" /><label asp-for="HasParking" class="form-check-label"></label></div></div>
                        <div class="col-md-3"><div class="form-check"><input asp-for="HasWomenSection" class="form-check-input" /><label asp-for="HasWomenSection" class="form-check-label"></label></div></div>
                        <div class="col-md-3"><div class="form-check"><input asp-for="HasAirConditioning" class="form-check-input" /><label asp-for="HasAirConditioning" class="form-check-label"></label></div></div>
                        <div class="col-md-3"><div class="form-check"><input asp-for="HasWuduArea" class="form-check-input" /><label asp-for="HasWuduArea" class="form-check-label"></label></div></div>
                        <div class="col-md-3"><div class="form-check"><input asp-for="HasLibrary" class="form-check-input" /><label asp-for="HasLibrary" class="form-check-label"></label></div></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <!-- بيانات الإمام -->
            <div class="card mb-4">
                <div class="card-header bg-warning"><h6 class="mb-0"><i class="fas fa-user-tie me-2"></i>بيانات الإمام</h6></div>
                <div class="card-body">
                    <div class="mb-3"><label asp-for="ImamName" class="form-label"></label><input asp-for="ImamName" class="form-control" /></div>
                    <div class="mb-3"><label asp-for="ImamPhone" class="form-label"></label><input asp-for="ImamPhone" class="form-control" dir="ltr" /></div>
                </div>
            </div>

            <!-- بيانات المؤذن -->
            <div class="card mb-4">
                <div class="card-header bg-secondary text-white"><h6 class="mb-0"><i class="fas fa-user me-2"></i>بيانات المؤذن</h6></div>
                <div class="card-body">
                    <div class="mb-3"><label asp-for="MuezzinName" class="form-label"></label><input asp-for="MuezzinName" class="form-control" /></div>
                    <div class="mb-3"><label asp-for="MuezzinPhone" class="form-label"></label><input asp-for="MuezzinPhone" class="form-control" dir="ltr" /></div>
                </div>
            </div>

            <!-- صور المسجد -->
            <div class="card mb-4">
                <div class="card-header bg-info text-white"><h6 class="mb-0"><i class="fas fa-images me-2"></i>صور المسجد (@images.Count())</h6></div>
                <div class="card-body">
                    @if (images.Any())
                    {
                        <div class="row g-2 mb-3">
                            @foreach (var img in images)
                            {
                                <div class="col-6">
                                    <div class="position-relative">
                                        <img src="@img.FilePath" class="img-fluid rounded @(img.IsMain ? "border border-3 border-primary" : "")" 
                                             style="height:80px;width:100%;object-fit:cover;cursor:pointer;" onclick="showImage('@img.FilePath')" />
                                        @if (img.IsMain)
                                        {<span class="badge bg-primary position-absolute top-0 start-0 m-1" style="font-size:10px;">رئيسية</span>}
                                        <div class="position-absolute bottom-0 start-0 end-0 bg-dark bg-opacity-75 p-1 text-center">
                                            <form asp-action="SetMainImage" method="post" class="d-inline">
                                                <input type="hidden" name="imageId" value="@img.Id" />
                                                <input type="hidden" name="mosqueId" value="@Model.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-light p-0 px-1" title="رئيسية"><i class="fas fa-star" style="font-size:10px;"></i></button>
                                            </form>
                                            <form asp-action="DeleteImage" method="post" class="d-inline" onsubmit="return confirm('حذف؟')">
                                                <input type="hidden" name="imageId" value="@img.Id" />
                                                <input type="hidden" name="mosqueId" value="@Model.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger p-0 px-1"><i class="fas fa-trash" style="font-size:10px;"></i></button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    <label class="form-label">إضافة صور جديدة</label>
                    <input type="file" name="images" class="form-control form-control-sm" multiple accept="image/*" onchange="previewImages(this)" />
                    <div id="imagePreview" class="row g-2 mt-2"></div>
                </div>
            </div>

            <!-- ملاحظات -->
            <div class="card mb-4">
                <div class="card-header bg-light"><h6 class="mb-0"><i class="fas fa-sticky-note me-2"></i>ملاحظات</h6></div>
                <div class="card-body"><textarea asp-for="Notes" class="form-control" rows="3"></textarea></div>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary btn-lg"><i class="fas fa-save me-2"></i>حفظ التعديلات</button>
                <a asp-action="Index" class="btn btn-outline-secondary">إلغاء</a>
            </div>
        </div>
    </div>
</form>

<!-- Modal لعرض الصور -->
<div class="modal fade" id="imageModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content bg-transparent border-0">
            <div class="modal-body p-0 text-center">
                <img id="modalImage" src="" class="img-fluid" style="max-height:90vh;" />
                <button type="button" class="btn btn-light position-absolute top-0 end-0 m-2" data-bs-dismiss="modal"><i class="fas fa-times"></i></button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    var lat = @Model.Latitude.ToString(System.Globalization.CultureInfo.InvariantCulture);
    var lng = @Model.Longitude.ToString(System.Globalization.CultureInfo.InvariantCulture);
    var map = L.map('locationMap').setView([lat, lng], 15);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
    var marker = L.marker([lat, lng], {draggable:true}).addTo(map);
    marker.on('dragend', function(){ var ll = marker.getLatLng(); document.getElementById('latitude').value = ll.lat.toFixed(6); document.getElementById('longitude').value = ll.lng.toFixed(6); });
    map.on('click', function(e){ marker.setLatLng(e.latlng); document.getElementById('latitude').value = e.latlng.lat.toFixed(6); document.getElementById('longitude').value = e.latlng.lng.toFixed(6); });

    function previewImages(input) {
        var preview = document.getElementById('imagePreview');
        preview.innerHTML = '';
        if (input.files) {
            Array.from(input.files).forEach(function(file) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    preview.innerHTML += '<div class="col-6"><img src="'+e.target.result+'" class="img-fluid rounded" style="height:60px;width:100%;object-fit:cover;cursor:pointer;" onclick="showImage(\''+e.target.result+'\')"></div>';
                };
                reader.readAsDataURL(file);
            });
        }
    }

    function showImage(src) {
        document.getElementById('modalImage').src = src;
        new bootstrap.Modal(document.getElementById('imageModal')).show();
    }
</script>
}
