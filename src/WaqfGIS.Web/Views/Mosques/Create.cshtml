@model MosqueViewModel
@{
    ViewData["Title"] = "إضافة مسجد جديد";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0"><i class="fas fa-plus text-primary me-2"></i>إضافة مسجد جديد</h4>
        <small class="text-muted">إدخال بيانات المسجد</small>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-right me-1"></i>العودة</a>
</div>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    <div class="row">
        <div class="col-lg-8">
            <!-- البيانات الأساسية -->
            <div class="card mb-4">
                <div class="card-header bg-primary text-white"><h6 class="mb-0"><i class="fas fa-info-circle me-2"></i>البيانات الأساسية</h6></div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="NameAr" class="form-label"></label>
                            <input asp-for="NameAr" class="form-control" placeholder="مسجد..." />
                            <span asp-validation-for="NameAr" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NameEn" class="form-label"></label>
                            <input asp-for="NameEn" class="form-control" placeholder="Mosque..." />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="MosqueTypeId" class="form-label"></label>
                            <select asp-for="MosqueTypeId" class="form-select" asp-items="@ViewBag.MosqueTypes">
                                <option value="">-- اختر النوع --</option>
                            </select>
                            <span asp-validation-for="MosqueTypeId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="MosqueStatusId" class="form-label"></label>
                            <select asp-for="MosqueStatusId" class="form-select" asp-items="@ViewBag.MosqueStatuses">
                                <option value="">-- اختر الحالة --</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="WaqfOfficeId" class="form-label"></label>
                            <select asp-for="WaqfOfficeId" class="form-select" asp-items="@ViewBag.WaqfOffices">
                                <option value="">-- اختر الدائرة --</option>
                            </select>
                            <span asp-validation-for="WaqfOfficeId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ProvinceId" class="form-label"></label>
                            <select asp-for="ProvinceId" class="form-select" asp-items="@ViewBag.Provinces">
                                <option value="">-- اختر المحافظة --</option>
                            </select>
                            <span asp-validation-for="ProvinceId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DistrictId" class="form-label"></label>
                            <select asp-for="DistrictId" class="form-select" asp-items="@ViewBag.Districts">
                                <option value="">-- اختر القضاء --</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label asp-for="Address" class="form-label"></label>
                            <textarea asp-for="Address" class="form-control" rows="2" placeholder="العنوان التفصيلي..."></textarea>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Neighborhood" class="form-label"></label>
                            <input asp-for="Neighborhood" class="form-control" placeholder="اسم الحي..." />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NearestLandmark" class="form-label"></label>
                            <input asp-for="NearestLandmark" class="form-control" placeholder="بالقرب من..." />
                        </div>
                    </div>
                </div>
            </div>

            <!-- الموقع الجغرافي -->
            <div class="card mb-4">
                <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                    <h6 class="mb-0"><i class="fas fa-map-marker-alt me-2"></i>الموقع الجغرافي</h6>
                    <div class="btn-group btn-group-sm">
                        <button type="button" class="btn btn-light" onclick="setCreateBaseMap('osm')" title="عادية"><i class="fas fa-map"></i></button>
                        <button type="button" class="btn btn-light" onclick="setCreateBaseMap('satellite')" title="فضائية"><i class="fas fa-satellite"></i></button>
                    </div>
                </div>
                <div class="card-body">
                    <!-- مساعد الإحداثيات - استخراج من رابط + إدخال يدوي -->
                    <div class="card mb-3 border-info">
                        <div class="card-header bg-info bg-opacity-10 py-2">
                            <h6 class="mb-0 text-info"><i class="fas fa-crosshairs me-2"></i>تحديد الموقع الجغرافي</h6>
                        </div>
                        <div class="card-body py-2">
                            <!-- استخراج من رابط -->
                            <div class="mb-3">
                                <label class="form-label small fw-bold">
                                    <i class="fab fa-google me-1"></i>استخراج من رابط خرائط Google أو Apple Maps
                                </label>
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text"><i class="fas fa-link"></i></span>
                                    <input type="text" id="mapsLink_mosque_create" class="form-control"
                                           placeholder="الصق رابط خرائط Google أو Apple هنا..."
                                           oninput="extractCoordsFromLink('mosque_create','latitude','longitude')" />
                                    <button type="button" class="btn btn-outline-success" onclick="extractCoordsFromLink('mosque_create','latitude','longitude')">
                                        <i class="fas fa-magic me-1"></i>استخراج
                                    </button>
                                    <button type="button" class="btn btn-outline-secondary" onclick="clearMapsLink('mosque_create')">
                                        <i class="fas fa-times"></i>
                                    </button>
                                </div>
                                <div id="linkResult_mosque_create" class="mt-1" style="display:none;"></div>
                            </div>
                            <!-- إدخال يدوي -->
                            <div class="row g-2">
                                <div class="col-md-5">
                                    <label class="form-label small"><i class="fas fa-arrows-alt-v text-danger me-1"></i>خط العرض (Latitude)</label>
                                    <div class="input-group input-group-sm">
                                        <input asp-for="Latitude" id="latitude" class="form-control"
                                               placeholder="33.315000"
                                               oninput="onManualCoordInput('mosque_create','latitude','longitude')" />
                                        <span class="input-group-text">°N</span>
                                    </div>
                                    <span asp-validation-for="Latitude" class="text-danger small"></span>
                                </div>
                                <div class="col-md-5">
                                    <label class="form-label small"><i class="fas fa-arrows-alt-h text-primary me-1"></i>خط الطول (Longitude)</label>
                                    <div class="input-group input-group-sm">
                                        <input asp-for="Longitude" id="longitude" class="form-control"
                                               placeholder="44.361000"
                                               oninput="onManualCoordInput('mosque_create','latitude','longitude')" />
                                        <span class="input-group-text">°E</span>
                                    </div>
                                    <span asp-validation-for="Longitude" class="text-danger small"></span>
                                </div>
                                <div class="col-md-2 d-flex align-items-end">
                                    <button type="button" class="btn btn-sm btn-primary w-100"
                                            onclick="goToManualCoords('mosque_create','latitude','longitude')" title="الذهاب للإحداثيات">
                                        <i class="fas fa-map-pin"></i>
                                    </button>
                                </div>
                            </div>
                            <small class="text-muted d-block mt-1">
                                <i class="fas fa-info-circle me-1"></i>
                                يمكن النقر على الخريطة أو إدخال الإحداثيات يدوياً أو لصق رابط خرائط
                            </small>
                        </div>
                    </div>
                    <div id="locationMap" style="height:320px;border-radius:8px;"></div>
                </div>
            </div>

            <!-- المواصفات -->
            <div class="card mb-4">
                <div class="card-header bg-info text-white"><h6 class="mb-0"><i class="fas fa-cogs me-2"></i>المواصفات</h6></div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label asp-for="Capacity" class="form-label"></label>
                            <input asp-for="Capacity" class="form-control" type="number" min="0" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="AreaSqm" class="form-label"></label>
                            <input asp-for="AreaSqm" class="form-control" type="number" step="0.01" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="EstablishedYear" class="form-label"></label>
                            <input asp-for="EstablishedYear" class="form-control" type="number" min="600" max="2030" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="LastRenovationYear" class="form-label"></label>
                            <input asp-for="LastRenovationYear" class="form-control" type="number" min="1900" max="2030" />
                        </div>
                    </div>
                    <hr>
                    <h6 class="mb-3">المرافق والخدمات</h6>
                    <div class="row">
                        <div class="col-md-3"><div class="form-check"><input asp-for="HasFridayPrayer" class="form-check-input" /><label asp-for="HasFridayPrayer" class="form-check-label"></label></div></div>
                        <div class="col-md-3"><div class="form-check"><input asp-for="HasMinaret" class="form-check-input" /><label asp-for="HasMinaret" class="form-check-label"></label></div></div>
                        <div class="col-md-3"><div class="form-check"><input asp-for="HasDome" class="form-check-input" /><label asp-for="HasDome" class="form-check-label"></label></div></div>
                        <div class="col-md-3"><div class="form-check"><input asp-for="HasParking" class="form-check-input" /><label asp-for="HasParking" class="form-check-label"></label></div></div>
                        <div class="col-md-3"><div class="form-check"><input asp-for="HasWomenSection" class="form-check-input" /><label asp-for="HasWomenSection" class="form-check-label"></label></div></div>
                        <div class="col-md-3"><div class="form-check"><input asp-for="HasAirConditioning" class="form-check-input" /><label asp-for="HasAirConditioning" class="form-check-label"></label></div></div>
                        <div class="col-md-3"><div class="form-check"><input asp-for="HasWuduArea" class="form-check-input" /><label asp-for="HasWuduArea" class="form-check-label"></label></div></div>
                        <div class="col-md-3"><div class="form-check"><input asp-for="HasLibrary" class="form-check-input" /><label asp-for="HasLibrary" class="form-check-label"></label></div></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- الشريط الجانبي -->
        <div class="col-lg-4">
            <!-- بيانات الإمام -->
            <div class="card mb-4">
                <div class="card-header bg-warning"><h6 class="mb-0"><i class="fas fa-user-tie me-2"></i>بيانات الإمام</h6></div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="ImamName" class="form-label"></label>
                        <input asp-for="ImamName" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="ImamPhone" class="form-label"></label>
                        <input asp-for="ImamPhone" class="form-control" dir="ltr" />
                    </div>
                </div>
            </div>

            <!-- بيانات المؤذن -->
            <div class="card mb-4">
                <div class="card-header bg-secondary text-white"><h6 class="mb-0"><i class="fas fa-user me-2"></i>بيانات المؤذن</h6></div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="MuezzinName" class="form-label"></label>
                        <input asp-for="MuezzinName" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="MuezzinPhone" class="form-label"></label>
                        <input asp-for="MuezzinPhone" class="form-control" dir="ltr" />
                    </div>
                </div>
            </div>

            <!-- أهلية الوقف وحالة الجامع -->
            <div class="card mb-4">
                <div class="card-header" style="background:#6f42c1;color:#fff"><h6 class="mb-0"><i class="fas fa-mosque me-2"></i>أهلية الوقف والحالة</h6></div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="WaqfNature" class="form-label fw-bold">طبيعة الوقف</label>
                            <select asp-for="WaqfNature" class="form-select" id="waqfNatureSelect" onchange="toggleAdminReceived()">
                                <option value="Khairi">خيري</option>
                                <option value="Ahli">أهلي</option>
                            </select>
                        </div>
                        <div class="col-md-4" id="adminReceivedGroup" style="display:none">
                            <label class="form-label fw-bold">مستلمة إدارياً</label>
                            <div class="d-flex gap-3 mt-2">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="IsAdminReceived" id="adminRecYes" value="true" @(Model.IsAdminReceived == true ? "checked" : "") />
                                    <label class="form-check-label" for="adminRecYes">نعم</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="IsAdminReceived" id="adminRecNo" value="false" @(Model.IsAdminReceived == false ? "checked" : "") />
                                    <label class="form-check-label" for="adminRecNo">لا</label>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="WaqfCondition" class="form-label fw-bold">شرط الوقف</label>
                            <select asp-for="WaqfCondition" class="form-select">
                                <option value="WithoutCondition">بدون شرط</option>
                                <option value="WithCondition">بشرط</option>
                            </select>
                        </div>
                    </div>
                    <hr class="my-3" />
                    <div class="row g-3">
                        <div class="col-md-4">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" asp-for="IsUsurped" id="isUsurped" />
                                <label class="form-check-label text-danger fw-bold" for="isUsurped"><i class="fas fa-exclamation-triangle me-1"></i>مغتصب</label>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" asp-for="IsClosed" id="isClosed" />
                                <label class="form-check-label text-warning fw-bold" for="isClosed"><i class="fas fa-lock me-1"></i>مغلق</label>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" asp-for="IsContested" id="isContested" />
                                <label class="form-check-label text-info fw-bold" for="isContested"><i class="fas fa-gavel me-1"></i>متنازع عليه</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ملفات التسجيل -->
            <div class="card mb-4">
                <div class="card-header bg-warning text-dark"><h6 class="mb-0"><i class="fas fa-file-alt me-2"></i>مستندات وملفات التسجيل</h6></div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-5">
                            <label class="form-label">نوع المستند</label>
                            <select name="regDocType" class="form-select">
                                <option value="سند ملكية">سند ملكية</option>
                                <option value="قرار تخصيص">قرار تخصيص</option>
                                <option value="عقد إيجار">عقد إيجار</option>
                                <option value="وثيقة وقف">وثيقة وقف</option>
                                <option value="أخرى">أخرى</option>
                            </select>
                        </div>
                        <div class="col-md-7">
                            <label class="form-label">اختيار الملف (أو عدة ملفات)</label>
                            <input type="file" name="regFiles" class="form-control" multiple accept=".pdf,.doc,.docx,.jpg,.jpeg,.png,.xlsx" />
                            <small class="text-muted">يقبل PDF, Word, صور, Excel</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- صور المسجد -->
            <div class="card mb-4">
                <div class="card-header bg-info text-white"><h6 class="mb-0"><i class="fas fa-images me-2"></i>صور المسجد</h6></div>
                <div class="card-body">
                    <input type="file" name="images" class="form-control" id="imageInput" multiple accept="image/*" onchange="previewImages(this)" />
                    <small class="text-muted d-block mt-1">يمكنك اختيار عدة صور (الحد الأقصى 10MB)</small>
                    <div id="imagePreview" class="row g-2 mt-2"></div>
                </div>
            </div>

            <!-- ملاحظات -->
            <div class="card mb-4">
                <div class="card-header bg-light"><h6 class="mb-0"><i class="fas fa-sticky-note me-2"></i>ملاحظات</h6></div>
                <div class="card-body">
                    <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                </div>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary btn-lg"><i class="fas fa-save me-2"></i>حفظ المسجد</button>
                <a asp-action="Index" class="btn btn-outline-secondary">إلغاء</a>
            </div>
        </div>
    </div>
</form>

<!-- Modal لعرض الصور بالحجم الطبيعي -->
<div class="modal fade" id="imageModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body p-0">
                <img id="modalImage" src="" class="img-fluid w-100" />
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/js/coordinates-helper.js"></script>
<script>
    var osmLayerCreate = L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '© OpenStreetMap' });
    var satLayerCreate = L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', { attribution: '© Esri' });

    var map = L.map('locationMap', { layers: [osmLayerCreate] }).setView([33.3, 44.4], 7);
    var marker = null;

    function setCreateBaseMap(type) {
        map.removeLayer(osmLayerCreate); map.removeLayer(satLayerCreate);
        if (type === 'osm') map.addLayer(osmLayerCreate);
        else map.addLayer(satLayerCreate);
    }

    map.on('click', function(e) {
        if (marker) marker.setLatLng(e.latlng);
        else {
            marker = L.marker(e.latlng, {draggable: true}).addTo(map);
            marker.on('dragend', updateCoords);
        }
        updateCoords();
        // مسح نتيجة الرابط عند النقر على الخريطة
        var rd = document.getElementById('linkResult_mosque_create');
        if (rd) rd.style.display = 'none';
    });

    function updateCoords() {
        if (marker) {
            var ll = marker.getLatLng();
            document.getElementById('latitude').value = ll.lat.toFixed(6);
            document.getElementById('longitude').value = ll.lng.toFixed(6);
        }
    }

    // تهيئة مساعد الإحداثيات
    window['locationMap_mosque_create'] = map;
    window['locationMarker_mosque_create'] = marker;
    // تحديث الـ marker reference عند إنشائه
    var origClick = map._events.click;
    // دالة مخصصة لتحديث الخريطة من مساعد الإحداثيات
    function updateMapMarker(uniqueId, lat, lng, flyToMap) {
        if (marker) marker.setLatLng([lat, lng]);
        else {
            marker = L.marker([lat, lng], {draggable: true}).addTo(map);
            marker.on('dragend', updateCoords);
            window['locationMarker_mosque_create'] = marker;
        }
        document.getElementById('latitude').value = lat.toFixed(6);
        document.getElementById('longitude').value = lng.toFixed(6);
        if (flyToMap !== false) map.flyTo([lat, lng], Math.max(map.getZoom(), 16), {duration: 0.8});
    }

    // أهلية الوقف
    function toggleAdminReceived() {
        var sel = document.getElementById('waqfNatureSelect');
        var grp = document.getElementById('adminReceivedGroup');
        if (sel && grp) grp.style.display = sel.value === 'Ahli' ? 'block' : 'none';
    }
    toggleAdminReceived();

    // معاينة الصور
    function previewImages(input) {
        var preview = document.getElementById('imagePreview');
        preview.innerHTML = '';
        if (input.files) {
            Array.from(input.files).forEach(function(file, i) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    preview.innerHTML += '<div class="col-6"><img src="'+e.target.result+'" class="img-fluid rounded" style="cursor:pointer;max-height:100px;object-fit:cover;width:100%;" onclick="showImage(\''+e.target.result+'\')"></div>';
                };
                reader.readAsDataURL(file);
            });
        }
    }

    function showImage(src) {
        document.getElementById('modalImage').src = src;
        new bootstrap.Modal(document.getElementById('imageModal')).show();
    }
</script>

@await Html.PartialAsync("_CascadingDistricts")
}
